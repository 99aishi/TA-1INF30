		<property name="com.jaspersoft.studio.field.label" value="cantidad_solicitudes"/>
	</field>
	<field name="monto_total_solicitado" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="monto_total_solicitado"/>
		<property name="com.jaspersoft.studio.field.label" value="monto_total_solicitado"/>
	</field>
	<variable name="totalSolicitudes" calculation="Sum" class="java.lang.Long">
		<expression><![CDATA[$F{cantidad_solicitudes}]]></expression>
	</variable>
	<variable name="totalMontoSolicitado" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{monto_total_solicitado}]]></expression>
	</variable>
