	<parameter name="nombreArea" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaInicio" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-01-01")]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaFin" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-12-31")]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
                a.id_area AS id_area,
                a.nombre_area AS area,
                u.id_usuario AS id_empleado,
                CONCAT(
                    u.nombres, ' ',
                    u.apellido_paterno, ' ',
                    IFNULL(u.apellido_materno, '')
                ) AS empleado,
                COUNT(sg.id_solicitud_gasto) AS cantidad_solicitudes,
                SUM(sg.monto_solicitado) AS monto_total_solicitado
            FROM ope_solicitud_gasto sg
            INNER JOIN rrhh_empleado e
                ON sg.id_usuario_solicitante = e.id_usuario
            INNER JOIN rrhh_usuario u
                ON e.id_usuario = u.id_usuario
            INNER JOIN rrhh_area a
                ON e.id_area = a.id_area
            WHERE
                a.nombre_area = $P{nombreArea}
                AND DATE(sg.fecha_solicitud) BETWEEN $P{fechaInicio} AND $P{fechaFin}
            GROUP BY
                a.id_area,
                a.nombre_area,
                u.id_usuario,
                u.nombres,
                u.apellido_paterno,
                u.apellido_materno
            ORDER BY
                SUM(sg.monto_solicitado) DESC]]></query>
