@using EconomixWS.UsuarioWS
@inherits LayoutComponentBase
@inject IUsuarioWS UsuarioWS
@inject NavigationManager Navigation

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (isAuthenticated)
{
    <div class="page d-flex flex-column vh-100 overflow-hidden">
        <header class="top-row d-flex justify-content-between align-items-center px-3">
            <Encabezado Usuario="currentUser"/>
            
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-danger btn-sm" @onclick="Logout"> 
                    Cerrar sesion</button>
            </div>
        </header>

        <div class="sidebar">
            <NavMenu UsuarioCategoria="@(currentUser?.Rol?.Titulo ?? "")"/>
        </div>

        <main class="flex-fill d-flex flex-column overflow-hidden">
            <article class="content h-100">
                @Body
            </article>
        </main>
    </div>
}
else if (!isLoginPage)
{
    Navigation.NavigateTo($"/?returnUrl={Uri.EscapeDataString(currentUrl)}", forceLoad: true);
}
else
{
    <div class="page d-flex flex-column vh-100 overflow-hidden">
        <main class="flex-fill d-flex flex-column overflow-hidden">
            <article class="content h-100">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool isLoginPage = false;
    private Usuario? currentUser;
    private string currentUrl = "/";

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        currentUrl = uri.AbsolutePath;
        isLoginPage = currentUrl == "/";
        
        isAuthenticated =  UsuarioWS.IsAuthenticated();
        
        if (isAuthenticated)
        {
            currentUser = UsuarioWS.GetCurrentUser();
        }
        
        isLoading = false;
    }
    
    private void Logout()
    { 
        Navigation.NavigateTo("/auth/logout", forceLoad: true);
    }
}
