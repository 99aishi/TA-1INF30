<div class="d-flex justify-content-between w-100 mt-3">
    <div class="d-flex justify-content-between align-items-center">
        <div class="rounded-3 me-3 mi-logo-box">
            
        </div>
        <div>
            <h1 class="h5 mb-0 fw-bold text-dark">Sistema de Caja Chica</h1>
            <p class="small mb-0 text-muted">Gestión y control de fondos</p>
        </div>
    </div>    

    <div class="d-flex align-items-center">
        <div class="text-end me-3">
            <h2 class="h6 mb-0 fw-semibold text-dark">@NombreCompleto</h2>
            <p class="small mb-0 text-muted">@Rol</p>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white @AvatarColor" style="width: 40px; height: 40px;">
            @Initial
        </div>
    </div>
</div>


@code {
    [Parameter] public Usuario? Usuario { get; set; }

    private string Initial => string.IsNullOrEmpty(Usuario?.Nombres)
        ? "?"
        : Usuario.Nombres.Substring(0, 1).ToUpper();

    private string NombreCompleto => Usuario != null
        ? $"{Usuario.Nombres} {Usuario.ApellidoPaterno}"
        : "Usuario";

    private string Rol => Usuario?.Rol?.Titulo ?? "Sin rol";

    private static readonly string[] AvatarColors = { "bg-primary", "bg-success", "bg-info", "bg-warning", "bg-danger", "bg-secondary" };
    private string AvatarColor { get; set; } = "bg-primary";

    protected override void OnInitialized()
    {
        AvatarColor = AvatarColors[Random.Shared.Next(AvatarColors.Length)];
    }
}
