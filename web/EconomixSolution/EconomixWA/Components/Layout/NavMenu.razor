@inject NavigationManager Navigation

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-row">
        @foreach (String opcion in opcionesMenu)
        {
            <div class="nav-item pt-0 px-3 d-flex flex-column">
                <a class="nav-link @ObtenerClaseActiva(opcion)" href="@($"/{opcion}")">
                    @opcion
                </a>
            </div>
        }
    </nav>
</div>

@code {
    public List<String> opcionesMenu = new();

    [Parameter] public String UsuarioCategoria { get; set; } = string.Empty;

    private String NombreEmpleado { get; set; } = string.Empty;
    private String RolEmpleado { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += (s, e) => StateHasChanged();

        string categoria = UsuarioCategoria?.Trim() ?? "";
        if (categoria.Equals("Administrador", StringComparison.OrdinalIgnoreCase))
        {
            opcionesMenu = new List<String>() { "Dashboard", "Areas", "Roles", "Usuarios", "Cuentas Bancarias", "Monedas", "Caja Chica", "Ciclos", "Solicitudes de Gasto", "Transacciones", "Comprobantes de Pago", "Rendiciones" };
        }
        else if (categoria.Equals("Jefe", StringComparison.OrdinalIgnoreCase) || 
                 categoria.Equals("Jefe de Área", StringComparison.OrdinalIgnoreCase) || 
                 categoria.Equals("Jefe de Area", StringComparison.OrdinalIgnoreCase))
        {
            opcionesMenu = new List<String>() { "Dashboard", "Mis Solicitudes de Gasto", "Solicitudes de Gasto", "Comprobantes de Pago", "Rendiciones", "Transacciones" };
        }
        else if (categoria.Equals("Empleado", StringComparison.OrdinalIgnoreCase))
        {
            opcionesMenu = new List<String>() { "Dashboard", "Mis Solicitudes de Gasto", "Mis Comprobantes de Pago",  "Transacciones" };
        }
        else if (categoria.Equals("Tesoreria", StringComparison.OrdinalIgnoreCase) || 
                 categoria.Equals("Tesorero", StringComparison.OrdinalIgnoreCase) || 
                 categoria.Equals("Tesorero y Finanzas", StringComparison.OrdinalIgnoreCase))
        {
            opcionesMenu = new List<String>() { "Dashboard", "Caja Chica", "Transacciones", "Solicitudes de Gasto", "Comprobantes de Pago", "Rendiciones" };
        }
        else
        {
            opcionesMenu = new List<String> { "Dashboard" };
        }
    }

    private string ObtenerClaseActiva(string opcion)
    {
        var uriActual = Navigation.Uri;
        var rutaRelativa = Navigation.ToBaseRelativePath(uriActual);

        // Remove query string
        var indiceQuery = rutaRelativa.IndexOf('?');
        if (indiceQuery >= 0)
            rutaRelativa = rutaRelativa.Substring(0, indiceQuery);

        var opcionNormalizada = opcion.Trim().Replace(" ", "%20");
        var rutaNormalizada = rutaRelativa.Trim().Replace(" ", "%20");

        if (string.IsNullOrEmpty(rutaNormalizada))
            return opcion.Equals("Dashboard", StringComparison.OrdinalIgnoreCase) ? "active" : "";

        // Exact match or starts with the menu option path
        if (rutaNormalizada.Equals(opcionNormalizada, StringComparison.OrdinalIgnoreCase)
            || rutaNormalizada.StartsWith($"{opcionNormalizada}/", StringComparison.OrdinalIgnoreCase))
        {
            return "active";
        }

        return "";
    }
}