@inject NavigationManager Navigation

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-row">
        @foreach (String opcion in opcionesMenu)
        {
            <div class="nav-item pt-0 px-3 d-flex flex-column">
                <a class="nav-link @ObtenerClaseActiva(opcion)" href="@($"/{opcion}")">
                    @opcion
                </a>
            </div>
        }
    </nav>
</div>

@code {
    public List<String> opcionesMenu = new();

    [Parameter] public String UsuarioCategoria { get; set; } = string.Empty;

    private String NombreEmpleado { get; set; }= "Pedro Paramo";
    private String RolEmpleado { get; set; } = "Jefe de TI";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += (s, e) => StateHasChanged();

        switch (UsuarioCategoria)
        {
            case "Administrador":
                opcionesMenu = new List<String>() { "Dashboard", "Areas", "Roles", "Usuarios", "Cuentas Bancarias", "Caja Chica", "Solicitudes de Gasto", "Transacciones", "Comprobantes de Pago", "Rendiciones", "Monedas" };
                break;
            case "Jefe":
            case "Jefe de Área":
            case "Jefe de Area":
                opcionesMenu = new List<String>() { "Dashboard", "Mis Solicitudes de Gasto", "Solicitudes de Gasto", "Comprobantes de Pago", "Rendiciones", "Permisos Pendientes", "Transacciones"};
                break;
            case "Empleado":
                opcionesMenu = new List<String>() { "Dashboard", "Mis Solicitudes de Gasto", "Mis Comprobantes de Pago", "Comprobantes de Pago" };
                break;
            case "Tesoreria":
            case "Tesorero":
            case "Tesorero y Finanzas":
                opcionesMenu = new List<String>() { "Dashboard", "Caja Chica", "Transacciones", "Solicitudes de Gasto", "Comprobantes de Pago", "Rendiciones", "Permisos Pendientes" };
                break;
            default:
                opcionesMenu = new List<String> { "Dashboard" };
                break;
        }
    }

    private string ObtenerClaseActiva(string opcion)
    {
        var uriActual = Navigation.Uri;
        var rutaRelativa = Navigation.ToBaseRelativePath(uriActual);

        // Remove query string
        var indiceQuery = rutaRelativa.IndexOf('?');
        if (indiceQuery >= 0)
            rutaRelativa = rutaRelativa.Substring(0, indiceQuery);

        var opcionNormalizada = opcion.Trim().Replace(" ", "%20");
        var rutaNormalizada = rutaRelativa.Trim().Replace(" ", "%20");

        if (string.IsNullOrEmpty(rutaNormalizada))
            return opcion.Equals("Dashboard", StringComparison.OrdinalIgnoreCase) ? "active" : "";

        // Exact match or starts with the menu option path
        if (rutaNormalizada.Equals(opcionNormalizada, StringComparison.OrdinalIgnoreCase)
            || rutaNormalizada.StartsWith($"{opcionNormalizada}/", StringComparison.OrdinalIgnoreCase))
        {
            return "active";
        }

        return "";
    }
}