<div class="card rounded-4 p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Banco</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="Nombre del banco..."
                   value="@BusquedaBanco"
                   @oninput="OnBancoCambiado" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Cuenta / CCI</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="Número o CCI..."
                   value="@BusquedaCuentaCCI"
                   @oninput="OnCuentaCCICambiado" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Moneda</label>
            <select class="form-select bg-light rounded-4"
                    value="@MonedaSeleccionadaId"
                    @onchange="OnMonedaCambiada">
                <option value="0">Todas</option>
                @foreach (var moneda in Monedas)
                {
                    <option value="@moneda.IdMoneda">@moneda.Simbolo - @moneda.Nombre</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Área</label>
            <select class="form-select bg-light rounded-4"
                    value="0"
                    @onchange="OnAreaSeleccionada">
                <option value="0">Todas</option>
                @foreach (var area in AreasDisponibles)
                {
                    <option value="@area.AreaID">@area.Nombre</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Nombre del empleado</label>
            <div class="position-relative">
                <input type="text"
                       class="form-control bg-light rounded-4"
                       placeholder="Buscar empleado..."
                       value="@BusquedaEmpleado"
                       @oninput="OnBusquedaEmpleadoCambiada"
                       @onfocus="() => MostrarDropdown = BusquedaEmpleado.Length >= 2"
                       @onblur="OnBlurEmpleado" />
                @if (MostrarDropdown && ResultadosBusqueda.Any())
                {
                    <div class="position-absolute top-100 start-0 w-100 bg-white border rounded-4 shadow-sm z-3"
                         style="max-height:200px;overflow-y:auto;">
                        @foreach (var emp in ResultadosBusqueda)
                        {
                            <div class="px-3 py-2 small cursor-pointer d-flex align-items-center"
                                 @onmouseenter="() => _hoveredEmpId = emp.UsuarioID"
                                 @onmouseleave="() => _hoveredEmpId = null"
                                 @onmousedown="() => SeleccionarEmpleado(emp)"
                                 style="@(_hoveredEmpId == emp.UsuarioID ? "background-color:#e9ecef;" : "")">
                                <span>@emp.Nombres @emp.ApellidoPaterno @emp.ApellidoMaterno</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="col-12 col-md-2 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-outline-secondary rounded-4" @onclick="Limpiar">
                Limpiar
            </button>
        </div>
    </div>
    @if (AreasSeleccionadas.Any() || EmpleadosSeleccionados.Any())
    {
        <div class="row mt-2">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var area in AreasSeleccionadas)
                    {
                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill d-flex align-items-center gap-1">
                            @area.Nombre
                            <button type="button" class="btn-close"
                                    style="font-size:0.6em;"
                                    @onclick="() => QuitarArea(area)">
                            </button>
                        </span>
                    }
                    @foreach (var emp in EmpleadosSeleccionados)
                    {
                        <span class="badge bg-primary-subtle text-primary-emphasis rounded-pill d-flex align-items-center gap-1">
                            @emp.Nombres @emp.ApellidoPaterno
                            <button type="button" class="btn-close"
                                    style="font-size:0.6em;"
                                    @onclick="() => QuitarEmpleado(emp)">
                            </button>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string BusquedaBanco { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> BusquedaBancoChanged { get; set; }

    [Parameter]
    public string BusquedaCuentaCCI { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> BusquedaCuentaCCIChanged { get; set; }

    [Parameter]
    public int MonedaSeleccionadaId { get; set; }

    [Parameter]
    public EventCallback<int> MonedaSeleccionadaIdChanged { get; set; }

    [Parameter]
    public List<Moneda> Monedas { get; set; } = new();

    [Parameter]
    public List<Area> Areas { get; set; } = new();

    [Parameter]
    public List<Area> AreasSeleccionadas { get; set; } = new();

    [Parameter]
    public EventCallback<List<Area>> AreasSeleccionadasChanged { get; set; }

    [Parameter]
    public List<Empleado> Empleados { get; set; } = new();

    [Parameter]
    public List<Empleado> EmpleadosSeleccionados { get; set; } = new();

    [Parameter]
    public EventCallback<List<Empleado>> EmpleadosSeleccionadosChanged { get; set; }

    [Parameter]
    public EventCallback OnBuscar { get; set; }

    private string BusquedaEmpleado { get; set; } = string.Empty;
    private bool MostrarDropdown { get; set; }
    private int? _hoveredEmpId;
    private IEnumerable<Empleado> ResultadosBusqueda =>
        Empleados
            .Where(e => !EmpleadosSeleccionados.Any(s => s.UsuarioID == e.UsuarioID))
            .Where(e => (e.Nombres ?? "").Contains(BusquedaEmpleado, StringComparison.OrdinalIgnoreCase)
                     || (e.ApellidoPaterno ?? "").Contains(BusquedaEmpleado, StringComparison.OrdinalIgnoreCase)
                     || (e.ApellidoMaterno ?? "").Contains(BusquedaEmpleado, StringComparison.OrdinalIgnoreCase))
            .Take(10);

    private IEnumerable<Area> AreasDisponibles =>
        Areas.Where(a => !AreasSeleccionadas.Any(s => s.AreaID == a.AreaID));

    private async Task OnBancoCambiado(ChangeEventArgs e)
    {
        BusquedaBanco = e.Value?.ToString() ?? string.Empty;
        await BusquedaBancoChanged.InvokeAsync(BusquedaBanco);
        await OnBuscar.InvokeAsync();
    }

    private async Task OnCuentaCCICambiado(ChangeEventArgs e)
    {
        BusquedaCuentaCCI = e.Value?.ToString() ?? string.Empty;
        await BusquedaCuentaCCIChanged.InvokeAsync(BusquedaCuentaCCI);
        await OnBuscar.InvokeAsync();
    }

    private async Task OnMonedaCambiada(ChangeEventArgs e)
    {
        MonedaSeleccionadaId = int.TryParse(e.Value?.ToString(), out var val) ? val : 0;
        await MonedaSeleccionadaIdChanged.InvokeAsync(MonedaSeleccionadaId);
        await OnBuscar.InvokeAsync();
    }

    private async Task OnAreaSeleccionada(ChangeEventArgs e)
    {
        var areaId = int.TryParse(e.Value?.ToString(), out var val) ? val : 0;
        if (areaId > 0)
        {
            var area = Areas.FirstOrDefault(a => a.AreaID == areaId);
            if (area != null && AreasSeleccionadas.All(a => a.AreaID != areaId))
            {
                AreasSeleccionadas = new List<Area>(AreasSeleccionadas) { area };
                await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
                await OnBuscar.InvokeAsync();
            }
        }
    }

    private async Task QuitarArea(Area area)
    {
        AreasSeleccionadas = AreasSeleccionadas.Where(a => a.AreaID != area.AreaID).ToList();
        await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
        await OnBuscar.InvokeAsync();
    }

    private async Task OnBusquedaEmpleadoCambiada(ChangeEventArgs e)
    {
        BusquedaEmpleado = e.Value?.ToString() ?? string.Empty;
        MostrarDropdown = BusquedaEmpleado.Length >= 2;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SeleccionarEmpleado(Empleado emp)
    {
        if (EmpleadosSeleccionados.All(e => e.UsuarioID != emp.UsuarioID))
        {
            EmpleadosSeleccionados = new List<Empleado>(EmpleadosSeleccionados) { emp };
            await EmpleadosSeleccionadosChanged.InvokeAsync(EmpleadosSeleccionados);
            await OnBuscar.InvokeAsync();
        }
        BusquedaEmpleado = string.Empty;
        MostrarDropdown = false;
    }

    private async Task QuitarEmpleado(Empleado emp)
    {
        EmpleadosSeleccionados = EmpleadosSeleccionados.Where(e => e.UsuarioID != emp.UsuarioID).ToList();
        await EmpleadosSeleccionadosChanged.InvokeAsync(EmpleadosSeleccionados);
        await OnBuscar.InvokeAsync();
    }

    private async Task OnBlurEmpleado()
    {
        await Task.Delay(200);
        MostrarDropdown = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Limpiar()
    {
        BusquedaBanco = string.Empty;
        await BusquedaBancoChanged.InvokeAsync(BusquedaBanco);

        BusquedaCuentaCCI = string.Empty;
        await BusquedaCuentaCCIChanged.InvokeAsync(BusquedaCuentaCCI);

        MonedaSeleccionadaId = 0;
        await MonedaSeleccionadaIdChanged.InvokeAsync(MonedaSeleccionadaId);

        AreasSeleccionadas = new();
        await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);

        EmpleadosSeleccionados = new();
        await EmpleadosSeleccionadosChanged.InvokeAsync(EmpleadosSeleccionados);

        await OnBuscar.InvokeAsync();
    }
}
