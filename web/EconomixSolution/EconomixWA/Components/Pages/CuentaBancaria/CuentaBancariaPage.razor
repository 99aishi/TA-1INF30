@page "/Cuentas Bancarias"
@rendermode InteractiveServer
@using EconomixWA.Components.Pages.CajaChica
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation
@inject ICuentaBancariaWS CuentaBancariaWS
@inject ICajaChicaWS CajaChicaWS
@inject IMonedaWS MonedaWS
@inject IEmpleadoWS EmpleadoWS
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS
@inject IJSRuntime JSRuntime

<div class="h-100 d-flex flex-column">
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Cuentas Bancarias</p>
            <p class="text-muted mb-0">Administración de cuentas bancarias y sus cajas chicas asociadas.</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button" class="btn btn-primary" @onclick="PrepararNueva">
                + Agregar cuenta
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <CuentaBancariaSearchBar @bind-BusquedaBanco="BusquedaBanco"
                             @bind-BusquedaCuentaCCI="BusquedaCuentaCCI"
                             @bind-MonedaSeleccionadaId="FiltroMonedaId"
                             @bind-FiltroAreaId="FiltroAreaIdBusqueda"
                             @bind-TipoDueno="FiltroTipoDueno"
                             Monedas="Monedas"
                             Areas="Areas"
                             OnBuscar="Filtrar" />

    <div class="d-flex flex-column flex-fill overflow-hidden">
        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(MostrarPanelLateral ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">
                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando cuentas...</p>
                        </div>
                    }
                    else if (CuentasFiltradas.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ninguna cuenta coincide con los filtros" : "No se encontraron cuentas bancarias")
                            </p>
                        </div>
                    }
                    else
                    {
                        @foreach (var cuenta in CuentasFiltradas)
                        {
                             <CuentaBancariaItem Cuenta="cuenta"
                                                 Empleados="Empleados"
                                                 Areas="Areas"
                                                 Seleccionada="@(CuentaSeleccionada?.IdCuenta == cuenta.IdCuenta)"
                                                 OnSeleccionar="() => Seleccionar(cuenta)"
                                                 OnVer="() => Seleccionar(cuenta)" />
                        }
                    }
                </div>
            </div>

            @if (MostrarCajaChicaDetalle && CajaChicaEnEdicion != null)
            {
                <div class="col-6 h-100">
                    <CajaChicaDetalle CajaChica="CajaChicaEnEdicion"
                                      OnCerrarDetalle="CerrarCajaChicaDetalle" />
                </div>
            }
            else if (MostrarEditor && CuentaEnEdicion != null)
            {
                <div class="col-6 h-100 d-flex flex-column gap-3">
                    <div class="card rounded-4 d-flex flex-column h-100 overflow-hidden">
                        <div class="p-3 pb-2">
                            <p class="h5 mb-0">@(CuentaEnEdicion.IdCuenta > 0 ? "Editar cuenta" : "Nueva cuenta")</p>
                        </div>
                        <hr class="my-0" />
                        <div class="p-3 overflow-scroll flex-fill">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label small text-muted">Banco</label>
                                    <input type="text" class="form-control rounded-4 bg-light @(Errores.ContainsKey("NombreBanco") ? "is-invalid" : "")"
                                           placeholder="Nombre del banco" @bind="CuentaEnEdicion.NombreBanco">
                                    @if (Errores.ContainsKey("NombreBanco"))
                                    {
                                        <div class="text-danger small mt-1">@Errores["NombreBanco"]</div>
                                    }
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-muted">Número de cuenta</label>
                                    <input type="text" class="form-control rounded-4 bg-light @(Errores.ContainsKey("NumeroBancario") ? "is-invalid" : "")"
                                           placeholder="Mínimo 10 dígitos" @bind="CuentaEnEdicion.NumeroBancario">
                                    @if (Errores.ContainsKey("NumeroBancario"))
                                    {
                                        <div class="text-danger small mt-1">@Errores["NumeroBancario"]</div>
                                    }
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-muted">CCI</label>
                                    <input type="text" class="form-control rounded-4 bg-light @(Errores.ContainsKey("Cci") ? "is-invalid" : "")"
                                           placeholder="20 dígitos" @bind="CuentaEnEdicion.Cci">
                                    @if (Errores.ContainsKey("Cci"))
                                    {
                                        <div class="text-danger small mt-1">@Errores["Cci"]</div>
                                    }
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-muted">Moneda</label>
                                    <select class="form-select rounded-4 bg-light @(Errores.ContainsKey("Moneda") ? "is-invalid" : "")"
                                            @bind="MonedaSeleccionadaId">
                                        <option value="0">Seleccione una moneda</option>
                                        @foreach (var moneda in Monedas)
                                        {
                                            <option value="@moneda.IdMoneda">@moneda.Simbolo - @moneda.Nombre</option>
                                        }
                                    </select>
                                    @if (Errores.ContainsKey("Moneda"))
                                    {
                                        <div class="text-danger small mt-1">@Errores["Moneda"]</div>
                                    }
                                </div>

                                <div class="col-12">
                                    <label class="form-label small text-muted">Dueño</label>
                                    <select class="form-select rounded-4 bg-light"
                                            @bind="TipoDuenoEdicion"
                                            disabled="@(CuentaEnEdicion.IdCuenta > 0)">
                                        <option value="">Seleccione tipo de dueño</option>
                                        <option value="Empleado">Empleado</option>
                                        <option value="Area">Área</option>
                                    </select>

                                    @if (TipoDuenoEdicion == "Empleado")
                                    {
                                        <select class="form-select rounded-4 bg-light @(Errores.ContainsKey("Dueno") ? "is-invalid" : "")"
                                                @bind="EmpleadoSeleccionadoId"
                                                disabled="@(CuentaEnEdicion.IdCuenta > 0)">
                                            <option value="0">Seleccione un empleado</option>
                                            @foreach (var emp in Empleados)
                                            {
                                                <option value="@emp.UsuarioID">@emp.Nombres @emp.ApellidoPaterno</option>
                                            }
                                        </select>
                                    }
                                    else if (TipoDuenoEdicion == "Area")
                                    {
                                        <select class="form-select rounded-4 bg-light @(Errores.ContainsKey("Dueno") ? "is-invalid" : "")"
                                                @bind="AreaSeleccionadaId"
                                                disabled="@(CuentaEnEdicion.IdCuenta > 0)">
                                            <option value="0">Seleccione un área</option>
                                            @foreach (var area in Areas)
                                            {
                                                <option value="@area.AreaID">@area.Nombre</option>
                                            }
                                        </select>
                                    }
                                    @if (Errores.ContainsKey("Dueno"))
                                    {
                                        <div class="text-danger small mt-1">@Errores["Dueno"]</div>
                                    }
                                </div>
                            </div>
                        </div>
                        <hr class="my-0" />
                        <div class="p-3 d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-warning" @onclick="Guardar">
                                Guardar Cambios
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CerrarEditor">
                                Cancelar
                            </button>
                            @if (CuentaEnEdicion.IdCuenta > 0)
                            {
                                <button type="button" class="btn btn-outline-danger" @onclick="Eliminar">
                                    Eliminar
                                </button>
                            }
                        </div>
                    </div>

                    @if (CuentaEnEdicion.IdCuenta > 0)
                    {
                        <div class="card rounded-4 flex-fill d-flex flex-column overflow-hidden">
                            <div class="p-3 pb-2 d-flex justify-content-between align-items-center">
                                <p class="h5 mb-0">Cajas Chicas</p>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="PrepararNuevaCajaChica">
                                    + Agregar
                                </button>
                            </div>
                            <hr class="my-0" />
                            <div class="p-3 overflow-scroll flex-fill">
                                @if (CargandoCajasChicas)
                                {
                                    <div class="d-flex justify-content-center align-items-center h-100">
                                        <p class="text-muted">Cargando cajas chicas...</p>
                                    </div>
                                }
                                else if (CajasChicasDeCuenta.Count == 0)
                                {
                                    <div class="d-flex justify-content-center align-items-center h-100">
                                        <p class="text-muted">No hay cajas chicas registradas para esta cuenta</p>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var cc in CajasChicasDeCuenta)
                                    {
                                        <CajaChicaItemSimple CajaChica="cc"
                                                             CuentasBancarias="Cuentas"
                                                             OnVerCiclos="() => IrACiclos(cc)"
                                                             OnEditar="() => EditarCajaChica(cc)"
                                                             OnEliminar="() => EliminarCajaChica(cc)"
                                                             OnRecuperar="() => RecuperarCajaChica(cc)" />
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public int? EmpleadoId { get; set; }

    [SupplyParameterFromQuery]
    public int? AreaId { get; set; }

    private bool Cargando { get; set; } = true;
    private bool CargandoCajasChicas { get; set; }
    private bool MostrarEditor { get; set; }
    private bool MostrarCajaChicaDetalle { get; set; }
    private bool MostrarPanelLateral => MostrarEditor || MostrarCajaChicaDetalle;
    private string ErrorMessage { get; set; } = string.Empty;
    private string BusquedaBanco { get; set; } = string.Empty;
    private string BusquedaCuentaCCI { get; set; } = string.Empty;
    private int FiltroMonedaId { get; set; }
    private int FiltroAreaIdBusqueda { get; set; }
    private string FiltroTipoDueno { get; set; } = "Todos";

    private List<CuentaBancaria> Cuentas { get; set; } = new();
    private List<CajaChica> CajasChicas { get; set; } = new();
    private List<CajaChica> CajasChicasDeCuenta { get; set; } = new();
    private List<Moneda> Monedas { get; set; } = new();
    private List<Empleado> Empleados { get; set; } = new();
    private List<Area> Areas { get; set; } = new();

    private CuentaBancaria? CuentaSeleccionada { get; set; }
    private CuentaBancaria CuentaEnEdicion { get; set; } = new();
    private CajaChica? CajaChicaEnEdicion { get; set; }
    private Dictionary<string, string> Errores { get; set; } = new();

    private string TipoDuenoEdicion { get; set; } = string.Empty;
    private int EmpleadoSeleccionadoId { get; set; }
    private int AreaSeleccionadaId { get; set; }

    private int MonedaSeleccionadaId
    {
        get => CuentaEnEdicion.Moneda?.IdMoneda ?? 0;
        set
        {
            CuentaEnEdicion.Moneda = value == 0
                ? null
                : Monedas.FirstOrDefault(m => m.IdMoneda == value);
        }
    }

    private bool HayFiltroEntidad => EmpleadoId.HasValue || AreaId.HasValue;

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(BusquedaBanco)
        || !string.IsNullOrWhiteSpace(BusquedaCuentaCCI)
        || FiltroMonedaId > 0
        || FiltroAreaIdBusqueda > 0
        || FiltroTipoDueno != "Todos";

    private IEnumerable<CuentaBancaria> CuentasFiltradas => Cuentas
        .Where(c => !HayFiltroEntidad
            || (EmpleadoId.HasValue && EmpleadoId > 0 && c.EmpleadoAdministrador?.UsuarioID == EmpleadoId.Value)
            || (AreaId.HasValue && AreaId > 0 && c.AreaAdministradora?.AreaID == AreaId.Value))
        .Where(c => string.IsNullOrWhiteSpace(BusquedaBanco)
            || c.NombreBanco.Contains(BusquedaBanco, StringComparison.OrdinalIgnoreCase))
        .Where(c => string.IsNullOrWhiteSpace(BusquedaCuentaCCI)
            || c.NumeroBancario.Contains(BusquedaCuentaCCI, StringComparison.OrdinalIgnoreCase)
            || (c.Cci?.Contains(BusquedaCuentaCCI, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(c => FiltroMonedaId == 0 || c.Moneda?.IdMoneda == FiltroMonedaId)
        .Where(c => FiltroAreaIdBusqueda <= 0 || c.AreaAdministradora?.AreaID == FiltroAreaIdBusqueda)
        .Where(c => FiltroTipoDueno == "Todos"
            || (FiltroTipoDueno == "Empleado" && c.EmpleadoAdministrador != null)
            || (FiltroTipoDueno == "Area" && c.AreaAdministradora != null));

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await CargarCatalogos();
        await ListarCuentas();
        Cargando = false;

        AplicarFiltroEntidad();
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        AplicarFiltroEntidad();
    }

    private void AplicarFiltroEntidad()
    {
        if (EmpleadoId.HasValue && EmpleadoId > 0)
        {
            if (EmpleadoSeleccionadoId != EmpleadoId.Value)
            {
                PrepararNueva();
                TipoDuenoEdicion = "Empleado";
                EmpleadoSeleccionadoId = EmpleadoId.Value;
            }
        }
        else if (AreaId.HasValue && AreaId > 0)
        {
            if (AreaSeleccionadaId != AreaId.Value)
            {
                PrepararNueva();
                TipoDuenoEdicion = "Area";
                AreaSeleccionadaId = AreaId.Value;
            }
        }
    }

    private async Task CargarCatalogos()
    {
        try { Monedas = await MonedaWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = $"Error al cargar monedas: {ex.Message}"; }

        try { Empleados = await EmpleadoWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = $"Error al cargar empleados: {ex.Message}"; }

        try { Areas = await AreaWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = $"Error al cargar áreas: {ex.Message}"; }
    }

    private async Task ListarCuentas()
    {
        ErrorMessage = string.Empty;
        try { Cuentas = await CuentaBancariaWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = ex.Message; }
    }

    private async Task ListarCajasChicas()
    {
        ErrorMessage = string.Empty;
        try { CajasChicas = await CajaChicaWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = ex.Message; }
    }

    private void Filtrar()
    {
        StateHasChanged();
    }

    private async void Seleccionar(CuentaBancaria cuenta)
    {
        CuentaSeleccionada = cuenta;
        CuentaEnEdicion = new CuentaBancaria
        {
            IdCuenta = cuenta.IdCuenta,
            NombreBanco = cuenta.NombreBanco,
            NumeroBancario = cuenta.NumeroBancario,
            Cci = cuenta.Cci,
            Moneda = cuenta.Moneda != null
                ? new Moneda { IdMoneda = cuenta.Moneda.IdMoneda, Nombre = cuenta.Moneda.Nombre, Simbolo = cuenta.Moneda.Simbolo, CodigoISO = cuenta.Moneda.CodigoISO }
                : null
        };

        if (cuenta.EmpleadoAdministrador != null)
        {
            TipoDuenoEdicion = "Empleado";
            EmpleadoSeleccionadoId = cuenta.EmpleadoAdministrador.UsuarioID;
            AreaSeleccionadaId = 0;
        }
        else if (cuenta.AreaAdministradora != null)
        {
            TipoDuenoEdicion = "Area";
            AreaSeleccionadaId = cuenta.AreaAdministradora.AreaID;
            EmpleadoSeleccionadoId = 0;
        }
        else
        {
            TipoDuenoEdicion = string.Empty;
            EmpleadoSeleccionadoId = 0;
            AreaSeleccionadaId = 0;
        }

        MostrarEditor = true;
        MostrarCajaChicaDetalle = false;
        Errores.Clear();

        await CargarCajasChicasDeCuenta(cuenta.IdCuenta);
    }

    private async Task CargarCajasChicasDeCuenta(int idCuenta)
    {
        CargandoCajasChicas = true;
        try
        {
            CajasChicasDeCuenta = await CajaChicaWS.listarPorCuentaBancariaAsync(idCuenta);
        }
        catch
        {
            CajasChicasDeCuenta = new List<CajaChica>();
        }
        CargandoCajasChicas = false;
        await InvokeAsync(StateHasChanged);
    }

    private void PrepararNueva()
    {
        CuentaSeleccionada = null;
        CuentaEnEdicion = new CuentaBancaria();
        TipoDuenoEdicion = string.Empty;
        EmpleadoSeleccionadoId = 0;
        AreaSeleccionadaId = 0;
        MostrarEditor = true;
        MostrarCajaChicaDetalle = false;
        CajaChicaEnEdicion = null;
        Errores.Clear();
    }

    private void PrepararNuevaCajaChica()
    {
        var cuenta = CuentaSeleccionada;
        if (cuenta == null) return;

        CajaChicaEnEdicion = new CajaChica
        {
            Estado = "ACTIVO",
            CuentaBancaria = new CuentaBancaria
            {
                IdCuenta = cuenta.IdCuenta,
                NombreBanco = cuenta.NombreBanco,
                NumeroBancario = cuenta.NumeroBancario,
                Moneda = cuenta.Moneda != null
                    ? new Moneda { IdMoneda = cuenta.Moneda.IdMoneda, Nombre = cuenta.Moneda.Nombre, Simbolo = cuenta.Moneda.Simbolo, CodigoISO = cuenta.Moneda.CodigoISO }
                    : null
            },
            Moneda = cuenta.Moneda != null
                ? new Moneda { IdMoneda = cuenta.Moneda.IdMoneda, Nombre = cuenta.Moneda.Nombre, Simbolo = cuenta.Moneda.Simbolo, CodigoISO = cuenta.Moneda.CodigoISO }
                : new Moneda()
        };

        MostrarCajaChicaDetalle = true;
    }

    private void EditarCajaChica(CajaChica cc)
    {
        CajaChicaEnEdicion = cc;
        MostrarCajaChicaDetalle = true;
    }

    private async Task CerrarCajaChicaDetalle()
    {
        MostrarCajaChicaDetalle = false;
        CajaChicaEnEdicion = null;
        if (CuentaSeleccionada != null)
            await CargarCajasChicasDeCuenta(CuentaSeleccionada.IdCuenta);
        await ListarCuentas();
    }

    private void IrACiclos(CajaChica cc)
    {
        Navigation.NavigateTo($"/Caja Chica?cajaId={cc.IdFondo}");
    }

    private async Task EliminarCajaChica(CajaChica cc)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"¿Eliminar la caja chica '{cc.Nombre}'?"))
            return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CajaChicaWS.eliminarAsync(cc.IdFondo, idUsuarioAccion);
            if (CuentaSeleccionada != null)
                await CargarCajasChicasDeCuenta(CuentaSeleccionada.IdCuenta);
            await ListarCuentas();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task RecuperarCajaChica(CajaChica cc)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"¿Recuperar la caja chica '{cc.Nombre}'?"))
            return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            cc.Estado = "ACTIVO";
            await CajaChicaWS.actualizarAsync(cc, idUsuarioAccion);
            if (CuentaSeleccionada != null)
                await CargarCajasChicasDeCuenta(CuentaSeleccionada.IdCuenta);
            await ListarCuentas();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private bool Validar()
    {
        Errores.Clear();

        if (string.IsNullOrWhiteSpace(CuentaEnEdicion.NombreBanco))
            Errores["NombreBanco"] = "El nombre del banco es obligatorio.";

        if (string.IsNullOrWhiteSpace(CuentaEnEdicion.NumeroBancario))
            Errores["NumeroBancario"] = "El número de cuenta es obligatorio.";
        else if (CuentaEnEdicion.NumeroBancario.Trim().Length < 10)
            Errores["NumeroBancario"] = "El número de cuenta debe tener al menos 10 caracteres.";

        if (string.IsNullOrWhiteSpace(CuentaEnEdicion.Cci))
            Errores["Cci"] = "El CCI es obligatorio.";
        else if (CuentaEnEdicion.Cci.Trim().Length != 20)
            Errores["Cci"] = "El CCI debe tener exactamente 20 caracteres.";

        if (CuentaEnEdicion.Moneda == null || CuentaEnEdicion.Moneda.IdMoneda <= 0)
            Errores["Moneda"] = "Debe seleccionar una moneda.";

        if (TipoDuenoEdicion == "Empleado" && EmpleadoSeleccionadoId <= 0)
            Errores["Dueno"] = "Debe seleccionar un empleado.";
        else if (TipoDuenoEdicion == "Area" && AreaSeleccionadaId <= 0)
            Errores["Dueno"] = "Debe seleccionar un área.";
        else if (string.IsNullOrEmpty(TipoDuenoEdicion))
            Errores["Dueno"] = "Debe seleccionar el tipo de dueño.";

        return Errores.Count == 0;
    }

    private async Task Guardar()
    {
        if (!Validar()) return;

        ErrorMessage = string.Empty;

        try
        {
            if (TipoDuenoEdicion == "Empleado")
            {
                CuentaEnEdicion.EmpleadoAdministrador = Empleados.First(e => e.UsuarioID == EmpleadoSeleccionadoId);
                CuentaEnEdicion.AreaAdministradora = null;
            }
            else
            {
                CuentaEnEdicion.AreaAdministradora = Areas.First(a => a.AreaID == AreaSeleccionadaId);
                CuentaEnEdicion.EmpleadoAdministrador = null;
            }

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            if (CuentaEnEdicion.IdCuenta > 0)
                await CuentaBancariaWS.actualizarAsync(CuentaEnEdicion, idUsuarioAccion);
            else
                await CuentaBancariaWS.insertarAsync(CuentaEnEdicion, idUsuarioAccion);

            await ListarCuentas();
            CerrarEditor();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task Eliminar()
    {
        ErrorMessage = string.Empty;
        if (CuentaEnEdicion.IdCuenta <= 0) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CuentaBancariaWS.eliminarAsync(CuentaEnEdicion.IdCuenta, idUsuarioAccion);
            await ListarCuentas();
            CerrarEditor();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void CerrarEditor()
    {
        MostrarEditor = false;
        CuentaSeleccionada = null;
        CuentaEnEdicion = new CuentaBancaria();
        Errores.Clear();
    }
}
