@page "/areas"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IAreaWS AreaWS

<div class="h-100 d-flex flex-column">

    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Gestión de Áreas</p>
            <p class="text-muted mb-0">Listado de áreas operativas del sistema</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button"
                    class="btn btn-primary"
                    @onclick="IrRegistrarArea">

                + Agregar Área

            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            Ocurrió un error al cargar las áreas
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <AreaSearchBar @bind-FiltroNombre="FiltroNombre"
                   @bind-FiltroCuentasMin="FiltroCuentasMin"
                   @bind-FiltroCuentasMax="FiltroCuentasMax"
                   @bind-FiltroEstado="FiltroEstado" />

    <div class="d-flex flex-column flex-fill overflow-hidden">

        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class=" @(@MostrarDetalle? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">

                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando Areas...</p>
                        </div>
                    }
                    else if (AreasFiltradas.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ningún área coincide con los filtros aplicados" : "No existe ninguna area registrada")
                            </p>
                        </div>
                    }
                    else
                    {
                         foreach(Area area in AreasFiltradas)
                         {
                              <AreaItem OnMuestraDetalle=" () => MostrarDetalleArea(area)" Area="area" />
                         }
                    }
                </div>

            </div>
            @if (MostrarDetalle && AreaSeleccionada != null)
            {
                <div class="col-6 h-100">
                    <AreaDetalle Area="AreaSeleccionada" OnCerrarDetalle="CerrarDetalleArea"/>
                </div>
            }
        </div>

    </div>

</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private string FiltroNombre { get; set; } = string.Empty;
    private int? FiltroCuentasMin { get; set; }
    private int? FiltroCuentasMax { get; set; }
    private string FiltroEstado { get; set; } = "Todas";
    private List<Area> Areas { get; set; } = new List<Area>();
    private Area? AreaSeleccionada { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroNombre)
        || FiltroCuentasMin.HasValue
        || FiltroCuentasMax.HasValue
        || FiltroEstado != "Todas";

    private IEnumerable<Area> AreasFiltradas => Areas
        .Where(a => string.IsNullOrWhiteSpace(FiltroNombre)
            || a.Nombre.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase))
        .Where(a => !FiltroCuentasMin.HasValue || (a.CuentasBancarias?.Count ?? 0) >= FiltroCuentasMin.Value)
        .Where(a => !FiltroCuentasMax.HasValue || (a.CuentasBancarias?.Count ?? 0) <= FiltroCuentasMax.Value)
        .Where(a => FiltroEstado == "Todas"
            || (FiltroEstado == "Activa" && a.EstaActivo)
            || (FiltroEstado == "Inactiva" && !a.EstaActivo));

    private void IrRegistrarArea()
    {
        Navigation.NavigateTo("/area/Crear");
    }

    private void MostrarDetalleArea(Area area)
    {
        AreaSeleccionada = area;
        MostrarDetalle = true;
    }

    private async Task CerrarDetalleArea()
    {
        await ListarAreas();
        MostrarDetalle = false;
        AreaSeleccionada = null;
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await ListarAreas();
        Cargando = false;
    }

    private async Task ListarAreas()
    {
        ErrorMessage = string.Empty;
        try
        {
            Areas = await Task.Run(() =>
                new List<Area>(AreaWS.listar()));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
