<div class="card rounded-4 p-3 mb-3 bg-light">
    <div class="d-flex flex-row justify-content-between align-items-center">
        <div class="d-flex flex-column">
            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5 mb-1">@(Area?.Nombre ?? "Sin nombre")</p>
                <span class="badge @((Area?.EstaActivo ?? false) ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") rounded-pill">
                    @((Area?.EstaActivo ?? false) ? "Activo" : "Inactivo")
                </span>
            </div>
            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">
                    Responsable: @(Area?.Jefe != null ? $"{Area.Jefe.Nombres} {Area.Jefe.ApellidoPaterno}".Trim() : "Sin asignar")
                </p>
                <p class="text-muted m-0">@(Area?.Descripcion ?? string.Empty)</p>
            </div>
        </div>

        <div class="d-flex flex-row justify-content-between align-items-center gap-4">
            <div class="d-flex flex-column align-items-end">
                <span class="badge bg-primary-subtle text-primary rounded-pill">
                    @(Area?.CuentasBancarias?.Count ?? 0) cuenta(s) bancaria(s)
                </span>
            </div>
            <button class="btn btn-outline-primary" @onclick="AbrirDetalle">
                Ver
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    [Parameter]
    public Area? Area { get; set; }

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
}
