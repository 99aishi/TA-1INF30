<div class="card rounded-4 p-3 mb-3 bg-light">

    <div class="d-flex flex-row justify-content-between align-items-center">

        <div class="d-flex flex-column">

            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5 mb-1">
                    @Area.Nombre
                </p>

                <span class="badge bg-success-subtle text-success rounded-pill">
                    Activo
                </span>
            </div>

            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">
                    Responsable: @(Area.Jefe != null && !string.IsNullOrEmpty(Area.Jefe.Nombres) 
                        ? $"{Area.Jefe.Nombres} {Area.Jefe.ApellidoPaterno} {Area.Jefe.ApellidoMaterno}" 
                        : "Sin asignar")
                </p>
                <p class="text-muted m-0">
                    @Area.Descripcion
                </p>
            </div>

        </div>

        <div class="d-flex flex-row justify-content-between align-items-center gap-5">
            <div class="d-flex flex-column align-items-center gap-2">
                <p class="h4 mb-0" style="width: 120%">
                    S/ 1,000.00
                </p>
                <div class="progress rounded-4 w-100" style="height: 10px;">
                    <div class="progress-bar rounded-4" 
                         style="width: @(Porcentaje.ToString())%" 
                         role="progressbar" 
                         aria-valuenow="1000"
                         aria-valuemin="0" 
                         aria-valuemax="@Area.CajaChica?.MontoTecho">
                    </div>
                </div>
            </div>
            <button class="btn btn-outline-primary" @onclick="AbrirDetalle">
                Ver
            </button>

        </div>

    </div>

</div>

@code {
    [Parameter]
    public EventCallback<Area> OnMuestraDetalle { get; set; }

    [Parameter] 
    public Area? Area { get; set; }

    private double? Porcentaje { get; set; } = 0;
    protected override void OnParametersSet()
    {
        // Validamos que ni Area, ni CajaChica, ni MontoTecho sean nulos, y que el techo sea mayor a 0
        if (Area?.CajaChica?.MontoTecho > 0)
        {
            Porcentaje = (1000.0 / Area.CajaChica.MontoTecho) * 100;
            if (Porcentaje > 100) Porcentaje = 100;
        }
    }
    
    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync(Area);
    }
}