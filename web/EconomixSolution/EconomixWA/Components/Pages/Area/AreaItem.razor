<div class="card rounded-4 p-3 mb-3 bg-light">

    <div class="d-flex flex-row justify-content-between align-items-center">

        <div class="d-flex flex-column">

            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5 mb-1">
                    Área No. 1
                </p>

                <span class="badge bg-success-subtle text-success rounded-pill">
                    Activo
                </span>
            </div>

            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">
                    Recursos Humanos
                </p>

                <p class="text-muted m-0">
                    Responsable: Carlos Ruiz
                </p>
            </div>

        </div>

        <div class="d-flex flex-row justify-content-between align-items-center gap-3">

            <div class="d-flex align-items-center gap-3">
                <p class="h4 mb-0">
                    S/ 8,000.00
                </p>
            </div>

            <div class="d-flex flex-column justify-content-center gap-2">
                <span class="badge bg-primary-subtle text-primary rounded-pill px-2">
                    Fondo máximo
                </span>
            </div>

            <button class="btn btn-primary"
                    @onclick="AbrirDetalle">

                Ver

            </button>

        </div>

    </div>

</div>

@code {
    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
}