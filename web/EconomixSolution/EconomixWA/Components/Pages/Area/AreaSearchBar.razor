@rendermode InteractiveServer

<div class="card rounded-4 p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
            <label class="form-label small text-muted">Nombre</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="Nombre del área"
                   value="@FiltroNombre"
                   @oninput="OnNombreCambiado" />
        </div>
        <div class="col-3 col-md-2">
            <label class="form-label small text-muted">Ctas. mín.</label>
            <input type="number"
                   class="form-control bg-light rounded-4"
                   placeholder="-"
                   value="@FiltroCuentasMin"
                   @oninput="OnCuentasMinCambiado" />
        </div>
        <div class="col-3 col-md-2">
            <label class="form-label small text-muted">Ctas. máx.</label>
            <input type="number"
                   class="form-control bg-light rounded-4"
                   placeholder="-"
                   value="@FiltroCuentasMax"
                   @oninput="OnCuentasMaxCambiado" />
        </div>
        <div class="col-3 col-md-2">
            <label class="form-label small text-muted">Estado</label>
            <select class="form-select bg-light rounded-4"
                    value="@FiltroEstado"
                    @onchange="OnEstadoCambiado">
                <option value="Todas">Todas</option>
                <option value="Activa">Activa</option>
                <option value="Inactiva">Inactiva</option>
            </select>
        </div>
        <div class="col-3 col-md-2 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-secondary rounded-4" @onclick="Limpiar">
                Limpiar
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string FiltroNombre { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> FiltroNombreChanged { get; set; }

    [Parameter]
    public int? FiltroCuentasMin { get; set; }

    [Parameter]
    public EventCallback<int?> FiltroCuentasMinChanged { get; set; }

    [Parameter]
    public int? FiltroCuentasMax { get; set; }

    [Parameter]
    public EventCallback<int?> FiltroCuentasMaxChanged { get; set; }

    [Parameter]
    public string FiltroEstado { get; set; } = "Todas";

    [Parameter]
    public EventCallback<string> FiltroEstadoChanged { get; set; }

    [Parameter]
    public EventCallback OnLimpiar { get; set; }

    private async Task OnNombreCambiado(ChangeEventArgs e)
    {
        FiltroNombre = e.Value?.ToString() ?? string.Empty;
        await FiltroNombreChanged.InvokeAsync(FiltroNombre);
    }

    private async Task OnCuentasMinCambiado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            FiltroCuentasMin = val;
        else
            FiltroCuentasMin = null;
        await FiltroCuentasMinChanged.InvokeAsync(FiltroCuentasMin);
    }

    private async Task OnCuentasMaxCambiado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            FiltroCuentasMax = val;
        else
            FiltroCuentasMax = null;
        await FiltroCuentasMaxChanged.InvokeAsync(FiltroCuentasMax);
    }

    private async Task OnEstadoCambiado(ChangeEventArgs e)
    {
        FiltroEstado = e.Value?.ToString() ?? "Todas";
        await FiltroEstadoChanged.InvokeAsync(FiltroEstado);
    }

    private async Task Limpiar()
    {
        FiltroNombre = string.Empty;
        await FiltroNombreChanged.InvokeAsync(string.Empty);

        FiltroCuentasMin = null;
        await FiltroCuentasMinChanged.InvokeAsync(null);

        FiltroCuentasMax = null;
        await FiltroCuentasMaxChanged.InvokeAsync(null);

        FiltroEstado = "Todas";
        await FiltroEstadoChanged.InvokeAsync("Todas");

        await OnLimpiar.InvokeAsync();
    }
}
