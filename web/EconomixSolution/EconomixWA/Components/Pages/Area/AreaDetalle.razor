@page "/area/detalle"

@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="d-flex flex-column h-100 mb-3">

    <div class="row h-100 mb-3">

        <div class="col-12 h-100 mb-3">

            <div class="card rounded-4 p-3 mb-3 h-100">

                <p class="h3">
                    Registrar Área
                </p>

                <div class="row">

                    <div class="col-6 mt-3">
                        <label for="NombreArea" class="form-label">
                            Nombre del área
                        </label>

                        <input type="text"
                               class="form-control form-control-lg rounded-4 bg-light"
                               id="NombreArea"
                               maxlength="60"
                               placeholder="Ingrese el nombre del área">
                    </div>

                    <div class="col-6 mt-3">
                        <label for="NombreJefe" class="form-label">
                            Nombre del jefe
                        </label>

                        <input type="text"
                               class="form-control form-control-lg rounded-4 bg-light"
                               id="NombreJefe"
                               placeholder="Ingrese el nombre del jefe">
                    </div>

                    <div class="col-6 mt-3">
                        <label for="FondoMaximo" class="form-label">
                            Fondo máximo
                        </label>

                        <input type="text"
                               class="form-control form-control-lg rounded-4 bg-light"
                               id="FondoMaximo"
                               placeholder="S/ 0.00">
                    </div>

                    <div class="col-6 mt-3">
                        <label for="Estado" class="form-label">
                            Estado
                        </label>

                        <select class="form-select form-select-lg rounded-4 bg-light"
                                id="Estado">

                            <option value="1" selected>
                                Activo
                            </option>

                            <option value="0">
                                Desactivo
                            </option>

                        </select>
                    </div>

                    <div class="col-12 mt-3">
                        <label for="DescripcionArea" class="form-label">
                            Descripción
                        </label>

                        <textarea class="form-control bg-light rounded-4"
                                  id="DescripcionArea"
                                  rows="4"
                                  maxlength="200"
                                  placeholder="Ingrese una descripción del área"></textarea>
                    </div>

                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">

                    <button type="button"
                            class="btn btn-primary px-4"
                            @onclick="Guardar">

                        Guardar

                    </button>

                    <a href="/ListarAreas"
                       class="btn btn-outline-danger px-4">

                        Cancelar

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@code {
    private void Guardar()
    {
        Navigation.NavigateTo("/areas");
    }
}