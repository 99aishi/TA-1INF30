@page "/area/detalle"
@page "/area/Crear"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IAreaWS AreaWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 @(EsCreacion? "mb-3": " ")">
        <div class="col-12 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100 d-flex justify-content-between">
                <div class="d-flex flex-column">
                    <div class="d-flex gap-4"> 
                        @if (EsCreacion)
                        {
                            <p class="h3"> Registrar Area </p>
                        }
                        else
                        {
                            <p class="h3"> Area Nro @Area.AreaID</p>
                        }
                        <div class="d-flex flex-column justify-content-center gap-2">
                            <span class="badge @(Area.EstaActivo ? "text-bg-success" : "text-bg-secondary") rounded-pill px-2">
                                @(Area.EstaActivo ? "Activo" : "Inactivo")
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            Ocurrió un error al procesar la solicitud
                            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-6 mt-3">
                            <label for="NombreArea" class="form-label">Nombre del área</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("Nombre") ? "is-invalid" : "")"
                                   id="NombreArea"
                                   placeholder="Ingrese el nombre del área" @bind="Area.Nombre">
                            @if (Errores.ContainsKey("Nombre"))
                            {
                                <div class="text-danger small mt-1">@Errores["Nombre"]</div>
                            }
                        </div>
                        <div class="col-6 mt-3">
                            <label for="NombreJefe" class="form-label">
                                Nombre del jefe
                            </label>
                            @if (Area.Jefe != null)
                            {
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Ingrese el nombre del jefe" 
                                       @bind="Area.Jefe.Nombres" />
                            }
                            else
                            {
                                <input type="text" 
                                       class="form-control"
                                       placeholder="Ingrese el nombre del jefe"/>
                            }
                        </div>

                        <div class="col-6 mt-3">
                            <label for="FondoMaximo" class="form-label">
                                Fondo máximo (S/)
                            </label>
                            <input type="number" step="0.01" min="0"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("MontoTecho") ? "is-invalid" : "")"
                                   id="FondoMaximo"
                                   placeholder="0.00" @bind="Area.CajaChica.MontoTecho">
                            @if (Errores.ContainsKey("MontoTecho"))
                            {
                                <div class="text-danger small mt-1">@Errores["MontoTecho"]</div>
                            }
                        </div>
                        
                        <div class="col-12 mt-3">
                            <label for="DescripcionArea" class="form-label">
                                Descripción
                            </label>
                            <textarea class="form-control bg-light rounded-4 @(Errores.ContainsKey("Descripcion") ? "is-invalid" : "")"
                                      id="DescripcionArea" rows="4"
                                      placeholder="Ingrese una descripción del área" @bind="@Area.Descripcion"></textarea>
                            @if (Errores.ContainsKey("Descripcion"))
                            {
                                <div class="text-danger small mt-1">@Errores["Descripcion"]</div>
                            }
                        </div>
                    </div>
                </div>
               
                <div class="d-flex justify-content-end gap-3 mt-4">
                @if (EsCreacion)
                {
                    <button type="button" class="btn btn-outline-primary align-self-start mt-3" @onclick="InsertarArea">
                        Registrar
                    </button>
                    <button type="button" class="btn btn-outline-info align-self-start mt-3" @onclick="IrAAreas">
                        Cerrar
                    </button>
                    <button type="button" class="btn btn-outline-danger align-self-start mt-3" @onclick="IrAAreas">
                        Cancelar
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-outline-warning align-self-start mt-3" @onclick="GuardarCambios">
                        Guardar Cambios
                    </button>
                    <button type="button" class="btn btn-outline-info align-self-start mt-3" @onclick="CerrarDetalle">
                        Cerrar
                    </button>
                    @if (Area.EstaActivo)
                    {
                        <button type="button" class="btn btn-outline-danger align-self-start mt-3" @onclick="EliminarArea">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-success align-self-start mt-3" @onclick="RecuperarArea">
                            Recuperar
                        </button>
                    }
                    
                }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle{ get; set; }
    [Parameter]
    public Area Area { get; set; } = new Area();
    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> Errores { get; set; } = new();

    private bool ValidarFormulario()
    {
        Errores.Clear();

        if (string.IsNullOrWhiteSpace(Area.Nombre))
            Errores["Nombre"] = "El nombre del área es obligatorio.";

        if (string.IsNullOrWhiteSpace(Area.Descripcion))
            Errores["Descripcion"] = "La descripción del área es obligatoria.";

        if (Area.CajaChica == null || Area.CajaChica.MontoTecho <= 0)
            Errores["MontoTecho"] = "El fondo máximo debe ser mayor que cero.";

        return Errores.Count == 0;
    }

    protected override void OnInitialized()
    {
        Inicializar();
    }

    protected override void OnParametersSet()
    {
        Inicializar();
    }

    private void Inicializar()
    {
        Area.CajaChica ??= new CajaChica();
        EsCreacion = Navigation.Uri.Contains("/Crear");
        if (EsCreacion)
        {
            Area = new Area();
            Area.Jefe = null;
            Area.CajaChica = new CajaChica();
        }
    }

    private async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private void IrAAreas()
    {
        Navigation.NavigateTo("/Areas");
    }

    private async Task InsertarArea()
    {
        ErrorMessage = string.Empty;
        if (!ValidarFormulario()) return;

        try
        {
            await Task.Run(() => AreaWS.insertar(Area));
            await Task.Run(() => IrAAreas());
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task GuardarCambios()
    {
        await Task.Run(() => AreaWS.actualizar(Area));
        await OnCerrarDetalle.InvokeAsync();
    }

    private async Task EliminarArea()
    {
        await Task.Run(() => AreaWS.eliminar(Area.AreaID));
        await OnCerrarDetalle.InvokeAsync();
    }

    private async Task RecuperarArea()
    {
        await Task.Run(() => AreaWS.recuperar(Area.AreaID));
        await OnCerrarDetalle.InvokeAsync();
    }
}