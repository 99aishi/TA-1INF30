@page "/area/detalle"
@page "/area/Crear"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS
@inject ICuentaBancariaWS CuentaBancariaWS
@inject IMonedaWS MonedaWS
@inject IEmpleadoWS EmpleadoWS
@inject ICajaChicaWS CajaChicaWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
        <div class="p-3 pb-2 d-flex gap-4 align-items-center">
            @if (EsCreacion)
            {
                <p class="h3 mb-0">Registrar Área</p>
            }
            else
            {
                <p class="h3 mb-0">Área Nro @Area.AreaID</p>
                <span class="badge @(Area.EstaActivo ? "text-bg-success" : "text-bg-secondary") rounded-pill px-2">
                    @(Area.EstaActivo ? "Activo" : "Inactivo")
                </span>
            }
        </div>
        <hr class="my-0" />
        <div class="flex-fill overflow-auto p-3">

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @ErrorMessage
                    <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                </div>
            }

            <div class="row">
                <div class="col-12 col-md-6 mt-3">
                    <label for="NombreArea" class="form-label">Nombre del área</label>
                    <input type="text"
                           class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("Nombre") ? "is-invalid" : "")"
                           id="NombreArea"
                           placeholder="Ingrese el nombre del área" @bind="Area.Nombre">
                    @if (Errores.ContainsKey("Nombre"))
                    {
                        <div class="text-danger small mt-1">@Errores["Nombre"]</div>
                    }
                </div>
                <div class="col-12 col-md-6 mt-3">
                    <label for="NombreJefe" class="form-label">Jefe del área</label>
                    <select id="NombreJefe" class="form-select form-select-lg rounded-4 bg-light"
                            @bind="JefeSeleccionadoId">
                        <option value="0">Sin jefe asignado</option>
                        @foreach (var jefe in Jefes)
                        {
                            <option value="@jefe.UsuarioID">@jefe.Nombres @jefe.ApellidoPaterno</option>
                        }
                    </select>
                </div>

                <div class="col-12 mt-3">
                    <label for="DescripcionArea" class="form-label">Descripción</label>
                    <textarea class="form-control bg-light rounded-4 @(Errores.ContainsKey("Descripcion") ? "is-invalid" : "")"
                              id="DescripcionArea" rows="5"
                              placeholder="Ingrese una descripción del área" @bind="Area.Descripcion"></textarea>
                    @if (Errores.ContainsKey("Descripcion"))
                    {
                        <div class="text-danger small mt-1">@Errores["Descripcion"]</div>
                    }
                </div>
            </div>

            @if (!EsCreacion)
            {
                <hr class="my-4" />

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="h5 mb-0">Cuentas bancarias</p>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="IniciarNuevaCuenta">
                        + Agregar cuenta
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(ErrorCuenta))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @ErrorCuenta
                        <button type="button" class="btn-close" @onclick="() => ErrorCuenta = string.Empty" aria-label="close"></button>
                    </div>
                }

                @if (MostrarEditorCuenta)
                {
                    <CuentaBancariaEditor Cuenta="CuentaEnEdicion"
                                          Monedas="Monedas"
                                          EsEdicion="@(CuentaEnEdicion.IdCuenta > 0)"
                                          OnGuardar="GuardarCuenta"
                                          OnCancelar="CancelarEdicionCuenta" />
                }

                @if (CuentaSeleccionada != null)
                {
                    <div class="card rounded-4 p-3 mb-3 bg-light">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="h6 mb-1">@CuentaSeleccionada.NombreBanco</p>
                                <p class="text-muted small mb-0">@CuentaSeleccionada.NumeroBancario · CCI: @CuentaSeleccionada.Cci</p>
                                <p class="text-muted small mb-0">Moneda: @(CuentaSeleccionada.Moneda?.Simbolo ?? "-")</p>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CerrarDetalleCuenta">
                                Cerrar
                            </button>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-semibold">Cajas chicas</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AgregarCajaChica">
                                + Agregar caja chica
                            </button>
                        </div>
                        @if (CajasChicasCache.ContainsKey(CuentaSeleccionada.IdCuenta))
                        {
                            var cajas = CajasChicasCache[CuentaSeleccionada.IdCuenta];
                            @if (cajas.Count == 0)
                            {
                                <p class="text-muted small mb-0">No hay cajas chicas registradas.</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-borderless align-middle mb-0">
                                        <thead>
                                            <tr class="small text-muted">
                                                <th>Nombre</th>
                                                <th>Monto techo</th>
                                                <th>Moneda</th>
                                                <th>Estado</th>
                                                <th class="text-end">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var caja in cajas)
                                            {
                                                <tr>
                                                    <td>@caja.Nombre</td>
                                                    <td>@caja.MontoTecho.ToString("N2")</td>
                                                    <td>@(caja.Moneda?.Simbolo ?? "-")</td>
                                                    <td>
                                                        <span class="badge @(caja.Estado == "ACTIVO" ? "bg-success" : "bg-secondary")">
                                                            @caja.Estado
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-sm btn-outline-warning me-1" @onclick="() => EditarCajaChica(caja)">
                                                            Editar
                                                        </button>
                                                        @if (caja.Estado == "ACTIVO")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarCajaChica(caja)">
                                                                Eliminar
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => RecuperarCajaChica(caja)">
                                                                Recuperar
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Cargando...</p>
                        }
                    </div>
                }

                <div class="flex-fill overflow-auto">
                    @if (Area.CuentasBancarias.Count == 0 && !MostrarEditorCuenta)
                    {
                        <p class="text-muted">No hay cuentas bancarias registradas.</p>
                    }
                    else
                    {
                        @foreach (var cuenta in Area.CuentasBancarias)
                        {
                            <CuentaBancariaItem Cuenta="cuenta"
                                                Empleados="new List<Empleado>()"
                                                Areas="new List<Area> { Area }"
                                                Seleccionada="@(CuentaSeleccionada?.IdCuenta == cuenta.IdCuenta)"
                                                OnSeleccionar="() => SeleccionarCuenta(cuenta)"
                                                OnVer="() => VerCuenta(cuenta)" />
                        }
                    }
                </div>
            }
        </div>
        <hr class="my-0" />
        <div class="p-3 d-flex justify-content-end gap-3">
            @if (EsCreacion)
            {
                <button type="button" class="btn btn-outline-primary" @onclick="InsertarArea">
                    Registrar
                </button>
                <button type="button" class="btn btn-outline-info" @onclick="IrAAreas">
                    Cerrar
                </button>
                <button type="button" class="btn btn-outline-danger" @onclick="IrAAreas">
                    Cancelar
                </button>
            }
            else
            {
                <button type="button" class="btn btn-outline-warning" @onclick="GuardarCambios">
                    Guardar Cambios
                </button>
                <button type="button" class="btn btn-outline-info" @onclick="CerrarDetalle">
                    Cerrar
                </button>
                @if (Area.EstaActivo)
                {
                    <button type="button" class="btn btn-outline-danger" @onclick="EliminarArea">
                        Eliminar
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-outline-success" @onclick="RecuperarArea">
                        Recuperar
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public Area Area { get; set; } = new Area();

    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string ErrorCuenta { get; set; } = string.Empty;
    private Dictionary<string, string> Errores { get; set; } = new();
    private List<Moneda> Monedas { get; set; } = new();
    private List<Empleado> Jefes { get; set; } = new();
    private int IdUsuarioAccion { get; set; }

    private int JefeSeleccionadoId
    {
        get => Area.Jefe?.UsuarioID ?? 0;
        set => Area.Jefe = value == 0 ? null : Jefes.FirstOrDefault(j => j.UsuarioID == value);
    }

    private bool MostrarEditorCuenta { get; set; }
    private CuentaBancaria CuentaEnEdicion { get; set; } = new();
    private CuentaBancaria? CuentaSeleccionada { get; set; }
    private Dictionary<int, List<CajaChica>> CajasChicasCache { get; set; } = new();

    private bool ValidarFormulario()
    {
        Errores.Clear();

        if (string.IsNullOrWhiteSpace(Area.Nombre))
            Errores["Nombre"] = "El nombre del área es obligatorio.";

        if (string.IsNullOrWhiteSpace(Area.Descripcion))
            Errores["Descripcion"] = "La descripción del área es obligatoria.";

        return Errores.Count == 0;
    }

    protected override async Task OnInitializedAsync()
    {
        Inicializar();
        IdUsuarioAccion = UsuarioWS.GetCurrentUserId();
        await CargarCatalogos();
    }

    protected override void OnParametersSet()
    {
        Inicializar();
    }

    private void Inicializar()
    {
        EsCreacion = Navigation.Uri.Contains("/Crear");
        if (EsCreacion)
        {
            Area = new Area();
            Area.Jefe = null;
            Area.CuentasBancarias = new List<CuentaBancaria>();
        }
    }

    private async Task CargarCatalogos()
    {
        try { Monedas = await Task.Run(() => new List<Moneda>(MonedaWS.listar())); } catch { Monedas = new List<Moneda>(); }
        try
        {
            var empleados = await Task.Run(() => new List<Empleado>(EmpleadoWS.listar()));
            Jefes = empleados.Where(e => e.RolFlujo == RolFlujo.JEFE_AREA).ToList();
        }
        catch { Jefes = new List<Empleado>(); }
    }

    private async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private void IrAAreas()
    {
        Navigation.NavigateTo("/Areas");
    }

    private async Task InsertarArea()
    {
        ErrorMessage = string.Empty;
        if (!ValidarFormulario()) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => AreaWS.insertar(Area, idUsuarioAccion));
            await Task.Run(() => IrAAreas());
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task GuardarCambios()
    {
        ErrorMessage = string.Empty;
        if (!ValidarFormulario()) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => AreaWS.actualizar(Area, idUsuarioAccion));
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task EliminarArea()
    {
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => AreaWS.eliminar(Area.AreaID, idUsuarioAccion));
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task RecuperarArea()
    {
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => AreaWS.recuperar(Area.AreaID, idUsuarioAccion));
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void IniciarNuevaCuenta()
    {
        CuentaEnEdicion = new CuentaBancaria
        {
            AreaAdministradora = Area,
            EmpleadoAdministrador = null,
            Activa = true
        };
        MostrarEditorCuenta = true;
        CuentaSeleccionada = null;
        ErrorCuenta = string.Empty;
    }

    private async Task GuardarCuenta(CuentaBancaria cuenta)
    {
        ErrorCuenta = string.Empty;
        cuenta.AreaAdministradora = Area;
        cuenta.EmpleadoAdministrador = null;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            if (cuenta.IdCuenta > 0)
            {
                await Task.Run(() => CuentaBancariaWS.actualizar(cuenta, idUsuarioAccion));
            }
            else
            {
                await Task.Run(() => CuentaBancariaWS.insertar(cuenta, idUsuarioAccion));
            }

            var actualizadas = await Task.Run(() =>
                new List<CuentaBancaria>(CuentaBancariaWS.listar()
                    .Where(c => c.AreaAdministradora?.AreaID == Area.AreaID)));
            Area.CuentasBancarias = actualizadas;
            MostrarEditorCuenta = false;
            CuentaEnEdicion = new CuentaBancaria();
        }
        catch (Exception ex)
        {
            ErrorCuenta = ex.Message;
        }
    }

    private void CancelarEdicionCuenta()
    {
        MostrarEditorCuenta = false;
        CuentaEnEdicion = new CuentaBancaria();
    }

    private async Task SeleccionarCuenta(CuentaBancaria cuenta)
    {
        CuentaSeleccionada = cuenta;
        MostrarEditorCuenta = false;

        if (!CajasChicasCache.ContainsKey(cuenta.IdCuenta))
        {
            try
            {
                var cajas = await Task.Run(() => CajaChicaWS.listarPorCuentaBancaria(cuenta.IdCuenta));
                CajasChicasCache[cuenta.IdCuenta] = cajas ?? new List<CajaChica>();
            }
            catch
            {
                CajasChicasCache[cuenta.IdCuenta] = new List<CajaChica>();
            }
        }
    }

    private void CerrarDetalleCuenta()
    {
        CuentaSeleccionada = null;
    }

    private void VerCuenta(CuentaBancaria cuenta)
    {
        Navigation.NavigateTo("/Cuentas Bancarias");
    }

    private void AgregarCajaChica()
    {
        if (CuentaSeleccionada == null) return;
        Navigation.NavigateTo($"/Caja Chica/Crear?cuentaId={CuentaSeleccionada.IdCuenta}");
    }

    private void EditarCajaChica(CajaChica caja)
    {
        Navigation.NavigateTo($"/Caja Chica/detalle?cajaId={caja.IdFondo}");
    }

    private async Task EliminarCajaChica(CajaChica caja)
    {
        if (CuentaSeleccionada == null) return;
        ErrorCuenta = string.Empty;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => CajaChicaWS.eliminar(caja.IdFondo, idUsuarioAccion));
            CajasChicasCache[CuentaSeleccionada.IdCuenta] = await Task.Run(() =>
                CajaChicaWS.listarPorCuentaBancaria(CuentaSeleccionada.IdCuenta) ?? new List<CajaChica>());
        }
        catch (Exception ex)
        {
            ErrorCuenta = ex.Message;
        }
    }

    private async Task RecuperarCajaChica(CajaChica caja)
    {
        if (CuentaSeleccionada == null) return;
        ErrorCuenta = string.Empty;

        try
        {
            caja.Estado = "ACTIVO";
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => CajaChicaWS.actualizar(caja, idUsuarioAccion));
            CajasChicasCache[CuentaSeleccionada.IdCuenta] = await Task.Run(() =>
                CajaChicaWS.listarPorCuentaBancaria(CuentaSeleccionada.IdCuenta) ?? new List<CajaChica>());
        }
        catch (Exception ex)
        {
            ErrorCuenta = ex.Message;
        }
    }
}
