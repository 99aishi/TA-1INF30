@page "/roles"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IRolWS RolWS

<div class="h-100 d-flex flex-column">

    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Gestión de Roles</p>
            <p class="text-muted mb-0">Catálogo de roles del sistema</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button"
                    class="btn btn-primary"
                    @onclick="PrepararNuevoRol">
                + Agregar Rol
            </button>
        </div>
    </div>

    <RolSearchBar @bind-FiltroTitulo="FiltroTitulo"
                  @bind-FiltroDescripcion="FiltroDescripcion"
                  @bind-FiltroEstado="FiltroEstado" />

    <div class="d-flex flex-column flex-fill overflow-hidden">

        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(@MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">

                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando Roles...</p>
                        </div>
                    }
                    else if (RolesFiltrados.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ningún rol coincide con los filtros" : "No existe ningun rol registrado")
                            </p>
                        </div>
                    }
                    else
                    {
                        foreach (Rol rol in RolesFiltrados)
                        {
                            <RolItem OnMuestraDetalle="MostrarDetalleRol" Rol="rol" />
                        }
                    }
                </div>

            </div>
            @if (MostrarDetalle && RolSeleccionado != null)
            {
                <div class="col-6 h-100">
                    <RolDetalle Rol="RolSeleccionado" OnCerrarDetalle="CerrarDetalleRol" />
                </div>
            }
        </div>

    </div>

</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string FiltroTitulo { get; set; } = string.Empty;
    private string FiltroDescripcion { get; set; } = string.Empty;
    private string FiltroEstado { get; set; } = "Todas";
    private List<Rol> Roles { get; set; } = new List<Rol>();
    private Rol? RolSeleccionado { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroTitulo)
        || !string.IsNullOrWhiteSpace(FiltroDescripcion)
        || FiltroEstado != "Todas";

    private IEnumerable<Rol> RolesFiltrados => Roles
        .Where(r => string.IsNullOrWhiteSpace(FiltroTitulo)
            || r.Titulo.Contains(FiltroTitulo, StringComparison.OrdinalIgnoreCase))
        .Where(r => string.IsNullOrWhiteSpace(FiltroDescripcion)
            || r.Descripcion.Contains(FiltroDescripcion, StringComparison.OrdinalIgnoreCase))
        .Where(r => FiltroEstado == "Todas"
            || (FiltroEstado == "Activo" && r.EstaActivo)
            || (FiltroEstado == "Inactivo" && !r.EstaActivo));

    private void PrepararNuevoRol()
    {
        RolSeleccionado = new Rol();
        MostrarDetalle = true;
    }

    private void MostrarDetalleRol(Rol rol)
    {
        RolSeleccionado = rol;
        MostrarDetalle = true;
    }

    private async Task CerrarDetalleRol()
    {
        await ListarRoles();
        MostrarDetalle = false;
        RolSeleccionado = null;
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await ListarRoles();
        Cargando = false;
    }

    private async Task ListarRoles()
    {
        Roles = await Task.Run(() =>
            new List<Rol>(RolWS.listar()));
    }
}
