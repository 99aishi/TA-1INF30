@inject IRolWS RolWS
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 overflow-hidden">
    <div class="card rounded-4 p-3 h-100 d-flex justify-content-between overflow-scroll">
                <div class="d-flex flex-column">
                    <div class="d-flex gap-4">
                        @if (EsCreacion)
                        {
                            <p class="h3"> Registrar Rol </p>
                        }
                        else
                        {
                            <p class="h3"> Rol Nro @Rol.RolID</p>
                        }
                        <div class="d-flex flex-column justify-content-center gap-2">
                            <span class="badge @(Rol.EstaActivo ? "text-bg-success" : "text-bg-secondary") rounded-pill px-2">
                                @(Rol.EstaActivo ? "Activo" : "Inactivo")
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            @ErrorMessage
                            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-6 mt-3">
                            <label for="TituloRol" class="form-label">Título del rol</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("Titulo") ? "is-invalid" : "")"
                                   id="TituloRol"
                                   placeholder="Ingrese el título del rol" @bind="Rol.Titulo">
                            @if (Errores.ContainsKey("Titulo"))
                            {
                                <div class="text-danger small mt-1">@Errores["Titulo"]</div>
                            }
                        </div>

                        <div class="col-6 mt-3">
                            <label for="AreaRol" class="form-label">Área</label>
                            <select id="AreaRol" class="form-select form-select-lg rounded-4 bg-light @(Errores.ContainsKey("Area") ? "is-invalid" : "")"
                                    @bind="AreaSeleccionadaId" disabled="@(!EsCreacion)">
                                <option value="0">Seleccione un área</option>
                                @foreach (var area in Areas)
                                {
                                    <option value="@area.AreaID">@area.Nombre</option>
                                }
                            </select>
                            @if (Errores.ContainsKey("Area"))
                            {
                                <div class="text-danger small mt-1">@Errores["Area"]</div>
                            }
                        </div>

                        <div class="col-12 mt-3">
                            <label for="DescripcionRol" class="form-label">Descripción</label>
                            <textarea class="form-control bg-light rounded-4 @(Errores.ContainsKey("Descripcion") ? "is-invalid" : "")"
                                      id="DescripcionRol" rows="4"
                                      placeholder="Ingrese una descripción del rol" @bind="@Rol.Descripcion"></textarea>
                            @if (Errores.ContainsKey("Descripcion"))
                            {
                                <div class="text-danger small mt-1">@Errores["Descripcion"]</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-4">
                    @if (EsCreacion)
                    {
                        <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="InsertarRol">
                            @(Procesando ? "Procesando..." : "Registrar")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="CerrarDetalle">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="CerrarDetalle">
                            @(Procesando ? "Procesando..." : "Cancelar")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                            @(Procesando ? "Procesando..." : "Guardar Cambios")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="CerrarDetalle">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        @if (Rol.EstaActivo)
                        {
                            <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="EliminarRol">
                                @(Procesando ? "Procesando..." : "Eliminar")
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success" disabled="@Procesando" @onclick="RecuperarRol">
                                @(Procesando ? "Procesando..." : "Recuperar")
                            </button>
                        }
                    }
                </div>
        </div>
    </div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }
    [Parameter]
    public Rol Rol { get; set; } = new Rol();
    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> Errores { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private bool Procesando { get; set; } = false;

    private int AreaSeleccionadaId
    {
        get => Rol.Area?.AreaID ?? 0;
        set => Rol.Area = value == 0 ? null : Areas.FirstOrDefault(a => a.AreaID == value);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Areas = await AreaWS.listarActivasAsync();
        }
        catch { Areas = new List<Area>(); }
    }

    protected override void OnParametersSet()
    {
        EsCreacion = Rol.RolID == 0;
    }

    private async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private bool ValidarFormulario()
    {
        Errores.Clear();

        if (string.IsNullOrWhiteSpace(Rol.Titulo))
            Errores["Titulo"] = "El título del rol es obligatorio.";

        if (string.IsNullOrWhiteSpace(Rol.Descripcion))
            Errores["Descripcion"] = "La descripción del rol es obligatoria.";

        if (Rol.Area == null || Rol.Area.AreaID <= 0)
            Errores["Area"] = "El área del rol es obligatoria.";

        return Errores.Count == 0;
    }

    private async Task InsertarRol()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            if (!ValidarFormulario()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await RolWS.insertarAsync(Rol, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task GuardarCambios()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            if (!ValidarFormulario()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await RolWS.actualizarAsync(Rol, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EliminarRol()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await RolWS.eliminarAsync(Rol.RolID, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task RecuperarRol()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            Rol.EstaActivo = true;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await RolWS.actualizarAsync(Rol, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }
}
