<div class="card rounded-4 p-3 mb-3 bg-light">

    <div class="d-flex flex-row justify-content-between align-items-center">

        <div class="d-flex flex-column">

            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5 mb-1">
                    @Rol.Titulo
                </p>

                <span class="badge @(Rol.EstaActivo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") rounded-pill">
                    @(Rol.EstaActivo ? "Activo" : "Inactivo")
                </span>
            </div>

            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">
                    @Rol.Descripcion
                </p>
            </div>

        </div>

        <div class="d-flex flex-row justify-content-between align-items-center gap-3">

            <button class="btn btn-outline-primary"
                    @onclick="AbrirDetalle">
                Ver
            </button>

        </div>

    </div>

</div>

@code {
    [Parameter]
    public EventCallback<Rol> OnMuestraDetalle { get; set; }

    [Parameter]
    public Rol? Rol { get; set; }

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync(Rol);
    }
}
