@inject NavigationManager Navigation
@inject IComprobantePagoWS ComprobantePagoWS
@inject IPermisoEdicionWS PermisoEdicionWS
@inject IUsuarioWS UsuarioWS
@inject ITransaccionWS TransaccionWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IMonedaWS MonedaWS

<div class="card p-3 h-100 rounded-4 d-flex justify-content-between flex-column mb-3">
    
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <p class="h5 mb-0">Datos extraidos</p> 
                @if (Comprobante != null && Comprobante.Estado != "POR_REVISAR" && !EsCreacion && !EsAsociacion)
                {
                    <span class="badge @ObtenerEstadoBadgeClase(Comprobante.Estado) rounded-pill px-2">@Comprobante.Estado</span>
                }
            </div>
            @if (RequiereAutorizacion)
            {
                <span class="badge bg-danger-subtle text-danger-emphasis rounded-pill" style="font-size: 0.95rem;">
                    <i class="bi bi-lock-fill me-1"></i> Solo lectura: ciclo @Comprobante?.Solicitud?.Ciclo?.Estado
                </span>
            }
        </div>
        <div class="col-4 mt-3">
            <label for="TipoDocumento" class="form-label small text-muted">Tipo de Documento</label>    
            @if (RequiereAutorizacion)
            {
                <select class="form-select rounded-4 bg-light" disabled>
                    <option selected value="@Comprobante?.TipoDocumento">@Comprobante?.TipoDocumento</option>
                </select>
            }
            else
            {
                <select class="form-select rounded-4 bg-light" @bind="Comprobante.TipoDocumento">
                    <option value="">Seleccione...</option>
                    @if (EsEvaluacion)
                    {
                        <option value="@Comprobante?.TipoDocumento">@Comprobante?.TipoDocumento</option>
                    }
                    else
                    {
                        <option value="FACTURA">Factura</option>
                        <option value="BOLETA">Boleta</option>
                        <option value="DJ_EXCEPCIONAL">DJ Excepcional</option>
                    }
                </select>
            }
        </div>
        <div class="col-4 mt-3">
            <label for="RUC" class="form-label small text-muted">RUC</label>    
            @if (RequiereAutorizacion)
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Comprobante?.RucProveedor" disabled>
            }
            else
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" @bind="Comprobante.RucProveedor" placeholder="RUC" disabled="@RequiereAutorizacion">
            }
        </div>
        <div class="col-4 mt-3">
            <label for="RazonSocial" class="form-label small text-muted">Razón Social</label>    
            @if (RequiereAutorizacion)
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Comprobante?.RazonSocial" disabled>
            }
            else
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" @bind="Comprobante.RazonSocial" placeholder="Razón Social" disabled="@RequiereAutorizacion">
            }
        </div>
        <div class="col-4 mt-3">
            <label for="NumeroSerial" class="form-label small text-muted">Número Serial</label>    
            @if (RequiereAutorizacion)
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Comprobante?.NumeroSerial" disabled>
            }
            else
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" @bind="Comprobante.NumeroSerial" placeholder="Número Serial" disabled="@RequiereAutorizacion">
            }
        </div>
        <div class="col-4 mt-3">
            <label for="FechaDeEmision" class="form-label small text-muted">Fecha de Emisión</label>    
            @if (RequiereAutorizacion)
            {
                <input type="date" class="form-control form-control-lg rounded-4 bg-light" value="@Comprobante?.FechaEmision?.ToString("yyyy-MM-dd")" disabled>
            }
            else
            {
                <input type="date" class="form-control form-control-lg rounded-4 bg-light" @bind="Comprobante.FechaEmision" disabled="@RequiereAutorizacion">
            }
        </div>
        <div class="col-2 mt-3">
            <label for="Total" class="form-label small text-muted">Total</label>
            @if (RequiereAutorizacion)
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(SimboloMoneda) @Comprobante?.MontoTotal.ToString("N2")" disabled>
            }
            else
            {
                if (EsEvaluacion)
                {
                    <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(SimboloMoneda) @Comprobante?.MontoTotal.ToString("N2")" disabled>
                }
                else
                {
                    <input type="number" step="0.01" class="form-control form-control-lg rounded-4 bg-light" @bind="Comprobante.MontoTotal" placeholder="0.00">
                }
            }
        </div>
        <div class="col-2 mt-3">
            <label for="Moneda" class="form-label small text-muted">Moneda</label>
            @if (EsCreacion || EsAsociacion)
            {
                <select class="form-select form-select-lg rounded-4 bg-light" @bind="IdMonedaSeleccionada">
                    <option value="0">Seleccione...</option>
                    @foreach (var moneda in Monedas)
                    {
                        <option value="@moneda.IdMoneda">@moneda.CodigoISO (@moneda.Simbolo)</option>
                    }
                </select>
            }
            else
            {
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Comprobante?.Moneda?.CodigoISO ?? "PEN")" disabled>
            }
        </div>
        @if (!RequiereAutorizacion && (EsCreacion || EsAsociacion) && Comprobante?.IdComprobante > 0)
        {
            <div class="col-4 mt-3">
                <label class="form-label small text-muted">Nro. Comprobante</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="CP-@Comprobante.IdComprobante" disabled>
            </div>
        }
        <div class="col-12 mt-3">
            <label for="Comentario" class="form-label small text-muted">Comentario</label>    
            <textarea class="form-control form-control-lg rounded-4 bg-light" rows="4" @bind="Comprobante.Comentario" placeholder="Por Evaluar" disabled="@ComentarioDeshabilitado"></textarea>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    @if (MostrarModalSolicitud)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content rounded-4">
                    <div class="modal-header">
                        <h5 class="modal-title">Solicitar autorización de edición</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModalSolicitud"></button>
                    </div>
                    <div class="modal-body">
                        <p>El ciclo se encuentra <strong>@Comprobante?.Solicitud?.Ciclo?.Estado</strong>. Para editar este comprobante necesitas autorización de un Jefe o Tesorero (válida por 48 horas).</p>
                        <div class="mb-3">
                        <label for="MotivoSolicitud" class="form-label small text-muted">Motivo de la solicitud</label>
                        <textarea id="MotivoSolicitud" class="form-control rounded-4 bg-light" rows="3" @bind="MotivoSolicitud" placeholder="Explique por qué necesita editar el comprobante..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalSolicitud">Cancelar</button>
                        <button type="button" class="btn btn-outline-primary" @onclick="SolicitarAutorizacion" disabled="@Solicitando">
                            @if (Solicitando)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Enviar solicitud
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-end gap-3 mt-3">
        <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-4">
            @if (EsCreacion || EsAsociacion)
            {
                <button type="button" class="btn btn-outline-primary" disabled="@Procesando"
                        @onclick="GuardarComprobante">
                    @(Procesando ? "Guardando..." : "Registrar Comprobante")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                <button type="button" class="btn btn-outline-danger" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Cancelar")
                </button>
            }
            else if (EsEvaluacion)
            {
                <button type="button" class="btn btn-outline-success" disabled="@Procesando"
                        @onclick="Aprobar">
                    @(Procesando ? "Procesando..." : "Aprobar")
                </button>
                <button type="button" class="btn btn-outline-warning" disabled="@Procesando"
                        @onclick="Observar">
                    @(Procesando ? "Procesando..." : "Observar")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                <button type="button" class="btn btn-outline-danger" disabled="@Procesando"
                        @onclick="Rechazar">
                    @(Procesando ? "Procesando..." : "Rechazar")
                </button>
            }
            else if (RequiereAutorizacion)
            {
                <button type="button" class="btn btn-outline-primary" disabled="@Procesando"
                        @onclick="AbrirModalSolicitud">
                    <i class="bi bi-key-fill me-1"></i> @(Procesando ? "Procesando..." : "Solicitar autorización")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Volver")
                </button>
            }
            else
            {
                <button type="button" class="btn btn-outline-info" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Volver")
                </button>
                <button type="button" class="btn btn-outline-danger" disabled="@Procesando"
                        @onclick="MostrarItemsComprobante">
                    @(Procesando ? "Procesando..." : "Eliminar")
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool EsCreacion { get; set; }

    [Parameter]
    public bool EsEvaluacion { get; set; }

    [Parameter]
    public bool EsAsociacion { get; set; }

    [Parameter]
    public bool RequiereAutorizacion { get; set; }

    [Parameter]
    public ComprobantePago? Comprobante { get; set; }

    [Parameter]
    public EventCallback OnEvaluado { get; set; }

    private string SimboloMoneda => Comprobante?.Moneda?.Simbolo ?? "S/.";
    private string ErrorMessage { get; set; } = string.Empty;
    private bool MostrarModalSolicitud { get; set; }
    private string MotivoSolicitud { get; set; } = string.Empty;
    private bool Solicitando { get; set; }
    private bool Procesando { get; set; } = false;

    public void Volver()
    {
        Navigation.NavigateTo("/Comprobantes de Pago");
    }

    private async Task MostrarItemsComprobante()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            Navigation.NavigateTo("/Comprobantes de Pago");
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task AbrirModalSolicitud()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            MotivoSolicitud = string.Empty;
            MostrarModalSolicitud = true;
        }
        finally
        {
            Procesando = false;
        }
    }

    private void CerrarModalSolicitud()
    {
        MostrarModalSolicitud = false;
    }

    private async Task GuardarComprobante()
    {
        if (Procesando) return;
        Procesando = true;
        if (Comprobante == null) { Procesando = false; return; }
        ErrorMessage = string.Empty;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            
            if (EsCreacion || EsAsociacion)
            {
                if (string.IsNullOrWhiteSpace(Comprobante.TipoDocumento))
                {
                    ErrorMessage = "Debe seleccionar el tipo de documento.";
                    return;
                }
                if (Comprobante.MontoTotal <= 0)
                {
                    ErrorMessage = "El monto total debe ser mayor que 0.";
                    return;
                }
                if (Comprobante.Solicitud?.IdSolicitudGasto <= 0)
                {
                    ErrorMessage = "Debe seleccionar una solicitud para asociar.";
                    return;
                }

                Comprobante.Estado = "POR_REVISAR";
                Comprobante.FechaCreacion = DateTime.Today;
                Comprobante.FechaCreacionString = DateTime.Today.ToString("yyyy-MM-dd");

                if (Comprobante.IdComprobante > 0)
                {
                    await ComprobantePagoWS.actualizarAsync(Comprobante, idUsuarioAccion);
                }
                else
                {
                    await ComprobantePagoWS.insertarAsync(Comprobante, idUsuarioAccion);
                }

                await OnEvaluado.InvokeAsync();
                Volver();
            }
            else if (EsEvaluacion)
            {
                await ComprobantePagoWS.evaluarAsync(Comprobante.IdComprobante, true, string.Empty, idUsuarioAccion);
                await OnEvaluado.InvokeAsync();
                Volver();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task Rechazar()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (Comprobante == null) return;
            ErrorMessage = string.Empty;

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await ComprobantePagoWS.evaluarAsync(Comprobante.IdComprobante, false, Comprobante.Comentario ?? "Rechazado", idUsuarioAccion);
            await OnEvaluado.InvokeAsync();
            Volver();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task Observar()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (Comprobante == null) return;
            ErrorMessage = string.Empty;

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await ComprobantePagoWS.evaluarAsync(Comprobante.IdComprobante, false, Comprobante.Comentario ?? "Observado", idUsuarioAccion);
            await OnEvaluado.InvokeAsync();
            Volver();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task SolicitarAutorizacion()
    {
        ErrorMessage = string.Empty;
        if (Comprobante == null || Comprobante.Solicitud?.Solicitante == null) return;

        Solicitando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            var permiso = new PermisoEdicion
            {
                Solicitante = Comprobante.Solicitud.Solicitante,
                Comprobante = Comprobante,
                MotivoSolicitud = MotivoSolicitud
            };
            await PermisoEdicionWS.SolicitarAsync(permiso, idUsuarioAccion);
            MostrarModalSolicitud = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Solicitando = false;
        }
    }

    private async Task Aprobar()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (Comprobante == null) return;
            ErrorMessage = string.Empty;

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await ComprobantePagoWS.evaluarAsync(Comprobante.IdComprobante, true, Comprobante.Comentario ?? string.Empty, idUsuarioAccion);
            await OnEvaluado.InvokeAsync();
            Volver();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private List<Moneda> Monedas { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            Monedas = await MonedaWS.listarAsync();
            if (Comprobante != null && Comprobante.Moneda == null && Monedas.Any())
            {
                Comprobante.Moneda = Monedas.FirstOrDefault();
            }
        }
        catch
        {
            Monedas = new();
        }
    }

    private int IdMonedaSeleccionada
    {
        get => Comprobante?.Moneda?.IdMoneda ?? 0;
        set
        {
            if (Comprobante != null)
            {
                if (Comprobante.Moneda == null)
                {
                    Comprobante.Moneda = new Moneda();
                }
                Comprobante.Moneda.IdMoneda = value;
                var selected = Monedas.FirstOrDefault(m => m.IdMoneda == value);
                if (selected != null)
                {
                    Comprobante.Moneda.Simbolo = selected.Simbolo;
                    Comprobante.Moneda.CodigoISO = selected.CodigoISO;
                }
            }
        }
    }

    private bool ComentarioDeshabilitado
    {
        get
        {
            if (RequiereAutorizacion) return true;
            var rol = UsuarioWS.GetCurrentUser()?.Rol?.Titulo?.ToUpperInvariant();
            if (rol == "EMPLEADO") return true;
            return !EsEvaluacion;
        }
    }

    private string ObtenerEstadoBadgeClase(string? estado)
    {
        if (string.IsNullOrEmpty(estado)) return "bg-secondary-subtle text-secondary";
        return estado.ToUpperInvariant() switch
        {
            "APROBADO" or "VALIDADO" => "bg-success-subtle text-success",
            "RECHAZADO" or "ANULADO" => "bg-danger-subtle text-danger",
            "OBSERVADO" => "bg-warning-subtle text-warning-emphasis",
            "POR_REVISAR" => "bg-info-subtle text-info-emphasis",
            _ => "bg-secondary-subtle text-secondary"
        };
    }
}
