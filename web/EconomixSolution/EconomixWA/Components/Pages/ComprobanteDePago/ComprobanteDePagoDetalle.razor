@page "/Comprobantes de Pago/Detalle/{IdComprobante:int}"
@page "/Comprobantes de Pago/Evaluar/{IdComprobante:int}"
@page "/Comprobantes de Pago/Crear"
@page "/Comprobantes de Pago/Asociar/{IdSolicitud:int}"
@inject NavigationManager Navigation
@inject IComprobantePagoWS ComprobantePagoWS

<div class="rounded-4 mb-3 p-3 h-100">

    <div class="row h-100">
        <div class="col-4 h-100">
            <ComprobanteDePagoSustento EsCreacion="EsCreacion" EsEvaluacion="EsEvaluacion" EsAsociacion="EsAsociacion" RequiereAutorizacion="RequiereAutorizacion" IdSolicitudPasada="IdSolicitud" />
        </div>
        <div class="col-8 h-100">
            <ComprobanteDePagoDatos EsCreacion="EsCreacion" EsEvaluacion="EsEvaluacion" EsAsociacion="EsAsociacion"
                                    RequiereAutorizacion="RequiereAutorizacion"
                                    Comprobante="Comprobante" OnEvaluado="VolverALista"/>
        </div>
    </div>
</div>


@code {
    private bool EsCreacion { get; set; }
    private bool EsAsociacion { get; set; }
    private bool EsEvaluacion { get; set; }
    private bool RequiereAutorizacion { get; set; }
    private ComprobantePago? Comprobante { get; set; }

    [Parameter]
    public int IdComprobante { get; set; }

    [Parameter]
    public int IdSolicitud { get; set; }

    protected override void OnInitialized()
    {
        EsCreacion = Navigation.Uri.EndsWith("/Crear");
        EsAsociacion = Navigation.Uri.Contains("/Asociar");
        EsEvaluacion = Navigation.Uri.Contains("/Evaluar");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!EsCreacion && !EsAsociacion && IdComprobante > 0)
        {
            Comprobante = await ComprobantePagoWS.obtenerPorIdAsync(IdComprobante);
            RequiereAutorizacion = DeterminarSiRequiereAutorizacion();
        }
        else if (IdSolicitud > 0 && (EsCreacion || EsAsociacion))
        {
            Comprobante = new ComprobantePago { 
                Solicitud = new SolicitudGasto { IdSolicitudGasto = IdSolicitud }
            };
        }
    }

    private bool DeterminarSiRequiereAutorizacion()
    {
        if (EsCreacion || EsAsociacion || EsEvaluacion) return false;
        if (Comprobante?.Solicitud?.Ciclo == null) return false;
        var estado = Comprobante.Solicitud.Ciclo.Estado?.ToUpperInvariant();
        return estado == "CERRADO" || estado == "LIQUIDADO" || estado == "EN_EXCEPCION";
    }

    private void VolverALista()
    {
        Navigation.NavigateTo("/Comprobantes de Pago");
    }

}
