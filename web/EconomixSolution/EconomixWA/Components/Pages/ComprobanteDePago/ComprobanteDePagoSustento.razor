<div class="card h-100 p-3 rounded-4 gap-3 d-flex flex-column mb-3">
    <p class="h5">Solicitud Asociada</p>

    <div class="dropzone-container d-flex flex-column align-items-center justify-content-center p-4 text-center rounded-4 position-relative">
        <div class="dropzone-content">
            <i class="bi bi-cloud-upload text-primary fs-1 mb-2"></i>
            <p class="text-info fw-bold mb-1">Arrastra PDF, JPG o PNG</p>
            <p class="text-muted small mb-0">(menor a 5mB)</p>
        </div>
    </div>

    @if (EsAsociacion && IdSolicitudPasada > 0)
    {
        <div class="alert alert-info mt-3 mb-0 p-3 rounded-4">
            <p class="fs-3 fw-bold text-info-emphasis mb-2">Solicitud #@(SolicitudSeleccionada?.IdSolicitudGasto ?? IdSolicitudPasada)</p>
            <hr class="my-2" />
            <div class="d-flex justify-content-between fs-5 mb-1">
                <span class="text-muted">Total:</span>
                <span class="fw-bold">@TotalMontoSolicitud @SimboloMonedaSolicitud</span>
            </div>
            <small class="text-muted d-block mt-2">Fecha Solicitud: @(SolicitudSeleccionada?.FechaSolicitud.ToString("dd/MM/yyyy") ?? "")</small>
        </div>
    }
    else if (EsCreacion)
    {
        @if (!TieneSolicitudSeleccionada)
        {
            <div class="mt-2">
                <label for="SolicitudAsociada" class="form-label small text-muted">Seleccionar Solicitud</label>
                <select id="SolicitudAsociada" class="form-select form-select-lg bg-light rounded-4" value="@IdSolicitudSeleccionada" @onchange="OnSolicitudChanged">
                    <option value="0">Seleccionar Solicitud de Gasto</option>
                    @if (SolicitudesDisponibles.Any())
                    {
                        @foreach (var solicitud in SolicitudesDisponibles)
                        {
                            <option value="@solicitud.IdSolicitudGasto">Monto: @(solicitud.MonedaOriginal?.Simbolo ?? "S/") @solicitud.MontoSolicitado.ToString("N2") - Fecha: @solicitud.FechaSolicitud.ToString("dd/MM/yyyy") (@solicitud.Estado)</option>
                        }
                    }
                    else
                    {
                        <option disabled>No hay solicitudes disponibles</option>
                    }
                </select>
            </div>
        }
        else
        {
            <div class="alert alert-info mt-3 mb-0 p-3 rounded-4 position-relative">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="DeseleccionarSolicitud" aria-label="Close"></button>
                <p class="fs-3 fw-bold text-info-emphasis mb-2">Solicitud #@(SolicitudSeleccionada?.IdSolicitudGasto ?? 0)</p>
                <hr class="my-2" />
                <div class="d-flex justify-content-between fs-5 mb-1">
                    <span class="text-muted">Total:</span>
                    <span class="fw-bold">@TotalMontoSolicitud @SimboloMonedaSolicitud</span>
                </div>
                <div class="d-flex justify-content-between fs-5 mb-1">
                    <span class="text-muted">Fecha Solicitud:</span>
                    <span class="fw-bold">@(SolicitudSeleccionada?.FechaSolicitud.ToString("dd/MM/yyyy") ?? "")</span>
                </div>
                @if (!string.IsNullOrEmpty(SolicitudSeleccionada?.Ciclo?.CajaChica?.Nombre))
                {
                    <div class="d-flex justify-content-between fs-5">
                        <span class="text-muted">Caja Chica:</span>
                        <span class="fw-bold">@SolicitudSeleccionada.Ciclo.CajaChica.Nombre</span>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <p class="text-muted text-center small mt-2">La solicitud es pre-seleccionada y no puede ser cambiada.</p>
    }
</div>

@code {
    [Parameter]
    public bool EsCreacion { get; set; } = true;
    [Parameter]
    public bool EsEvaluacion { get; set; } = false;
    [Parameter]
    public bool EsAsociacion { get; set; } = false;
    [Parameter]
    public bool RequiereAutorizacion { get; set; } = false;

    [Parameter]
    public int IdSolicitudPasada { get; set; } = 0;

    [Parameter]
    public ComprobantePago? Comprobante { get; set; }

    private List<SolicitudGasto> SolicitudesDisponibles { get; set; } = new();
    private int IdSolicitudSeleccionada { get; set; } = 0;
    private SolicitudGasto? SolicitudSeleccionada { get; set; }

    private string TotalMontoSolicitud => SolicitudSeleccionada?.MontoSolicitado.ToString("N2") ?? "0.00";
    private string SimboloMonedaSolicitud => SolicitudSeleccionada?.MonedaOriginal?.Simbolo ?? "S/";
    private bool TieneSolicitudSeleccionada => SolicitudSeleccionada != null && SolicitudSeleccionada.IdSolicitudGasto > 0;

    [Inject]
    private ISolicitudGastoWS SolicitudGastoWS { get; set; }
    [Inject]
    private IUsuarioWS UsuarioWS { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (IdSolicitudPasada > 0)
            {
                await CargarSolicitudEspecifica(IdSolicitudPasada);
            }
            else
            {
                await CargarSolicitudesEmpleado();
            }
        }
        catch
        {
        }
    }

    private async Task OnSolicitudChanged(ChangeEventArgs e)
    {
        var id = int.Parse(e.Value?.ToString() ?? "0");
        IdSolicitudSeleccionada = id;
        if (Comprobante != null)
        {
            if (id > 0)
            {
                Comprobante.Solicitud = new SolicitudGasto { IdSolicitudGasto = id };
            }
            else
            {
                Comprobante.Solicitud = null;
            }
        }
        if (id > 0)
        {
            await CargarSolicitudEspecifica(id);
        }
        else
        {
            SolicitudSeleccionada = null;
        }
    }

    private async Task CargarSolicitudesEmpleado()
    {
        try
        {
            var usuario = UsuarioWS.GetCurrentUser();
            if (usuario is Empleado empleado)
            {
                SolicitudesDisponibles = (await SolicitudGastoWS.listarPorSolicitanteAsync(empleado.UsuarioID))
                    .Where(s => s.Estado == "APROBADO" || s.Estado == "PAGADO")
                    .ToList();
            }
        }
        catch
        {
            SolicitudesDisponibles = new List<SolicitudGasto>();
        }
    }

    private async Task CargarSolicitudEspecifica(int idSolicitud)
    {
        try
        {
            SolicitudGasto solicitud = await SolicitudGastoWS.obtenerPorIdAsync(idSolicitud)
                ?? new SolicitudGasto { IdSolicitudGasto = idSolicitud };

            SolicitudSeleccionada = solicitud;
            IdSolicitudSeleccionada = solicitud.IdSolicitudGasto;
        }
        catch
        {
            SolicitudSeleccionada = null;
        }
    }

    private void DeseleccionarSolicitud()
    {
        IdSolicitudSeleccionada = 0;
        SolicitudSeleccionada = null;
        if (Comprobante != null)
        {
            Comprobante.Solicitud = null;
        }
    }
}
