<div class="card rounded-4 mt-3 p-3 bg-light">
    <div class="d-flex flex-row 
                    justify-content-between align-items-center gap-3">
        <div class="d-flex flex-column gap-1">
            <p class="h6">CP-340</p>
            <p class="text-muted mb-0">Factura - Distribuidora Lima SAC</p>
            <p class="text-muted mb-0">SG-1025 - Juan Preciado - s/. 2500.00</p>
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <p class="h6">11/05/2026</p>
            <span class="badge h-100 bg-warning-subtle text-warning-emphasis rounded-pill px-2">Pendiente</span>
            <p class="h6">s/. 4500.00</p>

            <div class="d-flex align-items-center">
                <button type="button" class="btn btn-outline-primary align-self-start" 
                            @onclick="MostrarDetalleComprobanteHijo">
                    BTN
                </button>
            </div>
        </div>
    </div>
</div>



@code {
    [Parameter]
    public EventCallback OnMuestraDetalle {get; set;}

    public async Task MostrarDetalleComprobanteHijo()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
    
}
