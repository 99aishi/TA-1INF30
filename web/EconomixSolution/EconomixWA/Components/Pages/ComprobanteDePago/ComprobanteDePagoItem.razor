<div class="card rounded-4 p-3 bg-light mb-3">
    <div class="d-flex flex-row justify-content-between align-items-center gap-3">
        <div class="d-flex flex-column gap-1">
            <p class="h6">CP-@Comprobante?.IdComprobante</p>
            <div class="d-flex @(EsParteDeSolicitud ? "flex-column gap-3" : "flex-row gap-3") justify-content-start">
                <p class="text-muted mb-0">@Comprobante?.TipoDocumento</p>
                <p class="text-muted mb-0">@Comprobante?.RazonSocial</p>
            </div>
            @if (!EsParteDeSolicitud)
            {
            <div class="d-flex flex-row gap-3 justify-content-start">
                <p class="text-muted mb-0">SG-@Comprobante?.Solicitud?.IdSolicitudGasto</p>
                <p class="text-muted mb-0">@Comprobante?.Solicitud?.Solicitante?.Nombres</p>
            </div>
            }
        </div>
        <div class="d-flex flex-row align-items-center gap-3">
            <p class="h6">@Comprobante?.FechaEmision?.ToString("dd/MM/yyyy")</p>
            <span class="badge h-100 @ClaseBadge rounded-pill px-2">@Comprobante?.Estado</span>
            <p class="h6">@(Comprobante?.Moneda?.Simbolo ?? "S/") @Comprobante?.MontoTotal.ToString("N2")</p>
            <div class="d-flex align-items-center">
                <button type="button" class="btn btn-outline-primary align-self-start" @onclick="AbrirDetalle">
                    Ver
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool EsParteDeSolicitud { get; set; } = false;

    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    [Parameter]
    public ComprobantePago? Comprobante { get; set; }

    private string ClaseBadge => Comprobante?.Estado?.ToUpperInvariant() switch
    {
        "POR_REVISAR" => "bg-warning-subtle text-warning-emphasis",
        "APROBADO" => "bg-success-subtle text-success-emphasis",
        "VALIDADO" => "bg-primary-subtle text-primary-emphasis",
        "RECHAZADO" => "bg-danger-subtle text-danger-emphasis",
        "OBSERVADO" => "bg-info-subtle text-info-emphasis",
        "ANULADO" => "bg-secondary-subtle text-secondary-emphasis",
        _ => "bg-light text-dark"
    };

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
}
