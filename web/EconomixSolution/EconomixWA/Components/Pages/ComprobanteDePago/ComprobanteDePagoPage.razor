@page "/Comprobantes de Pago"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IComprobantePagoWS ComprobantePagoWS
@inject IUsuarioWS UsuarioWS
@inject IAreaWS AreaWS
@inject IEmpleadoWS EmpleadoWS

<div class="h-100 d-flex flex-column">
    
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Comprobantes de Pago</p>
            <p class="text-muted mb-0">Gestión de comprobantes de pago asociados a solicitudes de gasto</p>
        </div>
        <LiveClock />
        <div class="flex-grow-1 text-end">
            @if (!EsAdministrador)
            {
                <button type="button" class="btn btn-primary" @onclick="IrAgregarComprobante">
                    + Agregar Comprobante
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <ComprobantePagoSearchBar @bind-FiltroTexto="FiltroTexto"
                              @bind-FiltroTipo="FiltroTipo"
                              @bind-FiltroEstado="FiltroEstado"
                              @bind-FiltroMontoMin="FiltroMontoMin"
                              @bind-FiltroMontoMax="FiltroMontoMax"
                              @bind-FiltroFechaInicio="FiltroFechaInicio"
                              @bind-FiltroFechaFin="FiltroFechaFin"
                              @bind-FiltroAreaId="FiltroAreaId"
                              @bind-FiltroEmpleadoId="FiltroEmpleadoId"
                              Areas="Areas"
                              Empleados="Empleados" />

    <div class="d-flex flex-column flex-fill overflow-hidden">
        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">
            
            @if(MostrarDetalle)
            {
                <div class="col-6 h-100 d-flex flex-column overflow-hidden">
                    <div class="card rounded-4 p-3 h-100 overflow-scroll">
                        @if (Cargando) { <p class="text-muted text-center mt-5">Cargando comprobantes...</p> }
                        else if (ComprobantesFiltrados.Count() == 0) { <p class="text-muted text-center mt-5">@(HayFiltrosActivos ? "Ningún comprobante coincide con los filtros" : "No se encontraron comprobantes")</p> }
                        else { @foreach (var cp in ComprobantesFiltrados) { <ComprobanteDePagoItem Comprobante="cp" OnMuestraDetalle="() => MostrarDetalleComprobante(cp)"/> } }
                    </div>
                </div>
                <div class="col-6 h-100">
                    <ComprobanteDePagoDetalle IdComprobante="ComprobanteSeleccionado?.IdComprobante ?? 0" />
                </div>
            }
            else
            {
                <div class="col-12 h-100 d-flex flex-column overflow-hidden">
                    <div class="card rounded-4 p-3 h-100 overflow-scroll">
                        @if (Cargando) { <p class="text-muted text-center mt-5">Cargando comprobantes...</p> }
                        else if (ComprobantesFiltrados.Count() == 0) { <p class="text-muted text-center mt-5">@(HayFiltrosActivos ? "Ningún comprobante coincide con los filtros" : "No se encontraron comprobantes")</p> }
                        else { @foreach (var cp in ComprobantesFiltrados) { <ComprobanteDePagoItem Comprobante="cp" OnMuestraDetalle="() => MostrarDetalleComprobante(cp)"/> } }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private string FiltroTexto { get; set; } = string.Empty;
    private string FiltroTipo { get; set; } = "Todos";
    private string FiltroEstado { get; set; } = "Todas";
    private double? FiltroMontoMin { get; set; }
    private double? FiltroMontoMax { get; set; }
    private int FiltroAreaId { get; set; }
    private int FiltroEmpleadoId { get; set; }
    private DateTime? FiltroFechaInicio { get; set; }
    private DateTime? FiltroFechaFin { get; set; }
    private List<ComprobantePago> Comprobantes { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private List<Empleado> Empleados { get; set; } = new();
    private ComprobantePago? ComprobanteSeleccionado { get; set; }
    private bool EsAdministrador { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroTexto)
        || FiltroTipo != "Todos"
        || FiltroEstado != "Todas"
        || FiltroMontoMin.HasValue
        || FiltroMontoMax.HasValue
        || FiltroFechaInicio.HasValue
        || FiltroFechaFin.HasValue
        || FiltroAreaId > 0
        || FiltroEmpleadoId > 0;

    private IEnumerable<ComprobantePago> ComprobantesFiltrados => Comprobantes
        .Where(c => string.IsNullOrWhiteSpace(FiltroTexto)
            || (c.RazonSocial?.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false)
            || (c.Solicitud?.Solicitante?.Nombres.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false)
            || (c.Solicitud?.Solicitante?.ApellidoPaterno.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(c => FiltroTipo == "Todos" || c.TipoDocumento.Equals(FiltroTipo, StringComparison.OrdinalIgnoreCase))
        .Where(c => FiltroEstado == "Todas" || c.Estado.Equals(FiltroEstado, StringComparison.OrdinalIgnoreCase))
        .Where(c => !FiltroMontoMin.HasValue || c.MontoTotal >= FiltroMontoMin.Value)
        .Where(c => !FiltroMontoMax.HasValue || c.MontoTotal <= FiltroMontoMax.Value)
        .Where(c => !FiltroFechaInicio.HasValue || (c.FechaEmision?.Date >= FiltroFechaInicio.Value.Date))
        .Where(c => !FiltroFechaFin.HasValue || (c.FechaEmision?.Date <= FiltroFechaFin.Value.Date))
        .Where(c => FiltroAreaId <= 0 || c.Solicitud?.Solicitante?.Area?.AreaID == FiltroAreaId)
        .Where(c => FiltroEmpleadoId <= 0 || c.Solicitud?.Solicitante?.UsuarioID == FiltroEmpleadoId);

    public void MostrarDetalleComprobante(ComprobantePago cp)
    {
        ComprobanteSeleccionado = cp;
        MostrarDetalle = true;
    }

    public async Task CerrarDetalleComprobante()
    {
        await ListarComprobantes();
        MostrarDetalle = false;
        ComprobanteSeleccionado = null;
    }
    
    private void IrAgregarComprobante()
    {
        Navigation.NavigateTo("/Comprobantes de Pago/Crear");
    }

    protected override async Task OnInitializedAsync()
    {
        EsAdministrador = UsuarioWS.GetCurrentUser() is Administrador;
        Cargando = true;
        try { Areas = await AreaWS.listarAsync(); } catch {}
        try { Empleados = await EmpleadoWS.listarAsync(); } catch {}
        await ListarComprobantes();
        Cargando = false;
    }

    private async Task ListarComprobantes()
    {
        ErrorMessage = string.Empty;
        try { Comprobantes = await ComprobantePagoWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = ex.Message; }
    }
}
