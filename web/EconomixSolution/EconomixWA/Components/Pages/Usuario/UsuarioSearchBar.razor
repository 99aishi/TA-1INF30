@rendermode InteractiveServer

<div class="card rounded-4 p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-3">
            <label class="form-label small text-muted">Nombre / Apellido</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="Nombres o apellidos"
                   value="@FiltroNombre"
                   @oninput="OnNombreCambiado" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Correo</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="correo@economix.pe"
                   value="@FiltroCorreo"
                   @oninput="OnCorreoCambiado" />
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small text-muted">Rol</label>
            <select class="form-select bg-light rounded-4"
                    value="0"
                    @onchange="OnRolSeleccionado">
                <option value="0">Todos</option>
                @foreach (var rol in RolesDisponibles)
                {
                    <option value="@rol.Titulo">@rol.Titulo</option>
                }
            </select>
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small text-muted">Área</label>
            <select class="form-select bg-light rounded-4"
                    value="0"
                    @onchange="OnAreaSeleccionada">
                <option value="0">Todas</option>
                @foreach (var area in AreasDisponibles)
                {
                    <option value="@area.AreaID">@area.Nombre</option>
                }
            </select>
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small text-muted">Estado</label>
            <select class="form-select bg-light rounded-4"
                    value="@FiltroEstado"
                    @onchange="OnEstadoCambiado">
                <option value="Todas">Todas</option>
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
            </select>
        </div>
        <div class="col-4 col-md-1 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-outline-secondary rounded-4" @onclick="Limpiar">
                Limpiar
            </button>
        </div>
    </div>
    @if (RolesSeleccionados.Any())
    {
        <div class="row mt-2">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var rol in RolesSeleccionados)
                    {
                        <span class="badge bg-warning-subtle text-warning-emphasis rounded-pill d-flex align-items-center gap-1">
                            @rol.Titulo
                            <button type="button" class="btn-close"
                                    style="font-size:0.6em;"
                                    @onclick="() => QuitarRol(rol)"></button>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
    @if (AreasSeleccionadas.Any())
    {
        <div class="row mt-2">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var area in AreasSeleccionadas)
                    {
                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill d-flex align-items-center gap-1">
                            @area.Nombre
                            <button type="button" class="btn-close"
                                    style="font-size:0.6em;"
                                    @onclick="() => QuitarArea(area)"></button>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string FiltroNombre { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> FiltroNombreChanged { get; set; }

    [Parameter]
    public string FiltroCorreo { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> FiltroCorreoChanged { get; set; }

    [Parameter]
    public List<Rol> Roles { get; set; } = new();

    [Parameter]
    public List<Rol> RolesSeleccionados { get; set; } = new();

    [Parameter]
    public EventCallback<List<Rol>> RolesSeleccionadosChanged { get; set; }

    [Parameter]
    public List<Area> Areas { get; set; } = new();

    [Parameter]
    public List<Area> AreasSeleccionadas { get; set; } = new();

    [Parameter]
    public EventCallback<List<Area>> AreasSeleccionadasChanged { get; set; }

    [Parameter]
    public string FiltroEstado { get; set; } = "Todas";

    [Parameter]
    public EventCallback<string> FiltroEstadoChanged { get; set; }

    [Parameter]
    public EventCallback OnLimpiar { get; set; }

    [Parameter]
    public EventCallback OnFiltrar { get; set; }

    private IEnumerable<Rol> RolesDisponibles =>
        Roles.Where(r => !RolesSeleccionados.Any(s => s.Titulo == r.Titulo));

    private IEnumerable<Area> AreasDisponibles =>
        Areas.Where(a => !AreasSeleccionadas.Any(s => s.AreaID == a.AreaID));

    private async Task OnNombreCambiado(ChangeEventArgs e)
    {
        FiltroNombre = e.Value?.ToString() ?? string.Empty;
        await FiltroNombreChanged.InvokeAsync(FiltroNombre);
    }

    private async Task OnCorreoCambiado(ChangeEventArgs e)
    {
        FiltroCorreo = e.Value?.ToString() ?? string.Empty;
        await FiltroCorreoChanged.InvokeAsync(FiltroCorreo);
    }

    private async Task OnRolSeleccionado(ChangeEventArgs e)
    {
        var titulo = e.Value?.ToString() ?? "0";
        if (titulo != "0")
        {
            var rol = Roles.FirstOrDefault(r => r.Titulo == titulo);
            if (rol != null)
            {
                RolesSeleccionados = new List<Rol>(RolesSeleccionados) { rol };
                await RolesSeleccionadosChanged.InvokeAsync(RolesSeleccionados);
                await OnFiltrar.InvokeAsync();
            }
        }
    }

    private async Task QuitarRol(Rol rol)
    {
        if (RolesSeleccionados.Any(r => r.Titulo == rol.Titulo))
        {
            RolesSeleccionados = RolesSeleccionados.Where(r => r.Titulo != rol.Titulo).ToList();
            await RolesSeleccionadosChanged.InvokeAsync(RolesSeleccionados);
            await OnFiltrar.InvokeAsync();
        }
    }

    private async Task OnAreaSeleccionada(ChangeEventArgs e)
    {
        var areaId = int.TryParse(e.Value?.ToString(), out var val) ? val : 0;
        if (areaId > 0)
        {
            var area = Areas.FirstOrDefault(a => a.AreaID == areaId);
            if (area != null)
            {
                AreasSeleccionadas = new List<Area>(AreasSeleccionadas) { area };
                await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
                await OnFiltrar.InvokeAsync();
            }
        }
    }

    private async Task QuitarArea(Area area)
    {
        if (AreasSeleccionadas.Any(a => a.AreaID == area.AreaID))
        {
            AreasSeleccionadas = AreasSeleccionadas.Where(a => a.AreaID != area.AreaID).ToList();
            await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
            await OnFiltrar.InvokeAsync();
        }
    }

    private async Task OnEstadoCambiado(ChangeEventArgs e)
    {
        FiltroEstado = e.Value?.ToString() ?? "Todas";
        await FiltroEstadoChanged.InvokeAsync(FiltroEstado);
    }

    private async Task Limpiar()
    {
        FiltroNombre = string.Empty;
        await FiltroNombreChanged.InvokeAsync(string.Empty);

        FiltroCorreo = string.Empty;
        await FiltroCorreoChanged.InvokeAsync(string.Empty);

        RolesSeleccionados = new();
        await RolesSeleccionadosChanged.InvokeAsync(RolesSeleccionados);

        AreasSeleccionadas = new();
        await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);

        FiltroEstado = "Todas";
        await FiltroEstadoChanged.InvokeAsync("Todas");

        await OnLimpiar.InvokeAsync();
        await OnFiltrar.InvokeAsync();
    }
}
