@page "/usuarios"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IEmpleadoWS EmpleadoWS
@inject IRolWS RolWS
@inject IAreaWS AreaWS

<div class="h-100 d-flex flex-column">

    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Gestión de Usuarios</p>
            <p class="text-muted mb-0">Administrar perfiles, roles, areas y estado de acceso</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button" class="btn btn-primary" @onclick="IrRegistrarUsuario"> + Agregar Usuario</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <UsuarioSearchBar @bind-FiltroNombre="FiltroNombre"
                      @bind-FiltroCorreo="FiltroCorreo"
                      @bind-RolesSeleccionados="RolesSeleccionadosBusqueda"
                      @bind-AreasSeleccionadas="AreasSeleccionadasBusqueda"
                      @bind-FiltroEstado="FiltroEstado"
                      Roles="Roles"
                      Areas="AreasDisponibles"
                      OnFiltrar="Filtrar" />

    <div class="d-flex flex-column flex-fill overflow-hidden">

        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class=" @(MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">

                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando usuarios...</p>
                        </div>
                    }
                    else if (UsuariosFiltrados.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ningún usuario coincide con los filtros" : "No se encontraron usuarios")
                            </p>
                        </div>
                    }
                    else
                    {
                        @foreach (var usuario in UsuariosFiltrados)
                        {
                            <UsuarioItem Usuario="usuario" OnMuestraDetalle="() => MostrarDetalleUsuario(usuario)" />
                        }
                    }
                </div>
            </div>
            @if (MostrarDetalle && UsuarioSeleccionado != null)
            {
                <div class="col-6 h-100">
                    <UsuarioDetalle Usuario="UsuarioSeleccionado" OnCerrarDetalle="CerrarDetalleUsuario" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private string FiltroNombre { get; set; } = string.Empty;
    private string FiltroCorreo { get; set; } = string.Empty;
    private List<Rol> RolesSeleccionadosBusqueda { get; set; } = new();
    private List<Area> AreasSeleccionadasBusqueda { get; set; } = new();
    private string FiltroEstado { get; set; } = "Todas";
    private List<Usuario> Usuarios { get; set; } = new();
    private List<Rol> Roles { get; set; } = new();
    private List<Area> AreasDisponibles { get; set; } = new();
    private Usuario? UsuarioSeleccionado { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroNombre)
        || !string.IsNullOrWhiteSpace(FiltroCorreo)
        || RolesSeleccionadosBusqueda.Any()
        || AreasSeleccionadasBusqueda.Any()
        || FiltroEstado != "Todas";

    private IEnumerable<Usuario> UsuariosFiltrados => Usuarios
        .Where(u => string.IsNullOrWhiteSpace(FiltroNombre)
            || u.Nombres.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase)
            || u.ApellidoPaterno.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase)
            || u.ApellidoMaterno.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase))
        .Where(u => string.IsNullOrWhiteSpace(FiltroCorreo)
            || u.Correo.Contains(FiltroCorreo, StringComparison.OrdinalIgnoreCase))
        .Where(u => !RolesSeleccionadosBusqueda.Any() || RolesSeleccionadosBusqueda.Any(r => r.Titulo == u.Rol?.Titulo))
        .Where(u => !AreasSeleccionadasBusqueda.Any() || (u is Empleado emp && AreasSeleccionadasBusqueda.Any(a => a.AreaID == emp.Area?.AreaID)))
        .Where(u => FiltroEstado == "Todas"
            || (FiltroEstado == "Activo" && u.Estado == EstadoUsuario.ACTIVO)
            || (FiltroEstado == "Inactivo" && u.Estado == EstadoUsuario.INACTIVO));

    private void IrRegistrarUsuario()
    {
        Navigation.NavigateTo("/usuarios/Crear");
    }

    private void Filtrar() => StateHasChanged();

    private void MostrarDetalleUsuario(Usuario usuario)
    {
        UsuarioSeleccionado = usuario;
        MostrarDetalle = true;
    }

    private async Task CerrarDetalleUsuario()
    {
        await ListarUsuarios();
        MostrarDetalle = false;
        UsuarioSeleccionado = null;
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await Task.WhenAll(CargarRoles(), ListarUsuarios(), CargarAreas());
        Cargando = false;
    }

    private async Task CargarAreas()
    {
        try { AreasDisponibles = await AreaWS.listarAsync(); }
        catch { AreasDisponibles = new(); }
    }

    private async Task CargarRoles()
    {
        try
        {
            Roles = await RolWS.listarAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task ListarUsuarios()
    {
        ErrorMessage = string.Empty;
        try
        {
            Usuarios = (await EmpleadoWS.listarAsync()).Cast<Usuario>().ToList();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
