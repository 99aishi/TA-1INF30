@page "/usuarios"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="h-100 d-flex flex-column">
    
    <div class="d-flex flex-row justify-content-between align-items-center mb-3">
        <div>
            <p class="h4 mb-1">Gestión de Usuarios</p>
            <p class="text-muted mb-0">Administrar perfiles, roles, areas y estado de acceso</p>
        </div>

        <button type="button"
                class="btn btn-primary"
                @onclick="IrRegistrarUsuario">

            + Nuevo Usuario

        </button>
    </div>
        <div class="d-flex flex-column flex-fill overflow-hidden">

            <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">
                
                @if (MostrarDetalle)
                {
                    <div class="col-6 h-100 d-flex flex-column overflow-hidden">

                    <div class="card rounded-4 p-3 h-100 overflow-scroll">

                        @for (int i = 0; i < 10; i++)
                        {
                             <UsuarioItem OnMuestraDetalle="MostrarDetalleUsuario" />
                        }

                    </div>

                </div>

                <div class="col-6 h-100">

                    <div class="card rounded-4 p-4 h-100 d-flex flex-column">

                        <div class="d-flex flex-row justify-content-between align-items-start mb-4">
                            <div>
                                <p class="h4 mb-0">
                                    Usuario 100001
                                </p>
                            </div>

                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    @onclick="CerrarDetalleUsuario">
                                Cerrar
                            </button>
                        </div>

                        <div class="row g-3">

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Nombres</label>
                                <input type="text"
                                       class="form-control rounded-4 bg-light"
                                       value="Robert Yonaikel"
                                       disabled />
                            </div>

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Apellidos</label>
                                <input type="text"
                                       class="form-control rounded-4 bg-light"
                                       value="Oppenheimer Sanchez"
                                       disabled />
                            </div>

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Correo Electronico</label>
                                <input type="text"
                                       class="form-control rounded-4 bg-light"
                                       value="yona.oppie@gmail.com"
                                       disabled />
                            </div>

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Estado</label>
                                <input type="text"
                                       class="form-control rounded-4 bg-light"
                                       value="Activo"
                                       disabled />
                            </div>

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Contrasena</label>
                                <input type="password"
                                       class="form-control rounded-4 bg-light"
                                       value="antisemititi"
                                       disabled />
                            </div>

                            <div class="col-6">
                                <label class="form-label mb-1" style="font-size: 0.85rem;">Rol</label>
                                <input type="text"
                                       class="form-control rounded-4 bg-light"
                                       value="Empleado"
                                       disabled />
                            </div>
                        </div>

                        <!-- Contenedor de Botones con mt-auto para empujar al fondo -->
                        <div class="d-flex justify-content-end gap-4 mt-auto pt-4">
                            <button type="button"
                                    class="btn btn-primary px-4"
                                    style="padding-top: 0.6rem; padding-bottom: 0.6rem;"
                                    @onclick="IrRegistrarUsuario">
                                Editar
                            </button>

                            <button type="button"
                                    class="btn btn-danger px-4"
                                    style="padding-top: 0.6rem; padding-bottom: 0.6rem;">
                                Eliminar
                            </button>
                        </div>

                    </div>

                </div>
                }
                else
                {
                <div class="col-12 h-100 d-flex flex-column overflow-hidden">

                    <div class="card rounded-4 mt-3 mb-3 p-3 flex-fill overflow-scroll">
                        @for (int i = 0; i < 10; i++)
                        {
                                <UsuarioItem OnMuestraDetalle="MostrarDetalleUsuario" />
                        }


                    </div>

                </div>
            }

         </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    
    private void IrRegistrarUsuario()
    {
        Navigation.NavigateTo("/usuarios/detalle");
    }
    
    private void MostrarDetalleUsuario()
    {
        MostrarDetalle = true;
    }

    private void CerrarDetalleUsuario()
    {
        MostrarDetalle = false;
    }
}
