@rendermode InteractiveServer

<div class="card rounded-4 p-3 mb-3 bg-light">

    <div class="d-flex flex-row justify-content-between align-items-center">

        <div class="d-flex flex-column">

            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5 mb-1">
                    @Usuario.Nombres @Usuario.ApellidoPaterno @Usuario.ApellidoMaterno
                </p>

                <span class="badge @(Usuario.Estado == EstadoUsuario.ACTIVO ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") rounded-pill">
                    @(Usuario.Estado == EstadoUsuario.ACTIVO ? "Activo" : "Inactivo")
                </span>
            </div>

            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">
                    @(Usuario.Rol?.Titulo ?? "Sin rol")
                </p>

                <p class="text-muted m-0">
                    @Usuario.Correo
                </p>
            </div>

        </div>

        <div class="d-flex flex-row justify-content-between align-items-center gap-3">

            <button class="btn btn-outline-primary"
                    @onclick="AbrirDetalle">

                Ver

            </button>

        </div>

    </div>

</div>

@code {
    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    [Parameter]
    public Usuario? Usuario { get; set; }

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
}
