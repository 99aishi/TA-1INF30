@page "/usuarios/Crear"
@page "/usuarios/detalle"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IEmpleadoWS EmpleadoWS
@inject IRolWS RolWS
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 @(EsCreacion? "mb-3": " ")">
        <div class="col-12 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100 d-flex flex-column overflow-auto">
                <div class="d-flex flex-column">
                    <div class="d-flex gap-4">
                        @if (EsCreacion)
                        {
                            <p class="h3"> Registrar Usuario </p>
                        }
                        else
                        {
                            <p class="h3"> @(Usuario?.Nombres ?? "Usuario") </p>
                        }
                        <div class="d-flex flex-column justify-content-center gap-2">
                            <span class="badge @(EstadoActivo ? "text-bg-success" : "text-bg-secondary") rounded-pill px-2">
                                @(EstadoActivo ? "Activo" : "Inactivo")
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            @ErrorMessage
                            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-12 mt-3">
                            <label for="Nombres" class="form-label small text-muted">Nombres</label>
                            <input type="text" id="Nombres" placeholder="Nombres"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   @bind="UsuarioEdicion.Nombres">
                        </div>

                        <div class="col-6 mt-3">
                            <label for="ApellidoPaterno" class="form-label small text-muted">Apellido Paterno</label>
                            <input type="text" id="ApellidoPaterno" placeholder="Apellido paterno"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   @bind="UsuarioEdicion.ApellidoPaterno">
                        </div>
                        <div class="col-6 mt-3">
                            <label for="ApellidoMaterno" class="form-label small text-muted">Apellido Materno</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   id="ApellidoMaterno"
                                   placeholder="Apellido materno"
                                   @bind="UsuarioEdicion.ApellidoMaterno">
                        </div>

                        <div class="col-6 mt-3">
                            <label for="Correo" class="form-label small text-muted">Correo electronico</label>
                            <input type="email"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   id="Correo"
                                   placeholder="ejemplo@correo.com"
                                   @bind="UsuarioEdicion.Correo">
                        </div>
                        <div class="col-6 mt-3">
                            <label for="Contrasena" class="form-label small text-muted">Contrasena</label>
                            <input type="password"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   id="Contrasena"
                                   placeholder="Contrasena"
                                   @bind="UsuarioEdicion.Password">
                        </div>

                        @if (EmpleadoEdicion != null)
                        {
                            <div class="col-6 mt-3">
                                <label for="NumeroCelular" class="form-label small text-muted">Celular</label>
                                <input type="text" id="NumeroCelular" placeholder="999999999"
                                       class="form-control form-control-lg rounded-4 bg-light"
                                       @bind="EmpleadoEdicion.NumeroCelular">
                            </div>

                            <div class="col-6 mt-3">
                                <label for="Area" class="form-label small text-muted">Área</label>
                                <select id="Area" class="form-select form-select-lg rounded-4 bg-light"
                                        @bind="AreaSeleccionadaId">
                                    <option value="0">Seleccione un área</option>
                                    @foreach (var area in Areas)
                                    {
                                        <option value="@area.AreaID">@area.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="col-6 mt-3">
                                <label for="Rol" class="form-label small text-muted">Rol</label>
                                <select id="Rol" class="form-select form-select-lg rounded-4 bg-light"
                                        @bind="RolSeleccionadoId">
                                    <option value="0">Seleccione un rol</option>
                                    @foreach (var rol in RolesFiltrados)
                                    {
                                        <option value="@rol.RolID">@rol.Titulo</option>
                                    }
                                </select>
                            </div>

                            <div class="col-6 mt-3">
                                <label class="form-label small text-muted">Jefe directo (automático)</label>
                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" disabled
                                       value="@(ObtenerNombreJefeDirecto())" />
                            </div>
                        }

                        @if (false)
                        {
                            <div class="col-6 mt-3">
                                <label for="Estado" class="form-label small text-muted">Estado</label>
                                <select id="Estado" class="form-select form-select-lg rounded-4 bg-light"
                                        @bind="UsuarioEdicion.Estado">
                                    <option value="@EstadoUsuario.ACTIVO">Activo</option>
                                    <option value="@EstadoUsuario.INACTIVO">Inactivo</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>

                @if (!EsCreacion && EmpleadoEdicion != null)
                {
                    <div class="mt-3">
                        <button type="button" class="btn btn-outline-primary" @onclick="IrACuentasBancarias">
                            Gestionar Cuentas Bancarias
                        </button>
                    </div>
                }

                <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-4">

                    @if (EsCreacion)
                    {
                        <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="Insertar">
                            @(Procesando ? "Procesando..." : "Registrar")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="IrAUsuarios">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="IrAUsuarios">
                            @(Procesando ? "Procesando..." : "Cancelar")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                            @(Procesando ? "Procesando..." : "Guardar Cambios")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="CerrarDetalle">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="Eliminar">
                            @(Procesando ? "Procesando..." : "Eliminar")
                        </button>

                    }
                </div>

            </div>

        </div>
    </div>
</div>
@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public Usuario? Usuario { get; set; }

    private bool Procesando { get; set; } = false;
    private Usuario UsuarioEdicion { get; set; } = new Empleado();
    private Empleado? EmpleadoEdicion => UsuarioEdicion as Empleado;
    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    private List<Rol> Roles { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private int IdUsuarioAccion { get; set; }

    private bool EstadoActivo => UsuarioEdicion.Estado == EstadoUsuario.ACTIVO;

    private List<Rol> RolesFiltrados => EmpleadoEdicion?.Area?.AreaID > 0
        ? Roles.Where(r => r.Area?.AreaID == EmpleadoEdicion.Area.AreaID).ToList()
        : new List<Rol>();

    private bool EsJefeArea => EmpleadoEdicion?.RolFlujo == RolFlujo.JEFE_AREA;

    private int AreaSeleccionadaId
    {
        get => EmpleadoEdicion?.Area?.AreaID ?? 0;
        set
        {
            if (EmpleadoEdicion == null) return;
            EmpleadoEdicion.Area = value == 0 ? null : Areas.FirstOrDefault(a => a.AreaID == value);
            EmpleadoEdicion.Rol = null;
        }
    }

    private int RolSeleccionadoId
    {
        get => EmpleadoEdicion?.Rol?.RolID ?? 0;
        set
        {
            if (EmpleadoEdicion != null)
                EmpleadoEdicion.Rol = value == 0 ? null : Roles.FirstOrDefault(r => r.RolID == value);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        EsCreacion = Navigation.Uri.Contains("/Crear");
        if (EsCreacion)
        {
            UsuarioEdicion = new Empleado();
            UsuarioEdicion.Estado = EstadoUsuario.ACTIVO;
        }
        else if (Usuario != null)
        {
            UsuarioEdicion = Usuario;
        }

        IdUsuarioAccion = UsuarioWS.GetCurrentUserId();
        await CargarCatalogos();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!EsCreacion && Usuario != null && UsuarioEdicion != Usuario)
        {
            UsuarioEdicion = Usuario;
        }
    }

    private async Task CargarCatalogos()
    {
        try { Roles = await RolWS.listarAsync(); } catch { Roles = new List<Rol>(); }
        try { Areas = await AreaWS.listarActivasAsync(); } catch { Areas = new List<Area>(); }
    }

    public async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private string ObtenerNombreJefeDirecto()
    {
        if (EmpleadoEdicion?.JefeDirecto != null)
            return $"{EmpleadoEdicion.JefeDirecto.Nombres} {EmpleadoEdicion.JefeDirecto.ApellidoPaterno}".Trim();

        var jefeArea = EmpleadoEdicion?.Area?.Jefe;
        if (jefeArea != null)
            return $"{jefeArea.Nombres} {jefeArea.ApellidoPaterno}".Trim();

        return "Sin jefe directo (será el jefe del área)";
    }

    private void IrAUsuarios()
    {
        Navigation.NavigateTo("/usuarios");
    }

    private async Task Insertar()
    {
        if (Procesando) return;
        Procesando = true;
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            if (EmpleadoEdicion != null)
            {
                await EmpleadoWS.insertarAsync(EmpleadoEdicion, idUsuarioAccion);
            }
            IrAUsuarios();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task GuardarCambios()
    {
        if (Procesando) return;
        Procesando = true;
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            if (EmpleadoEdicion != null)
            {
                await EmpleadoWS.actualizarAsync(EmpleadoEdicion, idUsuarioAccion);
            }
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task Eliminar()
    {
        if (Procesando) return;
        Procesando = true;
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            if (EmpleadoEdicion != null)
            {
                await EmpleadoWS.eliminarAsync(EmpleadoEdicion.UsuarioID, idUsuarioAccion);
            }
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private void IrACuentasBancarias()
    {
        Navigation.NavigateTo($"/Cuentas Bancarias?empleadoId={EmpleadoEdicion?.UsuarioID}");
    }
}
