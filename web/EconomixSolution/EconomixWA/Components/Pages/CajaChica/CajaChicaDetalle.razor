@rendermode InteractiveServer
@inject ICajaChicaWS CajaChicaWS
@inject ICuentaBancariaWS CuentaBancariaWS
@inject IMonedaWS MonedaWS
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
        <div class="p-3 pb-2 d-flex gap-4 align-items-center">
            @if (EsCreacion)
            {
                <p class="h3 mb-0">Registrar Caja Chica</p>
            }
            else
            {
                <p class="h3 mb-0">@(CajaChica?.Nombre ?? "Caja Chica")</p>
            }
        </div>
        <hr class="my-0" />
        <div class="flex-fill overflow-scroll p-3">

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @ErrorMessage
                    <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                </div>
            }

            <div class="row">
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label">Nombre</label>
                    <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                           placeholder="Nombre de la caja chica" @bind="CajaChica!.Nombre">
                </div>
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label">Monto Techo</label>
                    <input type="number" step="0.01" min="0"
                           class="form-control form-control-lg rounded-4 bg-light"
                           placeholder="0.00" @bind="CajaChica!.MontoTecho">
                </div>
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label">Área</label>
                    <select class="form-select form-select-lg rounded-4 bg-light"
                            @bind="AreaSeleccionadaId">
                        <option value="0">Seleccione área</option>
                        @foreach (var area in Areas)
                        {
                            <option value="@area.AreaID">@area.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label">Cuenta bancaria</label>
                    <select class="form-select form-select-lg rounded-4 bg-light"
                            @bind="CuentaBancariaSeleccionadaId"
                            disabled="@(AreaSeleccionadaId <= 0)">
                        <option value="0">@(AreaSeleccionadaId <= 0 ? "Seleccione un área primero" : "Seleccione cuenta")</option>
                        @foreach (var cuenta in CuentasBancariasFiltradas)
                        {
                            <option value="@cuenta.IdCuenta">@cuenta.NombreBanco - @cuenta.NumeroBancario (@(cuenta.Moneda?.Simbolo ?? "-"))</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label">Moneda (automática)</label>
                    <input type="text" class="form-control form-control-lg rounded-4 bg-light" disabled
                           value="@(CajaChica?.Moneda != null ? $"{CajaChica.Moneda.Simbolo} - {CajaChica.Moneda.Nombre}" : "Seleccione una cuenta bancaria")" />
                </div>
            </div>
        </div>
        <hr class="my-0" />
        <div class="p-3 d-flex flex-wrap-nowrap justify-content-end gap-3">
            @if (EsCreacion)
            {
                <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="InsertarCajaChica">
                    @(Procesando ? "Procesando..." : "Registrar")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="VolverAlPanel">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="VolverAlPanel">
                    @(Procesando ? "Procesando..." : "Cancelar")
                </button>
            }
            else
            {
                <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                    @(Procesando ? "Procesando..." : "Guardar Cambios")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="CerrarDetalle">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="EliminarCajaChica">
                    @(Procesando ? "Procesando..." : "Eliminar")
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public CajaChica CajaChica { get; set; } = new();

    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private bool Procesando { get; set; } = false;
    private List<Moneda> Monedas { get; set; } = new();
    private List<CuentaBancaria> CuentasBancarias { get; set; } = new();
    private List<Area> Areas { get; set; } = new();

    private int AreaSeleccionadaId { get; set; }

    private List<CuentaBancaria> CuentasBancariasFiltradas => AreaSeleccionadaId <= 0
        ? new List<CuentaBancaria>()
        : CuentasBancarias
            .Where(c => c.AreaAdministradora?.AreaID == AreaSeleccionadaId)
            .ToList();

    private int MonedaSeleccionadaId
    {
        get => CajaChica.Moneda?.IdMoneda ?? 0;
        set => CajaChica.Moneda = value == 0 ? null : Monedas.FirstOrDefault(m => m.IdMoneda == value);
    }

    private int CuentaBancariaSeleccionadaId
    {
        get => CajaChica.CuentaBancaria?.IdCuenta ?? 0;
        set
        {
            var cuenta = value == 0 ? null : CuentasBancarias.FirstOrDefault(c => c.IdCuenta == value);
            CajaChica.CuentaBancaria = cuenta;
            if (cuenta?.Moneda != null)
            {
                CajaChica.Moneda = new Moneda
                {
                    IdMoneda = cuenta.Moneda.IdMoneda,
                    Nombre = cuenta.Moneda.Nombre,
                    Simbolo = cuenta.Moneda.Simbolo,
                    CodigoISO = cuenta.Moneda.CodigoISO
                };
            }
            else
            {
                CajaChica.Moneda = null;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogos();
        InicializarDesdeParametro();
    }

    protected override void OnParametersSet()
    {
        InicializarDesdeParametro();
    }

    private async Task CargarCatalogos()
    {
        try { Monedas = await MonedaWS.listarAsync(); } catch { Monedas = new List<Moneda>(); }
        try { CuentasBancarias = await CuentaBancariaWS.listarAsync(); } catch { CuentasBancarias = new List<CuentaBancaria>(); }
        try { Areas = await AreaWS.listarAsync(); } catch { Areas = new List<Area>(); }
    }

    private void InicializarDesdeParametro()
    {
        CajaChica ??= new CajaChica { Estado = "ACTIVO", Moneda = new Moneda() };
        EsCreacion = CajaChica.IdFondo <= 0;

        if (CajaChica.CuentaBancaria?.AreaAdministradora != null)
            AreaSeleccionadaId = CajaChica.CuentaBancaria.AreaAdministradora.AreaID;

        if (CajaChica.Moneda == null)
            CajaChica.Moneda = new Moneda();
    }

    private async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private async Task VolverAlPanel()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private bool Validar()
    {
        ErrorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(CajaChica.Nombre))
        {
            ErrorMessage = "El nombre es obligatorio.";
            return false;
        }
        if (CajaChica.MontoTecho <= 0)
        {
            ErrorMessage = "El monto techo debe ser mayor que cero.";
            return false;
        }
        if (CajaChica.Moneda == null || CajaChica.Moneda.IdMoneda <= 0)
        {
            ErrorMessage = "La cuenta bancaria seleccionada no tiene moneda asignada.";
            return false;
        }
        if (CajaChica.CuentaBancaria == null || CajaChica.CuentaBancaria.IdCuenta <= 0)
        {
            ErrorMessage = "Debe seleccionar una cuenta bancaria.";
            return false;
        }
        return true;
    }

    private async Task InsertarCajaChica()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!Validar()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CajaChicaWS.insertarAsync(CajaChica, idUsuarioAccion);
            await VolverAlPanel();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task GuardarCambios()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!Validar()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CajaChicaWS.actualizarAsync(CajaChica, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EliminarCajaChica()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CajaChicaWS.eliminarAsync(CajaChica.IdFondo, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }
}
