@page "/Caja Chica/detalle"
@page "/Caja Chica/Crear"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ICajaChicaWS CajaChicaWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 @(EsCreacion ? "mb-3" : " ")">
        <div class="col-12 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100 d-flex justify-content-between">
                <div class="d-flex flex-column">
                    <div class="d-flex gap-4">
                        @if (EsCreacion)
                        {
                            <p class="h3"> Registar Caja Chica </p>
                        }
                        else
                        {
                            <p class="h3"> @(CajaChica?.Nombre ?? "Caja Chica") </p>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            @ErrorMessage
                            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-6 mt-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                                   placeholder="Nombre de la caja chica" @bind="CajaChica.Nombre">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Monto Techo (S/)</label>
                            <input type="number" step="0.01" min="0"
                                   class="form-control form-control-lg rounded-4 bg-light"
                                   placeholder="0.00" @bind="CajaChica.MontoTecho">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Área Asignada</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                                   placeholder="Nombre del área" @bind="CajaChica.AreaAsignada.Nombre">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Moneda</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                                   placeholder="Moneda" @bind="CajaChica.Moneda.CodigoISO">
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    @if (EsCreacion)
                    {
                        <button type="button" class="btn btn-outline-primary align-self-start mt-3" @onclick="InsertarCajaChica">
                            Registrar
                        </button>
                        <button type="button" class="btn btn-outline-info align-self-start mt-3" @onclick="IrACajaChica">
                            Cerrar
                        </button>
                        <button type="button" class="btn btn-outline-danger align-self-start mt-3" @onclick="IrACajaChica">
                            Cancelar
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-warning align-self-start mt-3" @onclick="GuardarCambios">
                            Guardar Cambios
                        </button>
                        <button type="button" class="btn btn-outline-info align-self-start mt-3" @onclick="CerrarDetalle">
                            Cerrar
                        </button>
                        <button type="button" class="btn btn-outline-danger align-self-start mt-3" @onclick="EliminarCajaChica">
                            Eliminar
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public CajaChica CajaChica { get; set; } = new();

    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        EsCreacion = Navigation.Uri.Contains("/Crear");
        if (EsCreacion)
        {
            CajaChica = new CajaChica();
            CajaChica.AreaAsignada = new Area();
            CajaChica.Moneda = new Moneda();
            CajaChica.CuentaOrigen = new CuentaBancaria();
        }
    }

    private async Task CerrarDetalle()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private void IrACajaChica()
    {
        Navigation.NavigateTo("/Caja Chica");
    }

    private async Task InsertarCajaChica()
    {
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => CajaChicaWS.insertar(CajaChica, idUsuarioAccion));
            IrACajaChica();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task GuardarCambios()
    {
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => CajaChicaWS.actualizar(CajaChica, idUsuarioAccion));
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task EliminarCajaChica()
    {
        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => CajaChicaWS.eliminar(CajaChica.IdFondo, idUsuarioAccion));
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
