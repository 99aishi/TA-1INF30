<div class="card rounded-4 p-3 bg-light mb-2">
    <div class="d-flex flex-row justify-content-between align-items-center gap-3">
        <div class="d-flex flex-column gap-1">
            <p class="h6 mb-0">@CajaChica?.Nombre</p>
            <div class="d-flex flex-row gap-3">
                <span class="badge @EstadoClase rounded-pill">@CajaChica?.Estado</span>
                <p class="text-muted mb-0">@CuentaBancariaText</p>
            </div>
        </div>
        <div class="d-flex flex-row align-items-center gap-2">
            <p class="h6 mb-0 me-2">@(MonedaSimbolo) @MontoTecho.ToString("N2")</p>
            <button type="button" class="btn btn-outline-primary" @onclick="VerCiclos">
                Ver ciclos
            </button>
            @if (OnEditar.HasDelegate)
            {
                <button type="button" class="btn btn-outline-dark" @onclick="Editar">
                    Editar
                </button>
            }
            @if (OnEliminar.HasDelegate && EsActivo)
            {
                <button type="button" class="btn btn-outline-danger" @onclick="Eliminar">
                    Eliminar
                </button>
            }
            @if (OnRecuperar.HasDelegate && !EsActivo)
            {
                <button type="button" class="btn btn-outline-success" @onclick="Recuperar">
                    Recuperar
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public CajaChica? CajaChica { get; set; }

    [Parameter]
    public List<CuentaBancaria> CuentasBancarias { get; set; } = new();

    [Parameter]
    public EventCallback OnVerCiclos { get; set; }

    [Parameter]
    public EventCallback OnEditar { get; set; }

    [Parameter]
    public EventCallback OnEliminar { get; set; }

    [Parameter]
    public EventCallback OnRecuperar { get; set; }

    private string MonedaSimbolo => CajaChica?.Moneda?.Simbolo ?? "S/";

    private double MontoTecho => CajaChica?.MontoTecho ?? 0;

    private bool EsActivo => string.Equals(CajaChica?.Estado, "ACTIVO", StringComparison.OrdinalIgnoreCase);

    private string CuentaBancariaText
    {
        get
        {
            var id = CajaChica?.CuentaBancaria?.IdCuenta ?? 0;
            if (id <= 0) return "Sin cuenta bancaria";
            var cuenta = CuentasBancarias.FirstOrDefault(c => c.IdCuenta == id);
            return cuenta != null ? $"{cuenta.NombreBanco} - {cuenta.NumeroBancario}" : $"Cuenta #{id}";
        }
    }

    private string EstadoClase => CajaChica?.Estado?.ToUpperInvariant() switch
    {
        "ACTIVO" => "bg-success-subtle text-success",
        "INACTIVO" => "bg-secondary-subtle text-secondary",
        _ => "bg-light text-dark"
    };

    private async Task VerCiclos()
    {
        await OnVerCiclos.InvokeAsync();
    }

    private async Task Editar()
    {
        await OnEditar.InvokeAsync();
    }

    private async Task Eliminar()
    {
        await OnEliminar.InvokeAsync();
    }

    private async Task Recuperar()
    {
        await OnRecuperar.InvokeAsync();
    }
}
