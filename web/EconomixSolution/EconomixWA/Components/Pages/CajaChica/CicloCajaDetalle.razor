@page "/Caja Chica/Detalle"
@page "/Caja Chica/Crear"
@attribute [Authorize(Roles = "Administrador, Tesoreria")]

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ICicloCajaWS CicloCajaWS
@inject ICajaChicaWS CajaChicaWS
@inject IRendicionWS RendicionWS
@inject IUsuarioWS UsuarioWS
@inject IJSRuntime JS
@using Microsoft.AspNetCore.WebUtilities

<div class="d-flex flex-column h-100 mb-3">
    <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
        <div class="p-3 pb-2 d-flex gap-4 align-items-center">
            @if (EsCreacion)
            {
                <p class="h3 mb-0">Registrar Ciclo de Caja Chica</p>
            }
            else
            {
                <p class="h3 mb-0">Ciclo Semana @(Ciclo?.NumeroSemana ?? 0)</p>
                <span class="badge @EstadoClase rounded-pill">@(Ciclo?.Estado ?? "-")</span>
            }
        </div>
        <hr class="my-0" />
        <div class="flex-fill overflow-scroll p-3">

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @ErrorMessage
                    <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                </div>
            }

            @if (!PuedeEditar && !EsCreacion)
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    Solo un usuario de Tesorería puede modificar ciclos de caja chica.
                </div>
            }

            <div class="row">
                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label small text-muted">Caja Chica</label>
                    <select class="form-select form-select-lg rounded-4 bg-light @(Errores.ContainsKey("CajaChica") ? "is-invalid" : "")"
                            @bind="CajaChicaSeleccionadaId"
                            disabled="@DeshabilitarCajaChica">
                        <option value="0">Seleccione una caja chica</option>
                        @foreach (var caja in CajasChicas)
                        {
                            <option value="@caja.IdFondo">@caja.Nombre</option>
                        }
                    </select>
                    @if (Errores.ContainsKey("CajaChica"))
                    {
                        <div class="text-danger small mt-1">@Errores["CajaChica"]</div>
                    }
                </div>

                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label small text-muted">Monto Techo (saldo inicial)</label>
                    <input type="text"
                           class="form-control form-control-lg rounded-4 bg-light"
                           value="@SimboloMoneda @MontoTecho.ToString("N2")"
                           disabled />
                </div>

                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label small text-muted">Fecha de apertura</label>
                    <input type="date" class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("FechaApertura") ? "is-invalid" : "")"
                           @bind="Ciclo!.FechaApertura"
                           disabled="@(!PuedeEditar)" />
                    @if (Errores.ContainsKey("FechaApertura"))
                    {
                        <div class="text-danger small mt-1">@Errores["FechaApertura"]</div>
                    }
                </div>

                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label small text-muted">Fecha de cierre</label>
                    <input type="date" class="form-control form-control-lg rounded-4 bg-light"
                           @bind="Ciclo!.FechaCierre"
                           disabled="@(!PuedeEditar)" />
                </div>

                <div class="col-12 col-md-6 mt-3">
                    <label class="form-label small text-muted">Estado</label>
                    <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                           value="@(Ciclo?.Estado ?? "-")"
                           disabled />
                </div>

                @if (!EsCreacion && Ciclo?.Estado == "EN_EXCEPCION" && PuedeEditar)
                {
                    <div class="col-12 mt-3">
                        <div class="alert alert-warning d-flex align-items-center justify-content-between">
                            <span>
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                El ciclo está en excepción por fin de semana.
                            </span>
                            <button type="button" class="btn btn-sm btn-outline-warning" @onclick="MarcarRevisado">
                                Marcar como revisado
                            </button>
                        </div>
                    </div>
                }

                @if (!EsCreacion)
                {
                    <div class="col-12 col-md-6 mt-3">
                        <label class="form-label small text-muted">Total gastado</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                               value="@(SimboloMoneda) @((Ciclo?.TotalGastado ?? 0).ToString("N2"))"
                               disabled />
                    </div>
                    <div class="col-12 col-md-6 mt-3">
                        <label class="form-label small text-muted">Disponible</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light"
                               value="@(SimboloMoneda) @Disponible.ToString("N2")"
                               disabled />
                    </div>
                    <div class="col-12 mt-3">
                        <label class="form-label small text-muted">Control de Comprobantes</label>
                        <div class="alert alert-info py-2 px-3 rounded-4 small mb-0">
                            <strong>Comprobantes aprobados:</strong> @ComprobantesAprobados de @TotalComprobantes
                        </div>
                    </div>
                    <div class="col-12 mt-3">
                        <button type="button" class="btn btn-outline-primary w-100 rounded-4 py-2 fw-semibold" @onclick="NavegarASolicitudes">
                            <i class="bi bi-list-check me-2"></i>Ver Solicitudes del Ciclo
                        </button>
                    </div>
                }
            </div>
        </div>
        <hr class="my-0" />
        <div class="p-3 d-flex flex-wrap-nowrap justify-content-end gap-3">
            @if (EsCreacion)
            {
                <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="InsertarCiclo">
                    @(Procesando ? "Procesando..." : "Registrar")
                </button>
                <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="IrACiclos">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                <button type="button" class="btn btn-outline-secondary" disabled="@Procesando" @onclick="IrACiclos">
                    @(Procesando ? "Procesando..." : "Cancelar")
                </button>
            }
            else
            {
                @if (PuedeEditar && Ciclo?.Estado == "ABIERTO")
                {
                    <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                        @(Procesando ? "Procesando..." : "Guardar Cambios")
                    </button>
                    <button type="button" class="btn btn-outline-dark" disabled="@Procesando" @onclick="EnviarAEvaluacion">
                        @(Procesando ? "Procesando..." : "Enviar a Evaluación")
                    </button>
                }
                else if (PuedeEditar && Ciclo?.Estado == "EN_EVALUACION")
                {
                    <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                        @(Procesando ? "Procesando..." : "Guardar Cambios")
                    </button>
                    <button type="button" class="btn btn-outline-success" disabled="@Procesando" @onclick="CerrarCiclo">
                        @(Procesando ? "Procesando..." : "Confirmar y Cerrar Ciclo")
                    </button>
                    <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="DevolverAlEmpleado">
                        @(Procesando ? "Procesando..." : "Devolver al Empleado")
                    </button>
                }
                else if (PuedeEditar)
                {
                    <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="GuardarCambios">
                        @(Procesando ? "Procesando..." : "Guardar Cambios")
                    </button>
                    @if (MostrarGenerarRendicion)
                    {
                        <button type="button" class="btn btn-outline-primary" @onclick="GenerarRendicion" disabled="@ProcesandoRendicion">
                            @(ProcesandoRendicion ? "Generando..." : "Generar Rendicion")
                        </button>
                    }
                    @if (MostrarVerRendicion)
                    {
                        <button type="button" class="btn btn-outline-info" @onclick="VerRendicion">
                            Ver Rendición
                        </button>
                    }
                }
                <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="CerrarDetalle">
                    @(Procesando ? "Procesando..." : "Cerrar")
                </button>
                @if (PuedeEditar)
                {
                    <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="EliminarCiclo">
                        @(Procesando ? "Procesando..." : "Eliminar")
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public CicloCajaChica Ciclo { get; set; } = new();

    [Parameter]
    public List<CajaChica> CajasChicas { get; set; } = new();

    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> Errores { get; set; } = new();
    private string? RolUsuario { get; set; }
    private bool ProcesandoRendicion { get; set; } = false;
    private bool Procesando { get; set; } = false;

    private bool PuedeEditar => RolUsuario is "Tesorero" or "Tesoreria" or "Tesorero y Finanzas";
    private bool DeshabilitarCajaChica => !EsCreacion || !PuedeEditar;

    private bool MostrarGenerarRendicion =>
        PuedeEditar &&
        Ciclo?.IdCicloCaja > 0 &&
        (Ciclo?.Estado == "CERRADO" || Ciclo?.Estado == "LIQUIDADO" || Ciclo?.Estado == "EN_EXCEPCION") &&
        (Ciclo?.Rendicion == null || Ciclo.Rendicion.IdRendicion <= 0);

    private bool MostrarVerRendicion =>
        Ciclo?.Rendicion != null && 
        Ciclo.Rendicion.IdRendicion > 0;

    private void VerRendicion()
    {
        if (Ciclo?.Rendicion != null && Ciclo.Rendicion.IdRendicion > 0)
        {
            Navigation.NavigateTo($"/Rendiciones?rendicionId={Ciclo.Rendicion.IdRendicion}");
        }
    }

    private string EstadoClase => Ciclo?.Estado?.ToUpperInvariant() switch
    {
        "ABIERTO" => "bg-success-subtle text-success",
        "CERRADO" => "bg-secondary-subtle text-secondary",
        "LIQUIDADO" => "bg-info-subtle text-info",
        "EN_EXCEPCION" => "bg-warning-subtle text-warning",
        _ => "bg-secondary-subtle text-secondary"
    };

    private int TotalComprobantes => Ciclo?.SolicitudesDeGasto?.Sum(s => s.Comprobantes?.Count ?? 0) ?? 0;
    private int ComprobantesAprobados => Ciclo?.SolicitudesDeGasto?.Sum(s => s.Comprobantes?.Count(c => c.Estado?.ToUpperInvariant() == "APROBADO") ?? 0) ?? 0;

    private string SimboloMoneda => Ciclo?.CajaChica?.Moneda?.Simbolo ?? "S/";

    private double MontoTecho => CajaChicaSeleccionada?.MontoTecho ?? Ciclo?.CajaChica?.MontoTecho ?? 0;

    private double Disponible => MontoTecho - (Ciclo?.TotalGastado ?? 0);

    private CajaChica? CajaChicaSeleccionada => CajasChicas.FirstOrDefault(c => c.IdFondo == CajaChicaSeleccionadaId);

    private int CajaChicaSeleccionadaId
    {
        get => Ciclo.CajaChica?.IdFondo ?? 0;
        set
        {
            var caja = value == 0 ? null : CajasChicas.FirstOrDefault(c => c.IdFondo == value);
            Ciclo.CajaChica = caja;
            Ciclo.SaldoInicial = caja?.MontoTecho ?? 0;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        EsCreacion = Navigation.Uri.Contains("/Crear");
        RolUsuario = UsuarioWS.GetCurrentUser()?.Rol?.Titulo;

        if (EsCreacion && PuedeEditar)
        {
            Ciclo = new CicloCajaChica
            {
                FechaApertura = DateTime.Today,
                Estado = "ABIERTO",
                SaldoInicial = 0,
                TotalGastado = 0
            };
        }
        else
        {
            await InicializarDesdeParametros();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!EsCreacion)
        {
            await InicializarDesdeParametros();
        }
    }

    private async Task InicializarDesdeParametros()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("cicloId", out var cicloIdValue)
            && int.TryParse(cicloIdValue, out var cicloId)
            && cicloId > 0)
        {
            Ciclo = await CicloCajaWS.obtenerPorIdAsync(cicloId) ?? new CicloCajaChica();
        }
        else if (Ciclo?.IdCicloCaja <= 0)
        {
            Ciclo = new CicloCajaChica();
        }

        if (EsCreacion && query.TryGetValue("cajaId", out var cajaIdValue)
            && int.TryParse(cajaIdValue, out var cajaId)
            && cajaId > 0)
        {
            var caja = CajasChicas.FirstOrDefault(c => c.IdFondo == cajaId)
                       ?? await CajaChicaWS.obtenerPorIdAsync(cajaId);
            if (caja != null)
            {
                Ciclo.CajaChica = caja;
                Ciclo.SaldoInicial = caja.MontoTecho;
                if (!CajasChicas.Any(c => c.IdFondo == caja.IdFondo))
                    CajasChicas.Add(caja);
            }
        }
    }

    private async Task CerrarDetalle()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (OnCerrarDetalle.HasDelegate)
            {
                await OnCerrarDetalle.InvokeAsync();
            }
            else
            {
                await JS.InvokeVoidAsync("history.back");
            }
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task IrACiclos()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            await JS.InvokeVoidAsync("history.back");
        }
        finally
        {
            Procesando = false;
        }
    }

    private bool Validar()
    {
        Errores.Clear();

        if (Ciclo?.CajaChica == null || Ciclo.CajaChica.IdFondo <= 0)
            Errores["CajaChica"] = "Debe seleccionar una caja chica.";

        if (Ciclo?.FechaApertura == null)
            Errores["FechaApertura"] = "La fecha de apertura es obligatoria.";

        return Errores.Count == 0;
    }

    private async Task InsertarCiclo()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar)
            {
                ErrorMessage = "No tiene permisos para registrar ciclos.";
                return;
            }
            if (!Validar()) return;

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.insertarAsync(Ciclo, idUsuarioAccion);
            IrACiclos();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task GuardarCambios()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar)
            {
                ErrorMessage = "No tiene permisos para modificar ciclos.";
                return;
            }
            if (!Validar()) return;

            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.actualizarAsync(Ciclo, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task CerrarCiclo()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar || Ciclo?.IdCicloCaja <= 0) return;

            ErrorMessage = string.Empty;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.cerrarCicloAsync(Ciclo.IdCicloCaja, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EnviarAEvaluacion()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar || Ciclo == null) return;
            ErrorMessage = string.Empty;
            Ciclo.Estado = "EN_EVALUACION";
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.actualizarAsync(Ciclo, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task DevolverAlEmpleado()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar || Ciclo == null) return;
            ErrorMessage = string.Empty;
            Ciclo.Estado = "ABIERTO";
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.actualizarAsync(Ciclo, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task MarcarRevisado()
    {
        if (!PuedeEditar || Ciclo == null) return;

        Ciclo.Estado = "ABIERTO";
        await GuardarCambios();
    }

    private async Task EliminarCiclo()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            if (!PuedeEditar || Ciclo?.IdCicloCaja <= 0) return;

            ErrorMessage = string.Empty;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await CicloCajaWS.eliminarAsync(Ciclo.IdCicloCaja, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task GenerarRendicion()
    {
        if (!PuedeEditar || Ciclo?.IdCicloCaja <= 0 || ProcesandoRendicion) return;

        ErrorMessage = string.Empty;
        ProcesandoRendicion = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await RendicionWS.generarRendicionDeCicloAsync(Ciclo.IdCicloCaja, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            ProcesandoRendicion = false;
        }
    }

    private void NavegarASolicitudes()
    {
        if (Ciclo?.IdCicloCaja > 0)
        {
            Navigation.NavigateTo($"/Solicitudes De Gasto?cicloId={Ciclo.IdCicloCaja}");
        }
    }
}
