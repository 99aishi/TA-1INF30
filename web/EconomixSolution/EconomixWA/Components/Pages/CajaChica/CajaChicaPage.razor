@page "/Caja Chica"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ICajaChicaWS CajaChicaWS
@inject ICuentaBancariaWS CuentaBancariaWS

<div class="h-100 d-flex flex-column">

    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Cajas Chicas</p>
            <p class="text-muted mb-0">Configuración de fondos fijos y techos presupuestales por cuenta bancaria</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button" class="btn btn-primary" @onclick="IrRegistrarCajaChica">
                + Agregar Caja Chica
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <CajaChicaSearchBar @bind-FiltroNombre="FiltroNombre"
                        @bind-FiltroCuentaBancariaId="FiltroCuentaBancariaId"
                        CuentasBancarias="CuentasBancarias"
                        @bind-FiltroMontoMin="FiltroMontoMin"
                        @bind-FiltroMontoMax="FiltroMontoMax"
                        @bind-FiltroEstado="FiltroEstado" />

    <div class="d-flex flex-column flex-fill overflow-hidden">

        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">

                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando cajas chicas...</p>
                        </div>
                    }
                    else if (CajasFiltradas.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ninguna caja chica coincide con los filtros" : "No hay cajas chicas registradas")
                            </p>
                        </div>
                    }
                    else
                    {
                        @foreach (var cc in CajasFiltradas)
                        {
                             <CajaChicaItem CajaChica="cc"
                                            CuentasBancarias="CuentasBancarias"
                                            PorcentajeUso="50"
                                            MontoTotal="@((decimal)cc.MontoTecho)"
                                            Gastado="0"
                                            Disponible="@((decimal)cc.MontoTecho)"
                                            ProximoCierre="Viernes 18:00"
                                            CerrarPronto="false"
                                            OnMuestraDetalle="() => SeleccionarCajaChica(cc)" />
                        }
                    }
                </div>
            </div>

            @if (MostrarDetalle && CajaSeleccionada != null)
            {
                <div class="col-6 h-100">
                    <CajaChicaDetalle CajaChica="CajaSeleccionada" OnCerrarDetalle="CerrarDetalleCajaChica" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private string FiltroNombre { get; set; } = string.Empty;
    private int FiltroCuentaBancariaId { get; set; }
    private double? FiltroMontoMin { get; set; }
    private double? FiltroMontoMax { get; set; }
    private string FiltroEstado { get; set; } = "Todas";
    private List<CajaChica> Cajas { get; set; } = new();
    private List<CuentaBancaria> CuentasBancarias { get; set; } = new();
    private CajaChica? CajaSeleccionada { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroNombre)
        || FiltroCuentaBancariaId > 0
        || FiltroMontoMin.HasValue
        || FiltroMontoMax.HasValue
        || FiltroEstado != "Todas";

    private IEnumerable<CajaChica> CajasFiltradas => Cajas
        .Where(c => string.IsNullOrWhiteSpace(FiltroNombre)
            || c.Nombre.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase)
            || (CuentaBancariaTexto(c.CuentaBancaria?.IdCuenta ?? 0)).Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase))
        .Where(c => FiltroCuentaBancariaId <= 0 || c.CuentaBancaria?.IdCuenta == FiltroCuentaBancariaId)
        .Where(c => !FiltroMontoMin.HasValue || c.MontoTecho >= FiltroMontoMin.Value)
        .Where(c => !FiltroMontoMax.HasValue || c.MontoTecho <= FiltroMontoMax.Value)
        .Where(c => FiltroEstado == "Todas" || c.Estado == FiltroEstado);

    private string CuentaBancariaTexto(int id)
    {
        if (id <= 0) return string.Empty;
        var cuenta = CuentasBancarias.FirstOrDefault(c => c.IdCuenta == id);
        return cuenta != null ? $"{cuenta.NombreBanco} {cuenta.NumeroBancario}" : string.Empty;
    }

    private void IrRegistrarCajaChica()
    {
        Navigation.NavigateTo("/Caja Chica/Crear");
    }

    private void SeleccionarCajaChica(CajaChica cc)
    {
        CajaSeleccionada = cc;
        MostrarDetalle = true;
    }

    private async Task CerrarDetalleCajaChica()
    {
        await ListarCajas();
        MostrarDetalle = false;
        CajaSeleccionada = null;
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await CargarCatalogos();
        await ListarCajas();
        Cargando = false;
    }

    private async Task CargarCatalogos()
    {
        try
        {
            CuentasBancarias = await Task.Run(() => new List<CuentaBancaria>(CuentaBancariaWS.listar()));
        }
        catch
        {
            CuentasBancarias = new List<CuentaBancaria>();
        }
    }

    private async Task ListarCajas()
    {
        ErrorMessage = string.Empty;
        try
        {
            Cajas = await Task.Run(() => new List<CajaChica>(CajaChicaWS.listar()));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
