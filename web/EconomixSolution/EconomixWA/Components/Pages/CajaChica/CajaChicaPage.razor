@page "/Caja Chica"
@attribute [Authorize(Roles = "Administrador, Tesoreria")]
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ICajaChicaWS CajaChicaWS
@inject ICuentaBancariaWS CuentaBancariaWS
@inject IAreaWS AreaWS
@inject IUsuarioWS UsuarioWS
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities

<div class="h-100 d-flex flex-column">

    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Gestión de Cajas Chicas</p>
            <p class="text-muted mb-0">Administración de fondos fijos, montos y cuentas bancarias asociadas.</p>
        </div>

        <LiveClock />

        <div class="flex-grow-1 text-end">
            <button type="button" class="btn btn-primary" @onclick="PrepararNueva">
                + Agregar Caja Chica
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <CajaChicaSearchBar @bind-FiltroNombre="FiltroNombre"
                        @bind-FiltroCuentaBancariaId="FiltroCuentaBancariaId"
                        @bind-AreasSeleccionadas="AreasSeleccionadasBusqueda"
                        @bind-FiltroEstado="FiltroEstado"
                        @bind-FiltroMontoMin="FiltroMontoMin"
                        @bind-FiltroMontoMax="FiltroMontoMax"
                        CuentasBancarias="CuentasBancarias"
                        Areas="Areas"
                        OnLimpiar="LimpiarFiltros"
                        OnFiltrar="Filtrar" />

    <div class="d-flex flex-column flex-fill overflow-hidden">
        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">
                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando cajas chicas...</p>
                        </div>
                    }
                    else if (CajasChicasFiltradas.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ninguna caja chica coincide con los filtros" : "No hay cajas chicas registradas")
                            </p>
                        </div>
                    }
                    else
                    {
                        @foreach (var cc in CajasChicasFiltradas)
                        {
                            <CajaChicaItemSimple CajaChica="cc"
                                                 CuentasBancarias="CuentasBancarias"
                                                 Areas="Areas"
                                                 OnVerCiclos="() => IrACiclos(cc)"
                                                 OnVer="() => EditarCajaChica(cc)" />
                        }
                    }
                </div>
            </div>

            @if (MostrarDetalle)
            {
                <div class="col-6 h-100">
                    <CajaChicaDetalle CajaChica="CajaChicaEnEdicion"
                                      OnCerrarDetalle="CerrarDetalle" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool Cargando { get; set; } = true;
    private bool MostrarDetalle { get; set; } = false;
    private string ErrorMessage { get; set; } = string.Empty;

    private string FiltroNombre { get; set; } = string.Empty;
    private int FiltroCuentaBancariaId { get; set; }
    private List<Area> AreasSeleccionadasBusqueda { get; set; } = new();
    private string FiltroEstado { get; set; } = "Todas";
    private double? FiltroMontoMin { get; set; }
    private double? FiltroMontoMax { get; set; }

    private List<CajaChica> CajasChicas { get; set; } = new();
    private List<CuentaBancaria> CuentasBancarias { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private CajaChica CajaChicaEnEdicion { get; set; } = new();
    private Dictionary<int, int> _areaIdByCajaChicaId = new();

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroNombre)
        || FiltroCuentaBancariaId > 0
        || AreasSeleccionadasBusqueda.Any()
        || FiltroEstado != "Todas"
        || FiltroMontoMin.HasValue
        || FiltroMontoMax.HasValue;

    private IEnumerable<CajaChica> CajasChicasFiltradas => CajasChicas
        .Where(cc => string.IsNullOrWhiteSpace(FiltroNombre)
            || (cc.Nombre?.Contains(FiltroNombre, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(cc => FiltroCuentaBancariaId <= 0 || cc.CuentaBancaria?.IdCuenta == FiltroCuentaBancariaId)
        .Where(cc => !AreasSeleccionadasBusqueda.Any()
            || AreasSeleccionadasBusqueda.Any(a => _areaIdByCajaChicaId.TryGetValue(cc.IdFondo, out var areaId) && areaId == a.AreaID))
        .Where(cc => FiltroEstado == "Todas" || cc.Estado == FiltroEstado)
        .Where(cc => !FiltroMontoMin.HasValue || cc.MontoTecho >= FiltroMontoMin.Value)
        .Where(cc => !FiltroMontoMax.HasValue || cc.MontoTecho <= FiltroMontoMax.Value)
        .OrderBy(cc => cc.Nombre);

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await CargarCatalogos();
        await ListarCajasChicas();
        BuildAreaLookup();
        Cargando = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("cuentaId", out var cuentaIdValue)
            && int.TryParse(cuentaIdValue, out var cuentaId)
            && cuentaId > 0)
        {
            FiltroCuentaBancariaId = cuentaId;
        }
    }

    private async Task CargarCatalogos()
    {
        try { CuentasBancarias = await CuentaBancariaWS.listarAsync(); }
        catch { CuentasBancarias = new List<CuentaBancaria>(); }

        try { Areas = await AreaWS.listarAsync(); }
        catch { Areas = new List<Area>(); }
    }

    private void BuildAreaLookup()
    {
        var cbByCuentaId = CuentasBancarias
            .Where(cb => cb.AreaAdministradora != null)
            .ToDictionary(cb => cb.IdCuenta, cb => cb.AreaAdministradora!.AreaID);

        _areaIdByCajaChicaId = CajasChicas
            .Where(cc => cc.CuentaBancaria != null && cbByCuentaId.ContainsKey(cc.CuentaBancaria.IdCuenta))
            .ToDictionary(cc => cc.IdFondo, cc => cbByCuentaId[cc.CuentaBancaria!.IdCuenta]);
    }

    private async Task ListarCajasChicas()
    {
        ErrorMessage = string.Empty;
        try { CajasChicas = await CajaChicaWS.listarAsync(); }
        catch (Exception ex) { ErrorMessage = ex.Message; }
    }

    private void LimpiarFiltros()
    {
        FiltroNombre = string.Empty;
        FiltroCuentaBancariaId = 0;
        AreasSeleccionadasBusqueda = new();
        FiltroEstado = "Todas";
        FiltroMontoMin = null;
        FiltroMontoMax = null;
    }

    private void Filtrar() => StateHasChanged();

    private void PrepararNueva()
    {
        CajaChicaEnEdicion = new CajaChica { Estado = "ACTIVO" };
        MostrarDetalle = true;
    }

    private void EditarCajaChica(CajaChica cc)
    {
        CajaChicaEnEdicion = new CajaChica
        {
            IdFondo = cc.IdFondo,
            Nombre = cc.Nombre,
            MontoTecho = cc.MontoTecho,
            Estado = cc.Estado,
            CuentaBancaria = cc.CuentaBancaria,
            Moneda = cc.Moneda
        };
        MostrarDetalle = true;
    }

    private async Task CerrarDetalle()
    {
        MostrarDetalle = false;
        await ListarCajasChicas();
    }

    private void IrACiclos(CajaChica cc)
    {
        Navigation.NavigateTo($"/Caja Chica/Ciclos?cajaId={cc.IdFondo}");
    }
}
