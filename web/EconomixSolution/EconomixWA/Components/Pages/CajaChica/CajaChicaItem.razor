<div class="row align-items-center px-4 py-3 border-bottom">
    <div class="col-3">
        <div class="d-flex align-items-center gap-2">
            <h6 class="fw-bold mb-0">@(Titulo ?? CuentaBancariaText)</h6>
            @if (string.IsNullOrEmpty(Titulo))
            {
                <span class="badge @(CajaChica?.Estado == "ACTIVO" ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                    @(CajaChica?.Estado ?? "-")
                </span>
            }
        </div>
        <small class="text-muted">
            <i class="bi bi-person"></i> @(Subtitulo ?? CajaChica?.Nombre)
        </small>
    </div>

    <div class="col-3">
        <small>Uso de Fondos (@PorcentajeUso%)</small>
        <div class="progress rounded-4 mt-2" style="height: 8px">
            <div class="progress-bar rounded-4 @(PorcentajeUso >= 90 ? "bg-warning" : "bg-primary")"
                 style="width: @($"{PorcentajeUso}%")"
                 role="progressbar"
                 aria-valuenow="@PorcentajeUso"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>
    </div>

    <div class="col-1 text-end">
        <strong>@(CajaChica?.Moneda?.Simbolo ?? "S/") @MontoTotal.ToString("N2")</strong>
    </div>

    <div class="col-1">
        <small class="text-muted">GASTADO</small>
        <p class="text-danger fw-bold mb-0">
            @(CajaChica?.Moneda?.Simbolo ?? "S/") @Gastado.ToString("N2")
        </p>
    </div>

    <div class="col-1">
        <small class="text-muted">DISPONIBLE</small>
        <p class="@(Disponible <= 500 ? "text-danger" : "text-success") fw-bold mb-0">
            @(CajaChica?.Moneda?.Simbolo ?? "S/") @Disponible.ToString("N2")
        </p>
    </div>

    <div class="col-2">
        <small class="@(CerrarPronto ? "text-warning fw-bold" : "text-muted")">
            @(CerrarPronto ? "CERRAR PRONTO" : "PRÓX CIERRE")
        </small>
        <p class="fw-bold mb-0">@ProximoCierre</p>
    </div>

    <div class="col-2 text-end">
        <button class="btn btn-outline-primary btn-sm px-2 me-1"
                @onclick="AbrirDetalle">
            Detalle
        </button>
        <button class="btn btn-outline-dark btn-sm px-2"
                @onclick="GestionarCiclos">
            Ciclos
        </button>
    </div>
</div>

@code {
    [Parameter]
    public CajaChica? CajaChica { get; set; }

    [Parameter]
    public List<CuentaBancaria> CuentasBancarias { get; set; } = new();

    [Parameter]
    public string? Titulo { get; set; }

    [Parameter]
    public string? Subtitulo { get; set; }

    [Parameter]
    public int PorcentajeUso { get; set; }

    [Parameter]
    public decimal MontoTotal { get; set; }

    [Parameter]
    public decimal Gastado { get; set; }

    [Parameter]
    public decimal Disponible { get; set; }

    [Parameter]
    public string ProximoCierre { get; set; } = string.Empty;

    [Parameter]
    public bool CerrarPronto { get; set; }

    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    [Parameter]
    public EventCallback OnGestionarCiclos { get; set; }

    private string CuentaBancariaText
    {
        get
        {
            var id = CajaChica?.CuentaBancaria?.IdCuenta ?? 0;
            if (id <= 0) return "Sin cuenta bancaria";
            var cuenta = CuentasBancarias.FirstOrDefault(c => c.IdCuenta == id);
            if (cuenta == null) return $"Cuenta #{id}";
            return $"{cuenta.NombreBanco} - {cuenta.NumeroBancario}";
        }
    }

    private async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }

    private async Task GestionarCiclos()
    {
        await OnGestionarCiclos.InvokeAsync();
    }
}
