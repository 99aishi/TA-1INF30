<div class="card rounded-4 p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-3">
            <label class="form-label small text-muted">Nombre</label>
            <input type="text" class="form-control bg-light rounded-4"
                   placeholder="Buscar..."
                   @bind="FiltroNombre" @bind:event="oninput" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Cuenta bancaria</label>
            <select class="form-select bg-light rounded-4" @bind="FiltroCuentaBancariaId">
                <option value="0">Todas</option>
                @foreach (var cuenta in CuentasBancariasDisponibles)
                {
                    <option value="@cuenta.IdCuenta">@cuenta.NombreBanco - @cuenta.NumeroBancario</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small text-muted">Área</label>
            <select class="form-select bg-light rounded-4"
                    value="0"
                    @onchange="OnAreaSeleccionada">
                <option value="0">Todas</option>
                @foreach (var area in AreasDisponibles)
                {
                    <option value="@area.AreaID">@area.Nombre</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small text-muted">Estado</label>
            <select class="form-select bg-light rounded-4" @bind="FiltroEstado">
                <option value="Todas">Todas</option>
                <option value="ACTIVO">Activo</option>
                <option value="INACTIVO">Inactivo</option>
            </select>
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label small text-muted">Monto mín.</label>
            <input type="number" step="0.01" class="form-control bg-light rounded-4"
                   placeholder="0.00" @bind="FiltroMontoMin" />
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label small text-muted">Monto máx.</label>
            <input type="number" step="0.01" class="form-control bg-light rounded-4"
                   placeholder="0.00" @bind="FiltroMontoMax" />
        </div>
        <div class="col-6 col-md-1 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-outline-secondary rounded-4" @onclick="Limpiar">
                Limpiar
            </button>
        </div>
    </div>
    @if (AreasSeleccionadas.Any())
    {
        <div class="row mt-2">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var area in AreasSeleccionadas)
                    {
                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill d-flex align-items-center gap-1">
                            @area.Nombre
                            <button type="button" class="btn-close"
                                    style="font-size:0.6em;"
                                    @onclick="() => QuitarArea(area)"></button>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string FiltroNombre { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> FiltroNombreChanged { get; set; }

    [Parameter] public int FiltroCuentaBancariaId { get; set; }
    [Parameter] public EventCallback<int> FiltroCuentaBancariaIdChanged { get; set; }

    [Parameter] public List<CuentaBancaria> CuentasBancarias { get; set; } = new();

    [Parameter] public List<Area> Areas { get; set; } = new();
    [Parameter] public List<Area> AreasSeleccionadas { get; set; } = new();
    [Parameter] public EventCallback<List<Area>> AreasSeleccionadasChanged { get; set; }

    [Parameter] public double? FiltroMontoMin { get; set; }
    [Parameter] public EventCallback<double?> FiltroMontoMinChanged { get; set; }

    [Parameter] public double? FiltroMontoMax { get; set; }
    [Parameter] public EventCallback<double?> FiltroMontoMaxChanged { get; set; }

    [Parameter] public string FiltroEstado { get; set; } = "Todas";
    [Parameter] public EventCallback<string> FiltroEstadoChanged { get; set; }

    [Parameter] public EventCallback OnLimpiar { get; set; }

    [Parameter] public EventCallback OnFiltrar { get; set; }

    private IEnumerable<Area> AreasDisponibles =>
        Areas.Where(a => !AreasSeleccionadas.Any(s => s.AreaID == a.AreaID));

    private IEnumerable<CuentaBancaria> CuentasBancariasDisponibles =>
        CuentasBancarias
            .Where(cb => !AreasSeleccionadas.Any()
                || AreasSeleccionadas.Any(a => a.AreaID == cb.AreaAdministradora?.AreaID));

    private async Task OnAreaSeleccionada(ChangeEventArgs e)
    {
        var areaId = int.TryParse(e.Value?.ToString(), out var val) ? val : 0;
        if (areaId > 0)
        {
            var area = Areas.FirstOrDefault(a => a.AreaID == areaId);
            if (area != null)
            {
                AreasSeleccionadas = new List<Area>(AreasSeleccionadas) { area };
                await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
                FiltroCuentaBancariaId = 0;
                await FiltroCuentaBancariaIdChanged.InvokeAsync(0);
                await OnFiltrar.InvokeAsync();
            }
        }
    }

    private async Task QuitarArea(Area area)
    {
        if (AreasSeleccionadas.Any(a => a.AreaID == area.AreaID))
        {
            AreasSeleccionadas = AreasSeleccionadas.Where(a => a.AreaID != area.AreaID).ToList();
            await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);
            FiltroCuentaBancariaId = 0;
            await FiltroCuentaBancariaIdChanged.InvokeAsync(0);
            await OnFiltrar.InvokeAsync();
        }
    }

    private async Task Limpiar()
    {
        FiltroNombre = string.Empty;
        await FiltroNombreChanged.InvokeAsync(string.Empty);

        FiltroCuentaBancariaId = 0;
        await FiltroCuentaBancariaIdChanged.InvokeAsync(0);

        AreasSeleccionadas = new();
        await AreasSeleccionadasChanged.InvokeAsync(AreasSeleccionadas);

        FiltroMontoMin = null;
        await FiltroMontoMinChanged.InvokeAsync(null);

        FiltroMontoMax = null;
        await FiltroMontoMaxChanged.InvokeAsync(null);

        FiltroEstado = "Todas";
        await FiltroEstadoChanged.InvokeAsync("Todas");

        await OnLimpiar.InvokeAsync();
        await OnFiltrar.InvokeAsync();
    }
}
