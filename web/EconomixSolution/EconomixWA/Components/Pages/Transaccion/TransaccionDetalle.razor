<div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
    <div class="p-3 pb-2 d-flex gap-4 align-items-center">
        <p class="h3 mb-0">Detalle de Transacción</p>
        @if (Transaccion != null)
        {
            <span class="badge rounded-pill @GetTipoBadgeClass() align-self-center">@Transaccion.TipoTransaccion</span>
            <span class="badge rounded-pill @GetEstadoBadgeClass() align-self-center">@Transaccion.EstadoTransaccion</span>
        }
    </div>
    <hr class="my-0" />
    <div class="flex-fill overflow-scroll p-3">
        @if (Transaccion == null)
        {
            <p class="text-muted text-center mt-5">Seleccione una transacción para ver su detalle</p>
        }
        else
        {
            @if (EsModoEdicion)
            {
                <div class="row">
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Nro. Transacción</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="TR-@Transaccion.IdTransaccion" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Fecha</label>
                        <input type="date" class="form-control form-control-lg rounded-4" value="@fechaInput" @onchange="e => fechaInput = e.Value?.ToString()" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Monto</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Moneda?.Simbolo ?? "S/") @Transaccion.Monto.ToString("N2")" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Medio de Pago</label>
                        <select class="form-select form-select-lg rounded-4" @bind="Transaccion.MedioPago">
                            <option value="">Seleccione...</option>
                            <option value="YAPE">YAPE</option>
                            <option value="PLIN">PLIN</option>
                            <option value="TRANSFERENCIA">TRANSFERENCIA</option>
                            <option value="EFECTIVO">EFECTIVO</option>
                        </select>
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Nro. Operación</label>
                        <input type="text" class="form-control form-control-lg rounded-4" @bind="Transaccion.NumeroOperacionBancaria" placeholder="N° operación" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">N° Celular</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Beneficiario?.NumeroCelular ?? "-")" disabled="true" />
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label small text-muted">Beneficiario</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Beneficiario != null ? $"{Transaccion.Beneficiario.Nombres} {Transaccion.Beneficiario.ApellidoPaterno} (N° {Transaccion.Beneficiario.UsuarioID})" : "-")" disabled="true" />
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label small text-muted">Cuenta Destino</label>
                        @if (Transaccion.TipoTransaccion == "DEVOLUCION_SOBRANTE")
                        {
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.CuentaDestino != null ? $"{Transaccion.CuentaDestino.NombreBanco} — N° {Transaccion.CuentaDestino.NumeroBancario}" : "-")" disabled="true" />
                        }
                        else
                        {
                            <select class="form-select form-select-lg rounded-4" @bind="cuentaDestinoId">
                                <option value="">Seleccione una cuenta</option>
                                @foreach (var cuenta in CuentasBancarias)
                                {
                                    <option value="@cuenta.IdCuenta">@cuenta.NombreBanco — @cuenta.NumeroBancario @((!string.IsNullOrEmpty(cuenta.Cci)) ? $"CCI {cuenta.Cci}" : "")</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="col-12 mt-3">
                        <label class="form-label small text-muted">Cuenta Origen (Caja Chica)</label>
                        @{
                            var ctaOrigen = Transaccion.Ciclo?.CajaChica?.CuentaBancaria ?? Transaccion.CuentaOrigen;
                        }
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(ctaOrigen != null ? $"{ctaOrigen.NombreBanco} — N° {ctaOrigen.NumeroBancario} {((!string.IsNullOrEmpty(ctaOrigen.Cci)) ? $"CCI {ctaOrigen.Cci}" : "")}" : "-")" disabled="true" />
                    </div>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Nro. Transacción</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="TR-@Transaccion.IdTransaccion" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Fecha</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Fecha == default ? "-" : Transaccion.Fecha.ToString("dd/MM/yyyy"))" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Monto</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Moneda?.Simbolo ?? "S/") @Transaccion.Monto.ToString("N2")" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Medio de Pago</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.MedioPago ?? "-")" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">Nro. Operación</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.NumeroOperacionBancaria ?? "-")" disabled="true" />
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label small text-muted">N° Celular</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Beneficiario?.NumeroCelular ?? "-")" disabled="true" />
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label small text-muted">Beneficiario</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Beneficiario != null ? $"{Transaccion.Beneficiario.Nombres} {Transaccion.Beneficiario.ApellidoPaterno} (N° {Transaccion.Beneficiario.UsuarioID})" : "-")" disabled="true" />
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label small text-muted">Cuenta Destino</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.CuentaDestino != null ? $"{Transaccion.CuentaDestino.NombreBanco} — N° {Transaccion.CuentaDestino.NumeroBancario} {((!string.IsNullOrEmpty(Transaccion.CuentaDestino.Cci)) ? $"CCI {Transaccion.CuentaDestino.Cci}" : "")}" : "-")" disabled="true" />
                    </div>
                    <div class="col-12 mt-3">
                        <label class="form-label small text-muted">Cuenta Origen (Caja Chica)</label>
                        @{
                            var ctaOrigen = Transaccion.Ciclo?.CajaChica?.CuentaBancaria ?? Transaccion.CuentaOrigen;
                        }
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(ctaOrigen != null ? $"{ctaOrigen.NombreBanco} — N° {ctaOrigen.NumeroBancario} {((!string.IsNullOrEmpty(ctaOrigen.Cci)) ? $"CCI {ctaOrigen.Cci}" : "")}" : "-")" disabled="true" />
                    </div>
                </div>
            }
        }
    </div>
    <hr class="my-0" />
    <div class="p-3 d-flex flex-wrap-nowrap justify-content-end gap-3">
        @if (Transaccion != null && EsModoEdicion)
        {
            <button class="btn btn-outline-secondary" disabled="@Procesando" @onclick="CancelarEdicion">
                Cancelar
            </button>
            <button class="btn btn-outline-primary" disabled="@Procesando" @onclick="ConfirmarTransaccion">
                @(Procesando ? "Procesando..." : "Confirmar")
            </button>
        }
        else if (Transaccion != null)
        {
            <button class="btn btn-outline-info" @onclick="CerrarDetalleComprobante">
                Cerrar
            </button>
        }
    </div>
</div>

@inject ITransaccionWS TransaccionWS
@inject IUsuarioWS UsuarioWS
@inject ICuentaBancariaWS CuentaBancariaWS

@code {
    [Parameter]
    public Transaccion? Transaccion { get; set; }

    [Parameter]
    public EventCallback OnCierraDetalle { get; set; }

    private bool EsModoEdicion { get; set; } = false;
    private string fechaInput { get; set; } = "";
    private int cuentaDestinoId { get; set; } = 0;
    private List<CuentaBancaria> CuentasBancarias { get; set; } = new();
    private bool EsJefe { get; set; } = false;
    private bool Procesando { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        var usuario = UsuarioWS.GetCurrentUser();
        EsJefe = usuario is Empleado emp && (emp.RolFlujo == RolFlujo.JEFE_AREA || emp.Area?.Jefe?.UsuarioID == emp.UsuarioID);

        if (usuario != null)
        {
            try
            {
                CuentasBancarias = await CuentaBancariaWS.listarPorEmpleadoAsync(usuario.UsuarioID);
            }
            catch
            {
                CuentasBancarias = new();
            }
        }

        DeterminarModo();
    }

    protected override void OnParametersSet()
    {
        DeterminarModo();
    }

    private void DeterminarModo()
    {
        if (Transaccion == null)
        {
            EsModoEdicion = false;
            return;
        }

        var usuario = UsuarioWS.GetCurrentUser();
        bool esSuDevolucion = usuario != null 
            && Transaccion.Beneficiario?.UsuarioID == usuario.UsuarioID 
            && Transaccion.TipoTransaccion == "DEVOLUCION_SOBRANTE"
            && Transaccion.EstadoTransaccion == "REGISTRADA";

        if (!EsJefe && !esSuDevolucion)
        {
            EsModoEdicion = false;
            return;
        }

        bool yaEditado = !string.IsNullOrEmpty(Transaccion.MedioPago)
            && Transaccion.Fecha != default;

        EsModoEdicion = !yaEditado;

        if (EsModoEdicion)
        {
            fechaInput = Transaccion.Fecha == default
                ? DateTime.Now.ToString("yyyy-MM-dd")
                : Transaccion.Fecha.ToString("yyyy-MM-dd");

            cuentaDestinoId = Transaccion.CuentaDestino?.IdCuenta ?? 0;
        }
    }

    private string GetTipoBadgeClass()
    {
        return Transaccion.TipoTransaccion switch
        {
            "DESEMBOLSO" => "bg-primary",
            "DEVOLUCION_SOBRANTE" => "bg-success",
            "REEMBOLSO_DEFICIT" => "bg-warning",
            "REPOSICION_FONDO" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetEstadoBadgeClass()
    {
        return Transaccion.EstadoTransaccion switch
        {
            "REGISTRADA" => "bg-warning",
            "COMPLETADA" => "bg-success",
            "ANULADA" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private async Task ConfirmarTransaccion()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            var usuario = UsuarioWS.GetCurrentUser();
            if (usuario == null || Transaccion == null)
                return;

            if (string.IsNullOrEmpty(Transaccion.NumeroOperacionBancaria) && (Transaccion.MedioPago == "YAPE" || Transaccion.MedioPago == "PLIN" || Transaccion.MedioPago == "TRANSFERENCIA"))
                return;

            Transaccion.Fecha = DateTime.Parse(fechaInput);

            if (cuentaDestinoId > 0 && Transaccion.TipoTransaccion != "DEVOLUCION_SOBRANTE")
            {
                Transaccion.CuentaDestino = CuentasBancarias.FirstOrDefault(c => c.IdCuenta == cuentaDestinoId);
            }

            if (Transaccion.TipoTransaccion == "DEVOLUCION_SOBRANTE" && Transaccion.Beneficiario?.UsuarioID == usuario.UsuarioID)
            {
                Transaccion.EstadoTransaccion = "COMPLETADA";
            }

            await TransaccionWS.actualizarAsync(Transaccion, usuario.UsuarioID);

            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar cambios: {ex.Message}");
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task CancelarEdicion()
    {
        EsModoEdicion = false;
        await OnCierraDetalle.InvokeAsync();
    }

    public async Task CerrarDetalleComprobante()
    {
        await OnCierraDetalle.InvokeAsync();
    }
}
