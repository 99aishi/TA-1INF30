<div class="card rounded-4 h-100 p-3 d-flex flex-column justify-content-between">
    <div class="row">
        <p class="h4">Detalle de Transacción</p>

        @if (Transaccion == null)
        {
            <p class="text-muted text-center mt-5">Seleccione una transacción para ver su detalle</p>
        }
        else
        {
            <div class="col-6 p-3">
                <label class="form-label">Nro. Transacción</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="TR-@Transaccion.IdTransaccion" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Fecha</label>
                <input type="date" class="form-control form-control-lg rounded-4 bg-light" value="@Transaccion.Fecha.ToString("yyyy-MM-dd")" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Tipo</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Transaccion.TipoTransaccion" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Estado</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Transaccion.EstadoTransaccion" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Monto</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Moneda?.Simbolo ?? "S/") @Transaccion.Monto.ToString("N2")" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Moneda</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Moneda?.Nombre ?? "-")" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Medio de Pago</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@Transaccion.MedioPago" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Nro. Operación Bancaria</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.NumeroOperacionBancaria ?? "-")" disabled="true">
            </div>
            <div class="col-12 p-3">
                <label class="form-label">Beneficiario</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.Beneficiario != null ? $"{Transaccion.Beneficiario.Nombres} {Transaccion.Beneficiario.ApellidoPaterno}" : "-")" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Cuenta de Origen</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.CuentaOrigen != null ? $"{Transaccion.CuentaOrigen.NombreBanco} - {Transaccion.CuentaOrigen.NumeroBancario}" : "-")" disabled="true">
            </div>
            <div class="col-6 p-3">
                <label class="form-label">Cuenta de Destino</label>
                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Transaccion.CuentaDestino != null ? $"{Transaccion.CuentaDestino.NombreBanco} - {Transaccion.CuentaDestino.NumeroBancario}" : "-")" disabled="true">
            </div>
        }
    </div>

    <div class="d-flex justify-content-end gap-3">
        <button class="btn btn-primary align-self-start mt-3" @onclick="CerrarDetalleComprobante">
            Cerrar
        </button>
    </div>
</div>

@code {
    [Parameter]
    public Transaccion? Transaccion { get; set; }

    [Parameter]
    public EventCallback OnCierraDetalle { get; set; }

    public async Task CerrarDetalleComprobante()
    {
        await OnCierraDetalle.InvokeAsync();
    }
}
