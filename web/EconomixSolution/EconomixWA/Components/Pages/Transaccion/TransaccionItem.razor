<div class="card rounded-4 p-3 bg-light d-flex flex-row justify-content-between align-items-center">
    <div class="d-flex flex-column justify-content-between">
        <p class="h5 mb-1">@Transaccion?.Beneficiario?.Nombres @Transaccion?.Beneficiario?.ApellidoPaterno</p>
        <div>
            <span class="badge rounded-pill align-self-start mb-2 px-2 py-1" style="@GetTipoTransaccionBadgeStyle()">@TextoTipoTransaccion</span>
        </div>
        <p class="text-muted mb-1">Fecha: @(Transaccion == null || Transaccion.Fecha == default ? "-" : Transaccion.Fecha.ToString("yyyy-MM-dd"))</p>
    </div>
    <div class="d-flex flex-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <p class="h4">@SimboloMoneda @Transaccion?.Monto.ToString("N2")</p>
        </div>
        <div class="d-flex flex-column justify-content-center gap-2">
            @if (Transaccion?.EstadoTransaccion != "REGISTRADA")
            {
                <span class="badge h-100 rounded-pill px-2" style="@GetMedioPagoBadgeStyle()">@Transaccion?.MedioPago</span>
            }
        </div>
        <button class="btn btn-outline-primary" @onclick="AbrirDetalle">Ver</button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<Transaccion> OnMuestraDetalle { get; set; }

    [Parameter]
    public Transaccion? Transaccion { get; set; }

    private string SimboloMoneda
    {
        get
        {
            var s = Transaccion?.Moneda?.Simbolo;
            return string.IsNullOrWhiteSpace(s) ? "S/" : s;
        }
    }

    private string TextoTipoTransaccion => Transaccion?.TipoTransaccion switch
    {
        "DEVOLUCION_SOBRANTE" => "Devolución de Sobrante",
        "DESEMBOLSO" => "Desembolso",
        "REEMBOLSO_DEFICIT" => "Reembolso de Déficit",
        _ => Transaccion?.TipoTransaccion ?? string.Empty
    };

    public async Task AbrirDetalle()
    {
        if (Transaccion != null)
            await OnMuestraDetalle.InvokeAsync(Transaccion);
    }

    private string GetTipoTransaccionBadgeStyle()
    {
        return Transaccion?.TipoTransaccion switch
        {
            "DEVOLUCION_SOBRANTE" => "background-color: #d1e7dd; color: #0f5132;",
            "DESEMBOLSO" => "background-color: #cff4fc; color: #055160;",
            "REEMBOLSO_DEFICIT" => "background-color: #f8d7da; color: #842029;",
            _ => "background-color: #e2e3e5; color: #41464b;"
        };
    }

    private string GetMedioPagoBadgeStyle()
    {
        return Transaccion?.MedioPago switch
        {
            "EFECTIVO" => "background-color: #198754; color: #fff;",
            "YAPE" => "background-color: rgb(157, 0, 255); color: #fff;",
            "PLIN" => "background-color: rgb(229, 185, 49); color: #000;",
            "TRANSFERENCIA" => "background-color: #0d6efd; color: #fff;",
            _ => "background-color: #ffc107; color: #000;"
        };
    }
}
