@rendermode InteractiveServer

<div class="card rounded-4 p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-2">
            <label class="form-label small text-muted">Beneficiario</label>
            <input type="text"
                   class="form-control bg-light rounded-4"
                   placeholder="Nombre"
                   value="@FiltroBeneficiario"
                   @oninput="OnBeneficiarioCambiado" />
        </div>
        <div class="col-4 col-md-1">
            <label class="form-label small text-muted">Medio</label>
            <select class="form-select bg-light rounded-4"
                    value="@FiltroMedio"
                    @onchange="OnMedioCambiado">
                <option value="Todos">Todos</option>
                <option value="TRANSFERENCIA">Transf.</option>
                <option value="YAPE">YAPE</option>
                <option value="EFECTIVO">Efect.</option>
            </select>
        </div>
        <div class="col-4 col-md-1">
            <label class="form-label small text-muted">Tipo</label>
            <select class="form-select bg-light rounded-4"
                    value="@FiltroTipo"
                    @onchange="OnTipoCambiado">
                <option value="Todos">Todos</option>
                <option value="DESEMBOLSO">Desemb.</option>
                <option value="REEMBOLSO">Reemb.</option>
            </select>
        </div>
        <div class="col-4 col-md-1">
            <label class="form-label small text-muted">Monto mín.</label>
            <input type="number"
                   step="0.01"
                   class="form-control bg-light rounded-4"
                   placeholder="0.00"
                   value="@FiltroMontoMin"
                   @oninput="OnMontoMinCambiado" />
        </div>
        <div class="col-4 col-md-1">
            <label class="form-label small text-muted">Monto máx.</label>
            <input type="number"
                   step="0.01"
                   class="form-control bg-light rounded-4"
                   placeholder="0.00"
                   value="@FiltroMontoMax"
                   @oninput="OnMontoMaxCambiado" />
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small text-muted">Fecha inicio</label>
            <input type="date"
                   class="form-control bg-light rounded-4"
                   value="@FiltroFechaInicio?.ToString("yyyy-MM-dd")"
                   @onchange="OnFechaInicioCambiada" />
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small text-muted">Fecha fin</label>
            <input type="date"
                   class="form-control bg-light rounded-4"
                   value="@FiltroFechaFin?.ToString("yyyy-MM-dd")"
                   @onchange="OnFechaFinCambiada" />
        </div>
        <div class="col-4 col-md-2 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-outline-secondary rounded-4" @onclick="Limpiar">
                Limpiar
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string FiltroBeneficiario { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> FiltroBeneficiarioChanged { get; set; }

    [Parameter]
    public string FiltroMedio { get; set; } = "Todos";

    [Parameter]
    public EventCallback<string> FiltroMedioChanged { get; set; }

    [Parameter]
    public string FiltroTipo { get; set; } = "Todos";

    [Parameter]
    public EventCallback<string> FiltroTipoChanged { get; set; }

    [Parameter]
    public double? FiltroMontoMin { get; set; }

    [Parameter]
    public EventCallback<double?> FiltroMontoMinChanged { get; set; }

    [Parameter]
    public double? FiltroMontoMax { get; set; }

    [Parameter]
    public EventCallback<double?> FiltroMontoMaxChanged { get; set; }

    [Parameter]
    public DateTime? FiltroFechaInicio { get; set; }

    [Parameter]
    public EventCallback<DateTime?> FiltroFechaInicioChanged { get; set; }

    [Parameter]
    public DateTime? FiltroFechaFin { get; set; }

    [Parameter]
    public EventCallback<DateTime?> FiltroFechaFinChanged { get; set; }

    [Parameter]
    public EventCallback OnLimpiar { get; set; }

    private async Task OnBeneficiarioCambiado(ChangeEventArgs e)
    {
        FiltroBeneficiario = e.Value?.ToString() ?? string.Empty;
        await FiltroBeneficiarioChanged.InvokeAsync(FiltroBeneficiario);
    }

    private async Task OnMedioCambiado(ChangeEventArgs e)
    {
        FiltroMedio = e.Value?.ToString() ?? "Todos";
        await FiltroMedioChanged.InvokeAsync(FiltroMedio);
    }

    private async Task OnTipoCambiado(ChangeEventArgs e)
    {
        FiltroTipo = e.Value?.ToString() ?? "Todos";
        await FiltroTipoChanged.InvokeAsync(FiltroTipo);
    }

    private async Task OnMontoMinCambiado(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
            FiltroMontoMin = val;
        else
            FiltroMontoMin = null;
        await FiltroMontoMinChanged.InvokeAsync(FiltroMontoMin);
    }

    private async Task OnMontoMaxCambiado(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
            FiltroMontoMax = val;
        else
            FiltroMontoMax = null;
        await FiltroMontoMaxChanged.InvokeAsync(FiltroMontoMax);
    }

    private async Task OnFechaInicioCambiada(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var val))
            FiltroFechaInicio = val.Date;
        else
            FiltroFechaInicio = null;
        await FiltroFechaInicioChanged.InvokeAsync(FiltroFechaInicio);
    }

    private async Task OnFechaFinCambiada(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var val))
            FiltroFechaFin = val.Date;
        else
            FiltroFechaFin = null;
        await FiltroFechaFinChanged.InvokeAsync(FiltroFechaFin);
    }

    private async Task Limpiar()
    {
        FiltroBeneficiario = string.Empty;
        await FiltroBeneficiarioChanged.InvokeAsync(string.Empty);

        FiltroMedio = "Todos";
        await FiltroMedioChanged.InvokeAsync("Todos");

        FiltroTipo = "Todos";
        await FiltroTipoChanged.InvokeAsync("Todos");

        FiltroMontoMin = null;
        await FiltroMontoMinChanged.InvokeAsync(null);

        FiltroMontoMax = null;
        await FiltroMontoMaxChanged.InvokeAsync(null);

        FiltroFechaInicio = null;
        await FiltroFechaInicioChanged.InvokeAsync(null);

        FiltroFechaFin = null;
        await FiltroFechaFinChanged.InvokeAsync(null);

        await OnLimpiar.InvokeAsync();
    }
}
