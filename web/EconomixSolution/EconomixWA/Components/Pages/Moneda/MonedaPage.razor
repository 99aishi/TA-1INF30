@page "/Monedas"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IMonedaWS MonedaWS

<div class="h-100 d-flex flex-column">
    <div class="d-flex flex-row justify-content-between align-items-center mb-3">
        <div>
            <p class="h4 mb-1">Monedas</p>
            <p class="text-muted mb-0">Catálogo de monedas utilizadas para solicitudes, comprobantes y transacciones.</p>
        </div>

        <button type="button" class="btn btn-primary" @onclick="PrepararNuevaMoneda">
            + Agregar moneda
        </button>
    </div>

    <MonedaSearchBar @bind-Busqueda="Busqueda"
                     @bind-FiltroEstado="FiltroEstado" />

    <div class="d-flex flex-column flex-fill overflow-hidden">

        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(@MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">

                <div class="card rounded-4 p-3 h-100 overflow-scroll">

                    @if (Cargando)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando monedas...</p>
                        </div>
                    }
                    else if (MonedasFiltradas.Count() == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">
                                @(HayFiltrosActivos ? "Ninguna moneda coincide con los filtros aplicados" : "No se encontraron monedas")
                            </p>
                        </div>
                    }
                    else
                    {
                        @foreach (var moneda in MonedasFiltradas)
                        {
                            <MonedaItem Moneda="moneda"
                                        Seleccionada="@(MonedaSeleccionada?.IdMoneda == moneda.IdMoneda)"
                                        OnSeleccionar="() => SeleccionarMoneda(moneda)" />
                        }
                    }
                </div>

            </div>
            @if (MostrarDetalle && MonedaSeleccionada != null)
            {
                <div class="col-6 h-100">
                    <MonedaDetalle Moneda="MonedaSeleccionada" OnCerrarDetalle="CerrarDetalleMoneda" />
                </div>
            }
        </div>

    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string Busqueda { get; set; } = string.Empty;
    private string FiltroEstado { get; set; } = "Todas";
    private Moneda? MonedaSeleccionada { get; set; }
    private List<Moneda> Monedas { get; set; } = new();

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(Busqueda)
        || FiltroEstado != "Todas";

    private IEnumerable<Moneda> MonedasFiltradas => Monedas
        .Where(m => string.IsNullOrWhiteSpace(Busqueda)
            || m.CodigoISO.Contains(Busqueda, StringComparison.OrdinalIgnoreCase)
            || m.Simbolo.Contains(Busqueda, StringComparison.OrdinalIgnoreCase)
            || m.Nombre.Contains(Busqueda, StringComparison.OrdinalIgnoreCase))
        .Where(m => FiltroEstado == "Todas" || (FiltroEstado == "Activa" && m.Activa) || (FiltroEstado == "Inactiva" && !m.Activa));

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await ListarMonedas();
        Cargando = false;
    }

    private async Task ListarMonedas()
    {
        Monedas = await Task.Run(() =>
            new List<Moneda>(MonedaWS.listar()));
    }

    private async Task CerrarDetalleMoneda()
    {
        await ListarMonedas();
        MostrarDetalle = false;
        MonedaSeleccionada = null;
    }

    private void SeleccionarMoneda(Moneda moneda)
    {
        MonedaSeleccionada = moneda;
        MostrarDetalle = true;
    }

    private void PrepararNuevaMoneda()
    {
        MonedaSeleccionada = new Moneda();
        MostrarDetalle = true;
    }

    private async Task OnLimpiar()
    {
        Busqueda = string.Empty;
        FiltroEstado = "Todas";
    }
}
