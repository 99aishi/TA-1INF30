<div class="card rounded-4 p-3 bg-light moneda-card @(Seleccionada ? "moneda-card-selected" : string.Empty)"
     role="button"
     @onclick="Seleccionar">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div class="d-flex align-items-start gap-3">
            <div class="moneda-symbol-box">
                @Simbolo
            </div>
            <div>
                <div class="d-flex align-items-center gap-3 mb-1">
                    <p class="h5 mb-0">@CodigoIso</p>
                        <span class="badge @(Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") rounded-pill">
                            @(Activo ? "Activa" : "Inactiva")
                        </span>
                </div>
                <p class="mb-1 fw-semibold">@Nombre</p>
                <p class="text-muted mb-0 small">@Descripcion</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string CodigoIso { get; set; } = string.Empty;
    [Parameter] public string Simbolo { get; set; } = string.Empty;
    [Parameter] public string Nombre { get; set; } = string.Empty;
    [Parameter] public string Tipo { get; set; } = "Moneda";
    [Parameter] public string Descripcion { get; set; } = string.Empty;
    [Parameter] public string Uso { get; set; } = string.Empty;
    [Parameter] public bool Activo { get; set; } = true;
    [Parameter] public bool Seleccionada { get; set; }
    [Parameter] public EventCallback OnSeleccionar { get; set; }

    private async Task Seleccionar()
    {
        await OnSeleccionar.InvokeAsync();
    }
}
