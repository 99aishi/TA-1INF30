<div class="card rounded-4 p-3 mb-3 bg-light moneda-card @(Seleccionada ? "moneda-card-selected" : string.Empty) justify-content-center">
    <div class="d-flex flex-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-start gap-3">
            <div class="moneda-symbol-box">
                @Moneda.Simbolo
            </div>
            <div>
                <div class="d-flex align-items-center gap-3 mb-1">
                    <p class="h5 mb-0">@Moneda.CodigoISO</p>
                    <span class="badge @(Moneda.Activa ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") rounded-pill">
                        @(Moneda.Activa ? "Activa" : "Inactiva")
                    </span>
                </div>
                <p class="mb-1 fw-semibold">@Moneda.Nombre</p>
                <p class="text-muted mb-0 small">@Moneda.Descripcion</p>
            </div>
        </div>
        <div class="d-flex align-items-center justify-content-center">
            <button class="btn btn-outline-primary" @onclick="Seleccionar">
                Ver
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Moneda Moneda { get; set; } = new();

    [Parameter]
    public bool Seleccionada { get; set; }

    [Parameter]
    public EventCallback OnSeleccionar { get; set; }

    private async Task Seleccionar()
    {
        await OnSeleccionar.InvokeAsync();
    }
}
