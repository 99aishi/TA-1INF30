@page "/moneda/Crear"
@page "/moneda/detalle"

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IMonedaWS MonedaWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100">
        <div class="col-12 h-100">
            <div class="card rounded-4 p-3 h-100 d-flex justify-content-between">
                <div class="d-flex flex-column">
                    <div class="d-flex gap-4">
                        @if (EsCreacion)
                        {
                            <p class="h3"> Registrar Moneda </p>
                        }
                        else
                        {
                            <p class="h3"> Moneda @Moneda.CodigoISO</p>
                        }
                        <div class="d-flex flex-column justify-content-center gap-2">
                            <span class="badge @(Moneda.Activa ? "text-bg-success" : "text-bg-secondary") rounded-pill px-2">
                                @(Moneda.Activa ? "Activa" : "Inactiva")
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            Ocurrió un error al procesar la solicitud
                            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-6 mt-3">
                            <label for="CodigoISO" class="form-label">Código ISO</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("CodigoISO") ? "is-invalid" : "")"
                                   id="CodigoISO"
                                   placeholder="PEN, USD, EUR"
                                   @bind="Moneda.CodigoISO">
                            @if (Errores.ContainsKey("CodigoISO"))
                            {
                                <div class="text-danger small mt-1">@Errores["CodigoISO"]</div>
                            }
                        </div>

                        <div class="col-6 mt-3">
                            <label for="Simbolo" class="form-label">Símbolo</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("Simbolo") ? "is-invalid" : "")"
                                   id="Simbolo"
                                   placeholder="S/., $, €"
                                   @bind="Moneda.Simbolo">
                            @if (Errores.ContainsKey("Simbolo"))
                            {
                                <div class="text-danger small mt-1">@Errores["Simbolo"]</div>
                            }
                        </div>

                        <div class="col-12 mt-3">
                            <label for="Nombre" class="form-label">Nombre</label>
                            <input type="text"
                                   class="form-control form-control-lg rounded-4 bg-light @(Errores.ContainsKey("Nombre") ? "is-invalid" : "")"
                                   id="Nombre"
                                   placeholder="Sol peruano, Dólar americano"
                                   @bind="Moneda.Nombre">
                            @if (Errores.ContainsKey("Nombre"))
                            {
                                <div class="text-danger small mt-1">@Errores["Nombre"]</div>
                            }
                        </div>

                        <div class="col-12 mt-3">
                            <label for="Descripcion" class="form-label">Descripción</label>
                            <textarea class="form-control bg-light rounded-4"
                                      id="Descripcion" rows="4"
                                      placeholder="Describe en qué casos se usa esta moneda dentro del sistema."
                                      @bind="Moneda.Descripcion"></textarea>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-4">
                    @if (EsCreacion)
                    {
                        <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="InsertarMoneda">
                            @(Procesando ? "Procesando..." : "Registrar")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="Cerrar">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="Cerrar">
                            @(Procesando ? "Procesando..." : "Cancelar")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-warning" disabled="@Procesando" @onclick="ActualizarMoneda">
                            @(Procesando ? "Procesando..." : "Guardar Cambios")
                        </button>
                        <button type="button" class="btn btn-outline-info" disabled="@Procesando" @onclick="Cerrar">
                            @(Procesando ? "Procesando..." : "Cerrar")
                        </button>
                        @if (Moneda.Activa)
                        {
                            <button type="button" class="btn btn-outline-danger" disabled="@Procesando" @onclick="EliminarMoneda">
                                @(Procesando ? "Procesando..." : "Eliminar")
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success" disabled="@Procesando" @onclick="RecuperarMoneda">
                                @(Procesando ? "Procesando..." : "Recuperar")
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnCerrarDetalle { get; set; }

    [Parameter]
    public Moneda Moneda { get; set; } = new();

    private bool EsCreacion { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> Errores { get; set; } = new();
    private bool Procesando { get; set; } = false;

    protected override void OnInitialized()
    {
        CalcularEsCreacion();
    }

    protected override void OnParametersSet()
    {
        CalcularEsCreacion();
    }

    private void CalcularEsCreacion()
    {
        EsCreacion = Navigation.Uri.Contains("/Crear") || Moneda.IdMoneda == 0;
        if (EsCreacion && Moneda.IdMoneda == 0)
        {
            Moneda = new Moneda();
        }
    }

    private async Task Cerrar()
    {
        await OnCerrarDetalle.InvokeAsync();
    }

    private bool ValidarFormulario()
    {
        Errores.Clear();

        if (string.IsNullOrWhiteSpace(Moneda.CodigoISO) || Moneda.CodigoISO.Trim().Length != 3)
            Errores["CodigoISO"] = "El código ISO debe tener 3 caracteres.";
        else
            Moneda.CodigoISO = Moneda.CodigoISO.Trim().ToUpperInvariant();

        if (string.IsNullOrWhiteSpace(Moneda.Simbolo))
            Errores["Simbolo"] = "El símbolo de la moneda es obligatorio.";

        if (string.IsNullOrWhiteSpace(Moneda.Nombre))
            Errores["Nombre"] = "El nombre de la moneda es obligatorio.";

        return Errores.Count == 0;
    }

    private async Task InsertarMoneda()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            if (!ValidarFormulario()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await MonedaWS.insertarAsync(Moneda, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task ActualizarMoneda()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            if (!ValidarFormulario()) return;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await MonedaWS.actualizarAsync(Moneda, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EliminarMoneda()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await MonedaWS.eliminarAsync(Moneda.IdMoneda, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task RecuperarMoneda()
    {
        if (Procesando) return;
        Procesando = true;
        try
        {
            ErrorMessage = string.Empty;
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await MonedaWS.recuperarAsync(Moneda.IdMoneda, idUsuarioAccion);
            await OnCerrarDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }
}
