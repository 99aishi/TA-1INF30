@page "/DashboardTesoreria"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ICajaChicaWS CajaChicaWS
@inject ICicloCajaWS CicloCajaWS
@inject IAreaWS AreaWS
@inject IEmpleadoWS EmpleadoWS
@inject ICuentaBancariaWS CuentaBancariaWS
@using EconomixWA.Components.Pages.CajaChica

<div class="d-flex flex-column h-100">

<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACajaChica">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Fondos Totales</h6>
                <p class="card-text h2">@FormatearSoles(FondosTotales)</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACajaChica">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h6 class="card-subtitle mb-2 text-body-primary">Fondos utilizados</h6>
                    <p class="card-text h2">@FormatearSoles(FondosUtilizados)</p>
                </div>
                <div class="progress rounded-4 mt-2" style="height: 10px">
                    <div class="progress-bar rounded-4" style="width: @PorcentajeUtilizado%" role="progressbar" aria-valuenow="@PorcentajeUtilizado" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACajaChica">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Saldo disponible</h6>
                <p class="card-text h2">@FormatearSoles(SaldoDisponible)</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACiclos">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Ciclos Activos</h6>
                <p class="card-text h2">@CiclosActivos</p>
                <p class="card-text" style="color: rgb(188, 94, 53)">@CiclosRevision requieren revisión</p>
            </div>
        </div>
    </div>
</div>

<div class="mb-2">
    <p class="h5 mb-1">Ciclos de caja chica por área</p>
    <p class="text-muted mb-0 small">Visualización y seguimiento de cajas chicas por cada área de la empresa</p>
</div>

<div class="card rounded-4 h-100 d-flex flex-column overflow-hidden flex-fill mb-3">
        <div class="overflow-scroll overflow-x-hidden flex-fill p-3">
            @if (Cargando)
            {
                <div class="p-3 text-center text-muted">Cargando ciclos...</div>
            }
            else if (CiclosCajaChica.Count == 0)
            {
                <div class="p-3 text-center text-muted">No se encontraron ciclos de caja chica</div>
            }
            else
            {
                @foreach (var ciclo in CiclosCajaChica)
                {
                    var c = ciclo;
                    <CajaChicaItem Titulo="@c.Area"
                                   Subtitulo="@c.Responsable"
                                   PorcentajeUso="@c.PorcentajeUso"
                                   MontoTotal="@c.MontoTotal"
                                   Gastado="@c.Gastado"
                                   Disponible="@c.Disponible"
                                   ProximoCierre="@c.ProximoCierre"
                                   CerrarPronto="@c.CerrarPronto"
                                   OnMuestraDetalle="() => VerDetalleCiclo(c)"
                                   OnGestionarCiclos="() => VerCiclosCajaChica(c)" />
                }
            }
        </div>
</div>

</div>

@code {
    private double FondosTotales { get; set; }
    private double FondosUtilizados { get; set; }
    private double SaldoDisponible => FondosTotales - FondosUtilizados;
    private int PorcentajeUtilizado => FondosTotales > 0 ? (int)((FondosUtilizados / FondosTotales) * 100) : 0;
    private int CiclosActivos { get; set; }
    private int CiclosRevision { get; set; }

    private List<CicloCajaChica> CiclosCajaChica { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private List<Empleado> Empleados { get; set; } = new();
    private List<CajaChica> CajasChicas { get; set; } = new();
    private List<CuentaBancaria> CuentasBancarias { get; set; } = new();
    private Dictionary<int, int> _areaIdByCajaChicaId = new();
    private bool Cargando { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await Task.WhenAll(
            CargarFondos(),
            CargarCatalogos());

        BuildAreaLookup();
        await CargarCiclos();
        Cargando = false;
    }

    private async Task CargarCatalogos()
    {
        try { Areas = await AreaWS.listarAsync(); } catch { Areas = new(); }
        try { Empleados = await EmpleadoWS.listarAsync(); } catch { Empleados = new(); }
        try { CajasChicas = await CajaChicaWS.listarAsync(); } catch { CajasChicas = new(); }
        try { CuentasBancarias = await CuentaBancariaWS.listarAsync(); } catch { CuentasBancarias = new(); }
    }

    private void BuildAreaLookup()
    {
        var cbByCuentaId = CuentasBancarias
            .Where(cb => cb.AreaAdministradora != null)
            .ToDictionary(cb => cb.IdCuenta, cb => cb.AreaAdministradora!.AreaID);

        _areaIdByCajaChicaId = CajasChicas
            .Where(cc => cc.CuentaBancaria != null && cbByCuentaId.ContainsKey(cc.CuentaBancaria.IdCuenta))
            .ToDictionary(cc => cc.IdFondo, cc => cbByCuentaId[cc.CuentaBancaria!.IdCuenta]);
    }

    private async Task CargarFondos()
    {
        try
        {
            var cajas = await CajaChicaWS.listarAsync();
            FondosTotales = cajas.Sum(c => c.MontoTecho);
        }
        catch
        {
            FondosTotales = 0;
        }
    }

    private async Task CargarCiclos()
    {
        try
        {
            var ciclos = await CicloCajaWS.listarAsync();
            FondosUtilizados = ciclos.Sum(c => c.TotalGastado);
            CiclosActivos = ciclos.Count(c => c.Estado.Equals("ABIERTO", StringComparison.OrdinalIgnoreCase));
            CiclosRevision = ciclos.Count(c => c.TotalGastado > c.SaldoInicial * 0.8);

            CiclosCajaChica = ciclos.Select(c =>
            {
                var montoTotal = (decimal)c.SaldoInicial;
                var gastado = (decimal)c.TotalGastado;
                var disponible = montoTotal - gastado;
                var porcentaje = montoTotal > 0 ? (int)((gastado / montoTotal) * 100) : 0;
                var fechaCierre = c.FechaCierre;
                var cerrarPronto = fechaCierre.HasValue && fechaCierre.Value.Date <= DateTime.Now.AddDays(3).Date;

                var cajaChicaId = c.CajaChica?.IdFondo ?? 0;
                var areaId = cajaChicaId > 0 && _areaIdByCajaChicaId.TryGetValue(cajaChicaId, out var mappedId) ? mappedId : 0;
                var area = areaId > 0 ? Areas.FirstOrDefault(a => a.AreaID == areaId) : null;
                var areaNombre = area?.Nombre ?? (areaId > 0 ? $"Área #{areaId}" : "Sin área");
                var jefeId = area?.Jefe?.UsuarioID ?? 0;
                var jefe = jefeId > 0 ? Empleados.FirstOrDefault(e => e.UsuarioID == jefeId) : null;
                var responsableNombre = jefe != null
                    ? $"{jefe.Nombres} {jefe.ApellidoPaterno}".Trim()
                    : (jefeId > 0 ? $"Jefe #{jefeId}" : "Sin responsable");

                return new CicloCajaChica
                {
                    IdCicloCaja = c.IdCicloCaja,
                    CajaChicaId = c.CajaChica?.IdFondo ?? 0,
                    Area = areaNombre,
                    Responsable = responsableNombre,
                    PorcentajeUso = porcentaje,
                    MontoTotal = montoTotal,
                    Gastado = gastado,
                    Disponible = disponible,
                    ProximoCierre = fechaCierre?.ToString("dd 'de' MMMM") ?? "Sin fecha",
                    CerrarPronto = cerrarPronto
                };
            }).ToList();
        }
        catch
        {
            FondosUtilizados = 0;
            CiclosActivos = 0;
            CiclosRevision = 0;
            CiclosCajaChica = new();
        }
    }

    private void VerDetalleCiclo(CicloCajaChica ciclo)
    {
        Navigation.NavigateTo($"/Caja Chica/Detalle?cicloId={ciclo.IdCicloCaja}");
    }

    private void VerCiclosCajaChica(CicloCajaChica ciclo)
    {
        Navigation.NavigateTo($"/Caja Chica?cajaId={ciclo.CajaChicaId}");
    }

    private void IrACajaChica() => Navigation.NavigateTo("/Caja Chica");
    private void IrACiclos() => Navigation.NavigateTo("/Ciclos");

    private string FormatearSoles(double monto)
    {
        return $"S/ {monto:N2}";
    }

    public class CicloCajaChica
    {
        public int IdCicloCaja { get; set; }
        public int CajaChicaId { get; set; }
        public string Area { get; set; } = string.Empty;
        public string Responsable { get; set; } = string.Empty;
        public int PorcentajeUso { get; set; }
        public decimal MontoTotal { get; set; }
        public decimal Gastado { get; set; }
        public decimal Disponible { get; set; }
        public string ProximoCierre { get; set; } = string.Empty;
        public bool CerrarPronto { get; set; }
    }
}
