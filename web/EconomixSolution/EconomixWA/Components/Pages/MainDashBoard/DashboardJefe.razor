@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsuarioWS UsuarioWS
@inject IEmpleadoWS EmpleadoWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject ICajaChicaWS CajaChicaWS
@inject ICicloCajaWS CicloCajaWS
@inject IAuditoriaWS AuditoriaWS

<div class="d-flex flex-column flex-grow-1 overflow-hidden pb-4">
    <div class="row g-3 mb-3 flex-shrink-0">
        <div class="col-6 col-lg-3">
            <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACajaChica">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-body-primary">Saldo de Caja Chica</h6>
                    <p class="card-text h2">@FormatearSoles(SaldoCajaChica)</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrASolicitudes">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Pendientes de Aprobación</h6>
                <p class="card-text h2">@PendientesAprobacion</p>
                <p class="card-text text-warning">@Urgentes urgentes</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACiclos">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Gastos del Ciclo</h6>
                <p class="card-text h2">@FormatearSoles(GastosCiclo)</p>
                <p class="card-text">@TransaccionesCiclo transacciones</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrASolicitudes">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Solicitudes Aprobadas</h6>
                <p class="card-text h2">@SolicitudesAprobadas</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 flex-fill overflow-hidden mb-3">
    <div class="col-12 col-lg-6 h-100 d-flex flex-column">
        <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0">Solicitudes Pendientes de Aprobación</h6>
            </div>
            <hr class="my-0" />
            <div class="card-body p-3 overflow-scroll flex-fill">
                @if (CargandoPendientes)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <p class="text-muted">Cargando solicitudes...</p>
                    </div>
                }
                else if (Pendientes.Count == 0)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <p class="text-muted">No hay solicitudes pendientes</p>
                    </div>
                }
                else
                {
                    @foreach (var s in Pendientes)
                    {
                        <SolicitudPendienteJefeItem Solicitud="s" OnEvaluar="() => OnSolicitudEvaluada(s)" />
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6 h-100 d-flex flex-column">
        <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0">Actividad Reciente</h6>
            </div>
            <hr class="my-0" />
            <div class="card-body p-3 overflow-scroll flex-fill">
                @if (CargandoActividad)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <p class="text-muted">Cargando actividad...</p>
                    </div>
                }
                else if (ActividadReciente.Count == 0)
                {
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <p class="text-muted">No hay registros</p>
                    </div>
                }
                else
                {
                    @foreach (var a in ActividadReciente)
                    {
                        <ActividadDashboardItem Actividad="a" />
                    }
                }
            </div>
        </div>
    </div>
</div>
</div>

@code {
    private double SaldoCajaChica { get; set; }
    private int PendientesAprobacion { get; set; }
    private int Urgentes { get; set; }
    private double GastosCiclo { get; set; }
    private int TransaccionesCiclo { get; set; }
    private int SolicitudesAprobadas { get; set; }

    private bool CargandoPendientes { get; set; } = true;
    private List<SolicitudGasto> Pendientes { get; set; } = new();

    private bool CargandoActividad { get; set; } = true;
    private List<AuditLogEntry> ActividadReciente { get; set; } = new();

    private int _idJefe;
    private Empleado? _empleadoJefe;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _idJefe = UsuarioWS.GetCurrentUserId();
        }
        catch
        {
            _idJefe = 0;
        }

        try
        {
            _empleadoJefe = await EmpleadoWS.obtenerPorIdAsync(_idJefe);
        }
        catch { }

        await Task.WhenAll(
            CargarCajaChica(),
            CargarPendientes(),
            CargarCiclos(),
            CargarAprobadas(),
            CargarActividadReciente());
    }

    private async Task CargarCajaChica()
    {
        try
        {
            var cajas = await CajaChicaWS.listarAsync();
            SaldoCajaChica = cajas.Sum(c => c.MontoTecho);
        }
        catch
        {
            SaldoCajaChica = 0;
        }
    }

    private async Task CargarPendientes()
    {
        CargandoPendientes = true;
        try
        {
            var todas = await SolicitudGastoWS.listarAsync();
            if (_empleadoJefe?.Area != null)
            {
                var empleadosArea = await EmpleadoWS.listarPorAreaAsync(_empleadoJefe.Area.AreaID);
                var idsArea = new HashSet<int>(empleadosArea.Select(e => e.UsuarioID));
                Pendientes = todas
                    .Where(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase)
                             && idsArea.Contains(s.Solicitante?.UsuarioID ?? 0))
                    .OrderByDescending(s => s.FechaSolicitud)
                    .ToList();
            }
            else
            {
                Pendientes = todas
                    .Where(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase))
                    .OrderByDescending(s => s.FechaSolicitud)
                    .ToList();
            }
            PendientesAprobacion = Pendientes.Count;
            Urgentes = Pendientes.Count(s => s.FechaSolicitud < DateTime.Now.AddDays(-2));
        }
        catch
        {
            Pendientes = new List<SolicitudGasto>();
            PendientesAprobacion = 0;
            Urgentes = 0;
        }
        CargandoPendientes = false;
    }

    private async Task CargarCiclos()
    {
        try
        {
            var ciclos = await CicloCajaWS.listarAsync();
            GastosCiclo = ciclos.Sum(c => c.TotalGastado);
            TransaccionesCiclo = ciclos.Sum(c => c.SolicitudesDeGasto?.Count ?? 0);
        }
        catch
        {
            GastosCiclo = 0;
            TransaccionesCiclo = 0;
        }
    }

    private async Task CargarAprobadas()
    {
        try
        {
            var aprobadas = (await SolicitudGastoWS.listarPendientesJefeAsync(_idJefe))
                .Where(s => s.Estado.Equals("APROBADO", StringComparison.OrdinalIgnoreCase))
                .ToList();
            SolicitudesAprobadas = aprobadas.Count;
        }
        catch
        {
            SolicitudesAprobadas = 0;
        }
    }

    private async Task CargarActividadReciente()
    {
        CargandoActividad = true;
        try
        {
            var todos = await AuditoriaWS.listarRecientesAsync(50);
            try
            {
                if (_empleadoJefe?.Area != null)
                {
                    var empleadosArea = await EmpleadoWS.listarPorAreaAsync(_empleadoJefe.Area.AreaID);
                    var idsArea = new HashSet<int>(empleadosArea.Select(e => e.UsuarioID));
                    ActividadReciente = todos
                        .Where(a => idsArea.Contains(a.IdUsuarioAuditoria))
                        .Where(a => a.TipoEvento != "LOGIN_SUCCESS")
                        .Take(10)
                        .ToList();
                }
                else
                {
                    ActividadReciente = todos
                        .Where(a => a.TipoEvento != "LOGIN_SUCCESS")
                        .Take(10)
                        .ToList();
                }
            }
            catch
            {
                ActividadReciente = todos
                    .Where(a => a.TipoEvento != "LOGIN_SUCCESS")
                    .Take(10)
                    .ToList();
            }
        }
        catch
        {
            ActividadReciente = new List<AuditLogEntry>();
        }
        CargandoActividad = false;
    }

    private async Task OnSolicitudEvaluada(SolicitudGasto solicitud)
    {
        Pendientes.Remove(solicitud);
        PendientesAprobacion = Pendientes.Count;
        Urgentes = Pendientes.Count(s => s.FechaSolicitud < DateTime.Now.AddDays(-2));
        StateHasChanged();
    }

    private string FormatearSoles(double monto)
    {
        return $"S/ {monto:N2}";
    }

    private void IrACajaChica() => Navigation.NavigateTo("/Caja Chica");
    private void IrASolicitudes() => Navigation.NavigateTo("/Solicitudes De Gasto");
    private void IrACiclos() => Navigation.NavigateTo("/Ciclos");
}
