@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsuarioWS UsuarioWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IComprobantePagoWS ComprobantePagoWS
@inject ICicloCajaWS CicloCajaWS

<div class="row g-3 mb-3">
    <div class="col-6 col-lg-4">
        <div class="card rounded-4 h-100 cursor-pointer" @onclick="IrAMisSolicitudes">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Mis solicitudes pendientes</h6>
                <p class="card-text h2">@MisSolicitudesPendientes</p>
                <p class="card-text text-warning">@Urgentes urgentes</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrAComprobantes">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Comprobantes por subir</h6>
                <p class="card-text h2">@ComprobantesPendientes</p>
                <p class="card-text text-primary">pendientes de sustento</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrAMisSolicitudes">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-body-primary">Gastos del Ciclo</h6>
                <p class="card-text h2">@FormatearSoles(GastosCiclo)</p>
                <p class="card-text text-primary">@MisSolicitudesCiclo solicitudes</p>
            </div>
        </div>
    </div>
</div>

@code {
    private int MisSolicitudesPendientes { get; set; }
    private int Urgentes { get; set; }
    private int ComprobantesPendientes { get; set; }
    private double GastosCiclo { get; set; }
    private int MisSolicitudesCiclo { get; set; }

    protected override async Task OnInitializedAsync()
    {
        int idEmpleado;
        try
        {
            idEmpleado = UsuarioWS.GetCurrentUserId();
        }
        catch
        {
            idEmpleado = 0;
        }

        var tareas = new List<Task>
        {
            CargarMisSolicitudes(idEmpleado),
            CargarComprobantesPendientes(idEmpleado),
            CargarGastosCiclo(idEmpleado)
        };
        await Task.WhenAll(tareas);
    }

    private async Task CargarMisSolicitudes(int idEmpleado)
    {
        try
        {
            var solicitudes = await SolicitudGastoWS.listarPorSolicitanteAsync(idEmpleado);
            MisSolicitudesPendientes = solicitudes.Count(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase));
            Urgentes = solicitudes.Count(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase) && s.FechaSolicitud < DateTime.Now.AddDays(-2));
        }
        catch
        {
            MisSolicitudesPendientes = 0;
            Urgentes = 0;
        }
    }

    private async Task CargarComprobantesPendientes(int idEmpleado)
    {
        try
        {
            var solicitudes = await SolicitudGastoWS.listarPorSolicitanteAsync(idEmpleado);
            ComprobantesPendientes = solicitudes
                .Where(s => s.Estado.Equals("APROBADA", StringComparison.OrdinalIgnoreCase))
                .Count(s => s.Comprobantes == null || s.Comprobantes.Count == 0);
        }
        catch
        {
            ComprobantesPendientes = 0;
        }
    }

    private async Task CargarGastosCiclo(int idEmpleado)
    {
        try
        {
            var ciclos = await CicloCajaWS.listarAsync();
            var misCiclos = ciclos
                .Where(c => c.SolicitudesDeGasto?.Any(s => s.Solicitante?.UsuarioID == idEmpleado) == true)
                .ToList();
            GastosCiclo = misCiclos.Sum(c => c.TotalGastado);
            MisSolicitudesCiclo = misCiclos.Sum(c => c.SolicitudesDeGasto?.Count(s => s.Solicitante?.UsuarioID == idEmpleado) ?? 0);
        }
        catch
        {
            GastosCiclo = 0;
            MisSolicitudesCiclo = 0;
        }
    }

    private string FormatearSoles(double monto)
    {
        return $"S/ {monto:N2}";
    }

    private void IrAMisSolicitudes()
    {
        Navigation.NavigateTo("/Mis Solicitudes De Gasto");
    }

    private void IrAComprobantes()
    {
        Navigation.NavigateTo("/Mis Comprobantes de Pago");
    }
}
