@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IEmpleadoWS EmpleadoWS
@inject IAreaWS AreaWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject ICajaChicaWS CajaChicaWS
@inject IAuditoriaWS AuditoriaWS

<div class="d-flex flex-column h-100 overflow-hidden">
    <div class="row g-3 mb-3">
        <div class="col-6 col-lg-3">
            <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrAUsuarios">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-body-primary">Usuarios Activos</h6>
                    <p class="card-text h2">@UsuariosActivos</p>
                    <p class="card-text" style="color: rgb(188, 94, 53)">@UsuariosNuevos nuevos este mes</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrAAreas">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-body-primary">Áreas activas</h6>
                    <p class="card-text h2">@AreasActivas</p>
                    <p class="card-text" style="color: rgb(188, 94, 53)">@AreasRevision en revisión</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrASolicitudes">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-body-primary">Solicitudes del mes</h6>
                    <p class="card-text h2">@SolicitudesMes</p>
                    <p class="card-text" style="color: rgb(188, 94, 53)">@SolicitudesPendientes pendientes</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card rounded-4 h-100 cursor-pointer hover-shadow" @onclick="IrACajasChicas">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-body-primary">Fondos administrados</h6>
                    <p class="card-text h2">@FormatearSoles(FondosAdministrados)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 flex-fill overflow-hidden mb-3">
        <div class="col-12 col-lg-6 h-100 d-flex flex-column overflow-hidden">
            <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden mb-3">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Solicitudes Recientes</h6>
                    <button class="btn btn-sm btn-outline-primary" @onclick="IrASolicitudes">Ver todas</button>
                </div>
                <hr class="my-0" />
                <div class="card-body p-3 overflow-auto flex-fill">
                    @if (CargandoSolicitudes)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando solicitudes...</p>
                        </div>
                    }
                    else if (SolicitudesRecientes.Count == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">No hay registros</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var s in SolicitudesRecientes)
                        {
                            <SolicitudRecienteItem Solicitud="s"
                                                   OnVerDetalle="VerSolicitud" />
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 h-100 d-flex flex-column overflow-hidden mb-3">
            <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden mb-3">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Actividad Reciente</h6>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-secondary-subtle text-secondary">@ActividadReciente.Count eventos</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick="IrAAuditoria">Ver todo</button>
                    </div>
                </div>
                <hr class="my-0" />
                <div class="card-body p-3 overflow-auto flex-fill">
                    @if (CargandoActividad)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">Cargando actividad...</p>
                        </div>
                    }
                    else if (ActividadReciente.Count == 0)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <p class="text-muted">No hay registros</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var a in ActividadReciente)
                        {
                            <ActividadDashboardItem Actividad="a" />
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int UsuariosActivos { get; set; }
    private int UsuariosNuevos { get; set; }
    private int AreasActivas { get; set; }
    private int AreasRevision { get; set; }
    private int SolicitudesMes { get; set; }
    private int SolicitudesPendientes { get; set; }
    private double FondosAdministrados { get; set; }

    private bool CargandoSolicitudes { get; set; } = true;
    private bool CargandoActividad { get; set; } = true;
    private List<SolicitudGasto> SolicitudesRecientes { get; set; } = new();
    private List<AuditLogEntry> ActividadReciente { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            CargarUsuarios(),
            CargarAreas(),
            CargarSolicitudes(),
            CargarFondos(),
            CargarSolicitudesRecientes(),
            CargarActividadReciente());
    }

    private async Task CargarUsuarios()
    {
        try
        {
            var usuarios = await Task.Run(() => EmpleadoWS.listar());
            UsuariosActivos = usuarios.Count(u => u.Estado == EstadoUsuario.ACTIVO);
            UsuariosNuevos = usuarios.Count(u => u.UsuarioID > 0);
        }
        catch
        {
            UsuariosActivos = 0;
            UsuariosNuevos = 0;
        }
    }

    private async Task CargarAreas()
    {
        try
        {
            var areas = await Task.Run(() => AreaWS.listar());
            AreasActivas = areas.Count(a => a.EstaActivo);
            AreasRevision = areas.Count(a => !a.EstaActivo);
        }
        catch
        {
            AreasActivas = 0;
            AreasRevision = 0;
        }
    }

    private async Task CargarSolicitudes()
    {
        try
        {
            var solicitudes = await Task.Run(() => SolicitudGastoWS.listar());
            var hoy = DateTime.Now;
            SolicitudesMes = solicitudes.Count(s => s.FechaSolicitud.Month == hoy.Month && s.FechaSolicitud.Year == hoy.Year);
            SolicitudesPendientes = solicitudes.Count(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            SolicitudesMes = 0;
            SolicitudesPendientes = 0;
        }
    }

    private async Task CargarFondos()
    {
        try
        {
            var cajas = await Task.Run(() => CajaChicaWS.listar());
            FondosAdministrados = cajas.Sum(c => c.MontoTecho);
        }
        catch
        {
            FondosAdministrados = 0;
        }
    }

    private async Task CargarSolicitudesRecientes()
    {
        CargandoSolicitudes = true;
        try
        {
            var todas = await Task.Run(() => SolicitudGastoWS.listar());
            SolicitudesRecientes = todas
                .OrderByDescending(s => s.FechaSolicitud)
                .Take(10)
                .ToList();
        }
        catch
        {
            SolicitudesRecientes = new List<SolicitudGasto>();
        }
        CargandoSolicitudes = false;
    }

    private async Task CargarActividadReciente()
    {
        CargandoActividad = true;
        try
        {
            ActividadReciente = await Task.Run(() => AuditoriaWS.listarRecientes(15));
        }
        catch
        {
            ActividadReciente = new List<AuditLogEntry>();
        }
        CargandoActividad = false;
    }

    private string FormatearSoles(double monto)
    {
        return $"S/ {monto:N2}";
    }

    private void VerSolicitud(int idSolicitud)
    {
        Navigation.NavigateTo($"/Mis Solicitudes De Gasto/Detalle/{idSolicitud}");
    }

    private void IrAUsuarios() => Navigation.NavigateTo("/Usuarios");
    private void IrAAreas() => Navigation.NavigateTo("/Areas");
    private void IrASolicitudes() => Navigation.NavigateTo("/Solicitudes De Gasto");
    private void IrACajasChicas() => Navigation.NavigateTo("/Caja Chica");
    private void IrAAuditoria() => Navigation.NavigateTo("/Auditoria");
}
