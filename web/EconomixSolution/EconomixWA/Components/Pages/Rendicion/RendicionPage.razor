@page "/Rendiciones"
@attribute [Authorize(Roles = "Administrador, Jefe, Tesoreria")]
@using Microsoft.AspNetCore.WebUtilities
@rendermode InteractiveServer
@inject IRendicionWS RendicionWS
@inject IAreaWS AreaWS
@inject IEmpleadoWS EmpleadoWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IUsuarioWS UsuarioWS
@inject NavigationManager Navigation

<div class="h-100 d-flex flex-column">
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Rendiciones</p>
            <p class="text-muted mb-0">Revision y gestion de rendiciones de caja chica</p>
        </div>
        <LiveClock />
        <div class="flex-grow-1 text-end"></div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <RendicionSearchBar @bind-EstadosSeleccionados="EstadosSeleccionados"
                        @bind-FiltroFechaInicio="FiltroFechaInicio"
                        @bind-FiltroFechaFin="FiltroFechaFin"
                        @bind-AreasSeleccionadas="AreasSeleccionadasBusqueda"
                        @bind-EmpleadosSeleccionados="EmpleadosSeleccionadosBusqueda"
                        Areas="Areas"
                        Empleados="Empleados"
                        OnLimpiar="StateHasChanged"
                        OnFiltrar="Filtrar" />

    <div class="d-flex flex-column flex-fill overflow-hidden">
        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            <div class="@(MostrarDetalle ? "col-6" : "col-12") h-100 d-flex flex-column overflow-hidden">
                <div class="card rounded-4 p-3 h-100 overflow-scroll">
                    @if (Cargando)
                    {
                        <p class="text-muted text-center mt-5">Cargando rendiciones...</p>
                    }
                    else if (RendicionesFiltradas.Count() == 0)
                    {
                        <p class="text-muted text-center mt-5">@(HayFiltrosActivos ? "Ninguna rendicion coincide con los filtros" : "No hay rendiciones registradas")</p>
                    }
                    else
                    {
                        @foreach (var r in RendicionesFiltradas)
                        {
                            <RendicionItem Rendicion="r" OnMuestraDetalle="SeleccionarRendicion"/>
                        }
                    }
                </div>
            </div>

            @if (MostrarDetalle && RendicionSeleccionada != null)
            {
                <div class="col-6 h-100">
                    <RendicionDetalle Rendicion="RendicionSeleccionada" OnCerrarDetalle="CerrarDetalleRendicion"/>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private List<string> EstadosSeleccionados { get; set; } = new();
    private DateTime? FiltroFechaInicio { get; set; }
    private DateTime? FiltroFechaFin { get; set; }
    private List<Area> AreasSeleccionadasBusqueda { get; set; } = new();
    private List<Empleado> EmpleadosSeleccionadosBusqueda { get; set; } = new();

    private List<Rendicion> Rendiciones { get; set; } = new();
    private Rendicion? RendicionSeleccionada { get; set; }
    private List<Area> Areas { get; set; } = new();
    private List<Empleado> Empleados { get; set; } = new();

    private string? RolUsuario { get; set; }
    private bool EsTesoreria => RolUsuario is "Tesorero" or "Tesoreria" or "Tesorero y Finanzas";
    private bool EsAdmin => RolUsuario == "Administrador";
    private bool EsJefe => RolUsuario is "Jefe" or "Jefe de Área" or "Jefe de Area";

    private bool HayFiltrosActivos =>
        EstadosSeleccionados.Any()
        || FiltroFechaInicio.HasValue
        || FiltroFechaFin.HasValue
        || AreasSeleccionadasBusqueda.Any()
        || EmpleadosSeleccionadosBusqueda.Any();

    private IEnumerable<Rendicion> RendicionesFiltradas => Rendiciones
        .Where(r => !EstadosSeleccionados.Any() || EstadosSeleccionados.Any(e => e.Equals(r.Estado, StringComparison.OrdinalIgnoreCase)))
        .Where(r => !FiltroFechaInicio.HasValue || (r.FechaPresentacion.HasValue && r.FechaPresentacion.Value.Date >= FiltroFechaInicio.Value.Date))
        .Where(r => !FiltroFechaFin.HasValue || (r.FechaPresentacion.HasValue && r.FechaPresentacion.Value.Date <= FiltroFechaFin.Value.Date))
        .Where(r => !AreasSeleccionadasBusqueda.Any() || AreasSeleccionadasBusqueda.Any(a => a.AreaID == r.CicloCajaChica?.CajaChica?.CuentaBancaria?.AreaAdministradora?.AreaID))
        .Where(r => !EmpleadosSeleccionadosBusqueda.Any() || EmpleadosSeleccionadosBusqueda.Any(e => r.CicloCajaChica?.SolicitudesDeGasto?.Any(s => s.Solicitante?.UsuarioID == e.UsuarioID) ?? false))
        .OrderByDescending(r => r.IdRendicion);

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        RolUsuario = UsuarioWS.GetCurrentUser()?.Rol?.Titulo;

        try { Areas = await AreaWS.listarAsync(); } catch { Areas = new List<Area>(); }
        try { Empleados = await EmpleadoWS.listarAsync(); } catch { Empleados = new List<Empleado>(); }

        await ListarRendiciones();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("rendicionId", out var rendicionIdValue) 
            && int.TryParse(rendicionIdValue, out var rendicionId) 
            && rendicionId > 0)
        {
            var found = Rendiciones.FirstOrDefault(r => r.IdRendicion == rendicionId);
            if (found != null)
            {
                SeleccionarRendicion(found);
            }
        }

        Cargando = false;
    }

    private async Task ListarRendiciones()
    {
        ErrorMessage = string.Empty;
        try
        {
            if (EsJefe && !EsTesoreria && !EsAdmin)
            {
                var idUsuario = UsuarioWS.GetCurrentUserId();
                var empleado = await EmpleadoWS.obtenerPorIdAsync(idUsuario);
                var idArea = empleado?.Area?.AreaID ?? 0;
                if (idArea > 0)
                {
                    Rendiciones = await RendicionWS.listarPorAreaAsync(idArea);
                }
                else
                {
                    Rendiciones = new List<Rendicion>();
                }
            }
            else
            {
                Rendiciones = await RendicionWS.listarAsync();
            }

            // Para cada rendición, cargar sus solicitudes asociadas para poder filtrar por empleado in-memory de forma segura
            if (Rendiciones != null)
            {
                foreach (var r in Rendiciones)
                {
                    if (r.CicloCajaChica != null && r.CicloCajaChica.SolicitudesDeGasto == null)
                    {
                        try
                        {
                            r.CicloCajaChica.SolicitudesDeGasto = await SolicitudGastoWS.listarPorCicloAsync(r.CicloCajaChica.IdCicloCaja);
                        }
                        catch
                        {
                            r.CicloCajaChica.SolicitudesDeGasto = new List<SolicitudGasto>();
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void SeleccionarRendicion(Rendicion rendicion)
    {
        RendicionSeleccionada = rendicion;
        MostrarDetalle = true;
    }

    private async Task CerrarDetalleRendicion()
    {
        await ListarRendiciones();
        MostrarDetalle = false;
        RendicionSeleccionada = null;
    }

    private void Filtrar() => StateHasChanged();
}
