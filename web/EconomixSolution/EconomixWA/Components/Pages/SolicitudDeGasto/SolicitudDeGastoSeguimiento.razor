<div class="card h-100 p-3">
    <!-- Paso 1: Crear solicitud -->
    <div class="timeline-item">
        <div class="timeline-badge-container">
            <div class="timeline-badge @(EsActivo("Crear solicitud") ? "active" : "")"></div>
            <div class="timeline-line"></div>
        </div>
        <div class="timeline-content">
            <h5 class="fw-bold mb-0">1. Crear solicitud</h5>
            <p class="text-muted small mb-0">Completa la solicitud</p>
        </div>
    </div>

    <!-- Paso 2: Evaluada -->
    <div class="timeline-item">
        <div class="timeline-badge-container">
            <div class="timeline-badge @(EsActivo("Evaluada") ? "active" : "")"></div>
            <div class="timeline-line"></div>
        </div>
        <div class="timeline-content">
            <h5 class="fw-bold mb-0">2. Evaluada</h5>
            <p class="text-muted small mb-0">Solicitud aprobada por el Jefe</p>
        </div>
    </div>

    <!-- Paso 3: Desembolso -->
    <div class="timeline-item mb-0">
        <div class="timeline-badge-container">
            <div class="timeline-badge @(EsActivo("Desembolso") ? "active" : "")"></div>
        </div>
        <div class="timeline-content">
            <h5 class="fw-bold mb-0">3. Desembolso</h5>
            <p class="text-muted small mb-0">Solicitud Desembolsada por el Jefe</p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Estado { get; set; } = "Crear solicitud";
    private bool EsActivo(string paso)
    {
        if (string.IsNullOrEmpty(Estado)) return false;

        return Estado.ToLower() switch
        {
            "crear solicitud" => paso.Equals("Crear solicitud", StringComparison.OrdinalIgnoreCase),
            "evaluada" => paso.Equals("Crear solicitud", StringComparison.OrdinalIgnoreCase) || 
                          paso.Equals("Evaluada", StringComparison.OrdinalIgnoreCase),
            "desembolso" => true, // Prende todos si ya llegó al final
            _ => false
        };
    }
}

<style>
    .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        position: relative;
        padding-bottom: 25px; /* Controla la distancia vertical entre pasos */
    }

    .timeline-badge-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 20px;
    }

    /* Círculo base (Inactivo) */
    .timeline-badge {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background-color: #94a3b8; /* Gris */
        border: 4px solid #cbd5e1; /* Gris claro exterior */
        z-index: 2;
    }

    /* Círculo Activo */
    .timeline-badge.active {
        background-color: #2563eb; /* Azul */
        border: 4px solid #bfdbfe; /* Azul claro exterior */
    }

    /* Línea vertical conectora */
    .timeline-line {
        width: 2px;
        background-color: #cbd5e1;
        flex-grow: 1;
        position: absolute;
        top: 18px;
        bottom: 0;
        z-index: 1;
    }

    .timeline-content h5 {
        font-size: 1rem;
        color: #0f172a;
    }
    
    .timeline-content p {
        color: #64748b !important;
    }
</style>
