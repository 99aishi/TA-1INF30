<div class="card h-100 p-3 overflow-auto">
    @foreach (var paso in Pasos.Select((p, i) => new { p, i }))
    {
        <div class="timeline-item @(paso.i == Pasos.Count - 1 ? "mb-0" : "")">
            <div class="timeline-badge-container">
                <div class="timeline-badge @(paso.p.Activo ? "active" : "")"></div>
                @if (paso.i < Pasos.Count - 1)
                {
                    <div class="timeline-line"></div>
                }
            </div>
            <div class="timeline-content">
                <h5 class="fw-bold mb-0">@(paso.i + 1). @paso.p.Titulo</h5>
                <p class="text-muted small mb-0">@paso.p.Descripcion</p>
                @if (!string.IsNullOrEmpty(paso.p.FechaTexto))
                {
                    <p class="text-muted small mb-0"><i class="bi bi-clock"></i> @paso.p.FechaTexto</p>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    private record Paso(string Titulo, string Descripcion, bool Activo, string? FechaTexto = null);

    private List<Paso> Pasos => GenerarPasos();

    private List<Paso> GenerarPasos()
    {
        var estado = Solicitud?.Estado?.ToUpperInvariant() ?? "PENDIENTE";
        var pasos = new List<Paso>();

        bool evaluacionRechazada = estado is "RECHAZADO" or "OBSERVADO";
        bool aprobado = estado is "APROBADO" or "PAGADO" or "RENDIDO";
        bool pagado = estado is "PAGADO" or "RENDIDO";
        bool rendida = estado is "RENDIDO";
        bool comprobantes = Solicitud?.Comprobantes?.Any() == true || rendida;

        // 1. Crear solicitud
        pasos.Add(new Paso(
            "Crear solicitud",
            "Solicitud registrada por el empleado",
            true,
            Solicitud?.FechaSolicitud.ToString("dd/MM/yyyy")));

        // 2. Evaluación del jefe
        pasos.Add(new Paso(
            "Evaluación del Jefe",
            evaluacionRechazada
                ? $"Solicitud {Solicitud?.Estado} por {Solicitud?.JefeAprobador?.Nombres} {Solicitud?.JefeAprobador?.ApellidoPaterno}"
                : aprobado
                    ? $"Aprobada por {Solicitud?.JefeAprobador?.Nombres} {Solicitud?.JefeAprobador?.ApellidoPaterno}"
                    : "Pendiente de aprobación del jefe",
            aprobado || evaluacionRechazada));

        // 3. Desembolso pendiente
        pasos.Add(new Paso(
            "Desembolso pendiente",
            pagado
                ? "Desembolso ejecutado"
                : aprobado
                    ? "Aprobado, pendiente de ejecutar desembolso"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de aprobación previa",
            aprobado || pagado));

        // 4. Desembolso completado
        pasos.Add(new Paso(
            "Desembolso completado",
            pagado
                ? "Fondos entregados al solicitante"
                : aprobado
                    ? "Pendiente de seleccionar medio de pago y operación"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de desembolso",
            pagado));

        // 5. Comprobantes
        pasos.Add(new Paso(
            "Comprobantes",
            comprobantes
                ? $"{Solicitud?.Comprobantes?.Count ?? 0} comprobante(s) registrado(s)"
                : pagado
                    ? "Pendiente de comprobantes"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de desembolso",
            comprobantes));

        // 6. Rendición
        pasos.Add(new Paso(
            "Rendición",
            rendida
                ? "Solicitud rendida"
                : comprobantes
                    ? "Pendiente de rendición"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de comprobantes",
            rendida));

        return pasos;
    }
}

<style>
    .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        position: relative;
        padding-bottom: 25px;
    }

    .timeline-badge-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 20px;
    }

    .timeline-badge {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background-color: #94a3b8;
        border: 4px solid #cbd5e1;
        z-index: 2;
    }

    .timeline-badge.active {
        background-color: #2563eb;
        border: 4px solid #bfdbfe;
    }

    .timeline-line {
        width: 2px;
        background-color: #cbd5e1;
        flex-grow: 1;
        position: absolute;
        top: 18px;
        bottom: 0;
        z-index: 1;
    }

    .timeline-content h5 {
        font-size: 1rem;
        color: #0f172a;
    }

    .timeline-content p {
        color: #64748b !important;
    }
</style>
