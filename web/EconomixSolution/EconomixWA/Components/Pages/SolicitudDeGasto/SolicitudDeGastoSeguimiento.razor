<div class="card h-100 p-3 overflow-scroll">
    @foreach (var paso in Pasos.Select((p, i) => new { p, i }))
    {
        <div class="timeline-item @(paso.i == Pasos.Count - 1 ? "mb-0" : "")">
            <div class="timeline-badge-container">
                <div class="timeline-badge @(paso.p.Activo ? "active" : "")"></div>
                @if (paso.i < Pasos.Count - 1)
                {
                    <div class="timeline-line"></div>
                }
            </div>
            <div class="timeline-content">
                <h5 class="fw-bold mb-0">@(paso.i + 1). @paso.p.Titulo</h5>
                <p class="text-muted small mb-0">@paso.p.Descripcion</p>
                @if (!string.IsNullOrEmpty(paso.p.FechaTexto))
                {
                    <p class="text-muted small mb-0"><i class="bi bi-clock"></i> @paso.p.FechaTexto</p>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    private record Paso(string Titulo, string Descripcion, bool Activo, string? FechaTexto = null);

    private List<Paso> Pasos => GenerarPasos();

    private List<Paso> GenerarPasos()
    {
        var estado = Solicitud?.Estado?.ToUpperInvariant() ?? "PENDIENTE";
        var pasos = new List<Paso>();

        bool evaluacionRechazada = estado is "RECHAZADO" or "OBSERVADO";
        bool aprobado = estado is "APROBADO" or "PAGADO" or "RENDIDO";
        bool pagado = estado is "PAGADO" or "RENDIDO";
        bool rendida = estado is "RENDIDO";
        bool comprobantes = Solicitud?.Comprobantes?.Any() == true || rendida;
        bool conTransaccion = Solicitud?.IdTransaccion > 0;

        // 1. Crear solicitud
        pasos.Add(new Paso(
            "Solicitud registrada",
            "El empleado registró la solicitud de gasto en el sistema",
            true,
            Solicitud?.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")));

        // 2. Evaluación del jefe
        var jefeNombre = Solicitud?.JefeAprobador != null
            ? $"{Solicitud.JefeAprobador.Nombres} {Solicitud.JefeAprobador.ApellidoPaterno}"
            : "";
        pasos.Add(new Paso(
            "Revisión del jefe",
            evaluacionRechazada
                ? $"Solicitud {Solicitud?.Estado?.ToLower()}: {Solicitud?.ComentarioDecision ?? jefeNombre}"
                : aprobado
                    ? $"Aprobada por {jefeNombre}"
                    : "Esperando revisión del jefe de área",
            aprobado || evaluacionRechazada));

        // 3. Desembolso
        pasos.Add(new Paso(
            "Desembolso",
            conTransaccion
                ? "Transacción creada para el desembolso"
                : aprobado
                    ? "Pendiente de crear transacción de desembolso"
                    : evaluacionRechazada
                        ? "No aplica (solicitud no aprobada)"
                        : "Esperando aprobación previa",
            conTransaccion || pagado));

        // 4. Confirmar transacción
        pasos.Add(new Paso(
            "Confirmar transacción",
            pagado
                ? "Transacción confirmada — fondos entregados"
                : conTransaccion
                    ? "Transacción creada, pendiente de confirmación"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de desembolso",
            pagado));

        // 5. Comprobantes
        pasos.Add(new Paso(
            "Comprobantes de gasto",
            comprobantes
                ? $"{Solicitud?.Comprobantes?.Count ?? 0} comprobante(s) subido(s)"
                : pagado
                    ? "Pendiente de subir comprobantes"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de desembolso",
            comprobantes));

        // 6. Rendición
        pasos.Add(new Paso(
            "Rendición final",
            rendida
                ? "Solicitud rendida exitosamente"
                : comprobantes
                    ? "Comprobantes subidos, pendiente de rendición"
                    : evaluacionRechazada
                        ? "No aplica"
                        : "Pendiente de comprobantes",
            rendida));

        return pasos;
    }
}

<style>
    .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        position: relative;
        padding-bottom: 25px;
    }

    .timeline-badge-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 20px;
    }

    .timeline-badge {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background-color: #94a3b8;
        border: 4px solid #cbd5e1;
        z-index: 2;
    }

    .timeline-badge.active {
        background-color: #2563eb;
        border: 4px solid #bfdbfe;
    }

    .timeline-line {
        width: 2px;
        background-color: #cbd5e1;
        flex-grow: 1;
        position: absolute;
        top: 18px;
        bottom: 0;
        z-index: 1;
    }

    .timeline-content h5 {
        font-size: 1rem;
        color: #0f172a;
    }

    .timeline-content p {
        color: #64748b !important;
    }
</style>
