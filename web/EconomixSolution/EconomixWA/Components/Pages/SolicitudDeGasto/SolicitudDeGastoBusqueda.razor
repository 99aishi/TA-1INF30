<div class="card rounded-4 mt-3 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-6">
            <label class="form-label small text-muted">Buscar</label>
            <input type="text" class="form-control rounded-4 bg-light" placeholder="Buscar Solicitud de gasto">
        </div>
        <div class="col-1">
            <label class="form-label small text-muted">Estado</label>
            <select class="form-select rounded-4 bg-light">
                <option selected>Todas</option>
                <option>Activo</option>
                <option>Inactivo</option>
            </select>
        </div>
        <div class="col-2">
            <label class="form-label small text-muted">Monto</label>
            <input type="text" class="form-control rounded-4 bg-light" placeholder="Monto">
        </div>
        <div class="col-2">
            <label class="form-label small text-muted">Fecha</label>
            <input type="date" class="form-control rounded-4 bg-light">
        </div>
        <div class="col-1 d-grid">
            <label class="form-label small text-muted">&nbsp;</label>
            <button type="button" class="btn btn-secondary rounded-4">Filtrar</button>
        </div>
    </div>
</div>

