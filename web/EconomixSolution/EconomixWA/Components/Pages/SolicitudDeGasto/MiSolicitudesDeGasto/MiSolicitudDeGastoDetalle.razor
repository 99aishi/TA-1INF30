@page "/Mis Solicitudes De Gasto/Detalle/{IdSolicitud:int}"
@page "/Mis Solicitudes De Gasto/Crear"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IUsuarioWS UsuarioWS
@inject IMonedaWS MonedaWS
@inject ICicloCajaWS CicloCajaWS
@inject IEmpleadoWS EmpleadoWS
@inject ITipoCambioWS TipoCambioWS
@inject IRendicionWS RendicionWS
@inject IComprobantePagoWS ComprobantePagoWS
@using EconomixWA.Components.Pages.ComprobanteDePago

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 mb-3">
        <div class="col-8 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100 overflow-scroll">
                <p class="h3">Solicitud de Gasto - No. @(SolicitudEdicion?.IdSolicitudGasto > 0 ? SolicitudEdicion.IdSolicitudGasto : "Nuevo")</p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                        @ErrorMessage
                        <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                    </div>
                }

                <div class="row">
                    <div class="col-6 mt-3">
                        <label class="form-label">Área</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(AreaSolicitante)" disabled="true">
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control form-control-lg rounded-4 bg-light" @bind="SolicitudEdicion.FechaSolicitud" disabled="@(!PuedeEditar)">
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label">Solicitante</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(NombreSolicitante)" disabled="true">
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label">Destinatario</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(NombreDestinatario)" disabled="true">
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label">Monto</label>
                        <input type="number" step="0.01" class="form-control form-control-lg rounded-4 bg-light" @bind="MontoSolicitadoEdicion" disabled="@(!PuedeEditar)">
                    </div>
                    <div class="col-4 mt-3">
                        <label class="form-label">Moneda</label>
                        <select class="form-select form-select-lg rounded-4 bg-light" @bind="MonedaSeleccionadaId" disabled="@(!PuedeEditar)">
                            <option value="0">Seleccione...</option>
                            @foreach (var moneda in Monedas)
                            {
                                <option value="@moneda.IdMoneda">@moneda.Nombre (@moneda.Simbolo)</option>
                            }
                        </select>
                    </div>
                    <div class="col-4 mt-3 align-self-center" style="height: 2rem">
                        <span class="badge h-100 @EstadoClase rounded-pill px-2 align-self-start mt-4">@(SolicitudEdicion?.Estado ?? "PENDIENTE")</span>
                    </div>
                    @if (EsCreacion || SolicitudEdicion.TipoCambio != 1.0 || TipoCambioNoEncontrado)
                    {
                        <div class="col-6 mt-3">
                            <label class="form-label">Tipo de Cambio</label>
                            @if (TipoCambioNoEncontrado)
                            {
                                <input type="text" class="form-control form-control-lg rounded-4 bg-light border-danger text-danger fw-bold" value="No registrado" disabled="true">
                                <small class="text-danger">Por favor, registre el tipo de cambio.</small>
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(SolicitudEdicion.TipoCambio.ToString("N4"))" disabled="true">
                            }
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Monto Convertido (@(SimboloMonedaCiclo))</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(TipoCambioNoEncontrado ? "-" : SolicitudEdicion.MontoConvertido.ToString("N2"))" disabled="true">
                        </div>
                    }
                    <div class="col-6 mt-3">
                        <label class="form-label">Caja Chica</label>
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(SolicitudEdicion.Ciclo?.CajaChica?.Nombre ?? "-")" disabled="true">
                    </div>
                    <div class="col-6 mt-3">
                        <label class="form-label">Ciclo de Caja Chica</label>
                        <select class="form-select form-select-lg rounded-4 bg-light" @bind="CicloSeleccionadoId" disabled="@(!PuedeEditar)">
                            <option value="0">Seleccione...</option>
                            @foreach (var ciclo in CiclosActivos)
                            {
                                <option value="@ciclo.IdCicloCaja">@(ciclo.CajaChica?.Nombre) - Semana @ciclo.NumeroSemana (@ciclo.FechaApertura?.ToString("dd/MM/yyyy"))</option>
                            }
                        </select>
                        <small class="text-muted">Saldo disponible: @(SimboloMonedaCiclo) @(SaldoDisponibleCiclo.ToString("N2"))</small>
                    </div>
                    <div class="col-12 mt-3">
                        <label class="form-label">Motivo</label>
                        <textarea class="form-control bg-light" rows="3" @bind="SolicitudEdicion.MotivoSolicitud" disabled="@(!PuedeEditar)"></textarea>
                    </div>

                    @if (!EsCreacion)
                    {
                        <div class="col-12 mt-3">
                            <label class="form-label">Decisión / Comentario</label>
                            <textarea class="form-control bg-light" rows="2" @bind="SolicitudEdicion.ComentarioDecision" disabled="true"></textarea>
                        </div>
                    }
                 </div>

                 @if (EsObservada)
                 {
                     <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-3">
                         <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="GuardarCambiosSolicitud">
                             @(Procesando ? "Procesando..." : "Guardar Cambios")
                         </button>
                     </div>
                 }

                 <div class="d-flex flex-wrap-nowrap justify-content-end gap-3 mt-3">
                     @if (EsCreacion)
                     {
                         <button type="button" class="btn btn-outline-primary" disabled="@Procesando" @onclick="RegistrarSolicitud">
                             @(Procesando ? "Procesando..." : "Registrar Solicitud")
                         </button>
                         <button type="button" class="btn btn-outline-danger" @onclick="CerrarDetalle">
                             Cancelar
                         </button>
                     }
                     else
                     {
                         <button type="button" class="btn btn-outline-primary" @onclick="CerrarDetalle">
                             Cerrar
                         </button>
                         @if (PuedeEliminar)
                         {
                             <button type="button" class="btn btn-outline-danger" @onclick="EliminarSolicitud">
                                 Eliminar
                             </button>
                         }
                     }
                </div>

                @if (!EsCreacion)
                {
                    @if (EsRendicionObservada)
                    {
                        <div class="alert alert-info d-flex justify-content-between align-items-center mt-4" role="alert">
                            <span>
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>Rendición observada:</strong> puede editar o eliminar los comprobantes de esta solicitud. Cuando termine, reenvíe la rendición.
                            </span>
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="ReenviarRendicion" disabled="@ProcesandoRendicion">
                                @(ProcesandoRendicion ? "Procesando..." : "Reenviar rendición")
                            </button>
                        </div>
                    }
                    @if (EsObservada)
                     {
                         <div class="alert alert-info d-flex justify-content-between align-items-center mt-4" role="alert">
                             <span>
                                 <i class="bi bi-info-circle me-2"></i>
                                 <strong>Observado por el Jefe:</strong> puedes editar esta solicitud. Cuando termines, regresa a PENDIENTE y el Jefe podrá reevaluarla.
                             </span>
                         </div>
                     }

                    @if (ComprobanteEnEdicion != null)
                    {
                        <div class="card rounded-4 p-3 mt-3">
                            <p class="h5 mb-3">Editar Comprobante CP-@ComprobanteEnEdicion.IdComprobante</p>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label">Tipo de documento</label>
                                    <select class="form-select" @bind="ComprobanteEnEdicion.TipoDocumento">
                                        <option value="FACTURA">Factura</option>
                                        <option value="BOLETA">Boleta</option>
                                        <option value="DJ_EXCEPCIONAL">DJ Excepcional</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Moneda</label>
                                    <select class="form-select" @bind="MonedaEdicionId">
                                        <option value="0">Seleccione...</option>
                                        @foreach (var moneda in Monedas)
                                        {
                                            <option value="@moneda.IdMoneda">@moneda.Nombre (@moneda.Simbolo)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">RUC proveedor</label>
                                    <input type="text" class="form-control" @bind="ComprobanteEnEdicion.RucProveedor" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Razón social</label>
                                    <input type="text" class="form-control" @bind="ComprobanteEnEdicion.RazonSocial" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Número de serie</label>
                                    <input type="text" class="form-control" @bind="ComprobanteEnEdicion.NumeroSerial" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Fecha de emisión</label>
                                    <input type="date" class="form-control" @bind="ComprobanteEnEdicion.FechaEmision" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Monto total</label>
                                    <input type="number" step="0.01" class="form-control" @bind="ComprobanteEnEdicion.MontoTotal" />
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-3">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CancelarEdicionComprobante">Cancelar</button>
                                <button type="button" class="btn btn-outline-primary" @onclick="GuardarComprobante" disabled="@ProcesandoComprobante">Guardar</button>
                            </div>
                        </div>
                    }

                    <div class="d-flex flex-fill flex-column mt-4 gap-3 overflow-scroll">
                        <div>
                            @if (SolicitudEdicion?.Comprobantes?.Any() == true)
                            {
                                @foreach (var comprobante in SolicitudEdicion.Comprobantes)
                                {
                                    <div class="d-flex gap-2 align-items-start mb-2">
                                        <ComprobanteDePagoItem EsParteDeSolicitud="true" Comprobante="comprobante" />
                                        @if (EsRendicionObservada)
                                        {
                                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => EditarComprobante(comprobante)">Editar</button>
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => EliminarComprobante(comprobante)">Eliminar</button>
                                        }
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="ReenviarRendicion" disabled="@ProcesandoRendicion">
                            @(ProcesandoRendicion ? "Procesando..." : "Reenviar rendición")
                        </button>
                    }
                 </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted text-center">No hay comprobantes registrados</p>
                            }
                        </div>
                    </div>
                    @if (PuedeAgregarComprobante)
                    {
                        <div class="mt-3 d-flex justify-content-end">
                            <button class="btn btn-outline-primary" disabled="@Procesando" @onclick="IrAgregarComprobante">@(Procesando ? "Procesando..." : "Agregar Comprobante")</button>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="col-4 h-100 mb-3">
            <SolicitudDeGastoSeguimiento Solicitud="SolicitudEdicion" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? IdSolicitud { get; set; }

    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    [Parameter]
    public EventCallback OnCierraDetalle { get; set; }

    private bool EsCreacion => !IdSolicitud.HasValue && Solicitud == null;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private bool TipoCambioNoEncontrado = false;

    private SolicitudGasto SolicitudEdicion { get; set; } = new();
    private List<Moneda> Monedas { get; set; } = new();
    private List<CicloCajaChica> CiclosActivos { get; set; } = new();
    private Empleado? EmpleadoActual { get; set; }

    private ComprobantePago? ComprobanteEnEdicion { get; set; }
    private bool Procesando { get; set; }
    private bool ProcesandoRendicion { get; set; }
    private bool ProcesandoComprobante { get; set; }

    private bool EsObservada => SolicitudEdicion?.Estado?.Equals("OBSERVADO", StringComparison.OrdinalIgnoreCase) == true;
    private bool PuedeEditar => EsCreacion || EsObservada;
    private bool EsRendicionObservada => SolicitudEdicion?.Ciclo?.Rendicion?.Estado?.Equals("OBSERVADO", StringComparison.OrdinalIgnoreCase) == true;

    private bool PuedeAgregarComprobante => SolicitudEdicion?.Estado?.Equals("APROBADO", StringComparison.OrdinalIgnoreCase) == true
        || SolicitudEdicion?.Estado?.Equals("PAGADO", StringComparison.OrdinalIgnoreCase) == true
        || EsRendicionObservada;

    private int MonedaEdicionId
    {
        get => ComprobanteEnEdicion?.Moneda?.IdMoneda ?? 0;
        set
        {
            if (ComprobanteEnEdicion != null)
                ComprobanteEnEdicion.Moneda = value == 0 ? null : Monedas.FirstOrDefault(m => m.IdMoneda == value);
        }
    }

    private int MonedaSeleccionadaId
    {
        get => SolicitudEdicion.MonedaOriginal?.IdMoneda ?? 0;
        set
        {
            SolicitudEdicion.MonedaOriginal = value == 0 ? null : Monedas.FirstOrDefault(m => m.IdMoneda == value);
            _ = RecalcularTipoCambio();
        }
    }

    private int CicloSeleccionadoId
    {
        get => SolicitudEdicion.Ciclo?.IdCicloCaja ?? 0;
        set
        {
            SolicitudEdicion.Ciclo = value == 0 ? null : CiclosActivos.FirstOrDefault(c => c.IdCicloCaja == value);
            _ = RecalcularTipoCambio();
        }
    }

    private double MontoSolicitadoEdicion
    {
        get => SolicitudEdicion.MontoSolicitado;
        set
        {
            SolicitudEdicion.MontoSolicitado = value;
            _ = RecalcularTipoCambio();
        }
    }

    private string NombreSolicitante => EmpleadoActual != null
        ? $"{EmpleadoActual.Nombres} {EmpleadoActual.ApellidoPaterno}"
        : SolicitudEdicion.Solicitante != null
            ? $"{SolicitudEdicion.Solicitante.Nombres} {SolicitudEdicion.Solicitante.ApellidoPaterno}"
            : string.Empty;

    private string NombreDestinatario => SolicitudEdicion.Destinatario != null
        ? $"{SolicitudEdicion.Destinatario.Nombres} {SolicitudEdicion.Destinatario.ApellidoPaterno}"
        : (EmpleadoActual?.JefeDirecto != null
            ? $"{EmpleadoActual.JefeDirecto.Nombres} {EmpleadoActual.JefeDirecto.ApellidoPaterno}"
            : string.Empty);

    private string AreaSolicitante => EmpleadoActual?.Area?.Nombre
        ?? SolicitudEdicion.Solicitante?.Area?.Nombre
        ?? "-";

    private string SimboloMonedaCiclo => CicloSeleccionadoId > 0
        ? (CiclosActivos.FirstOrDefault(c => c.IdCicloCaja == CicloSeleccionadoId)?.CajaChica?.Moneda?.Simbolo ?? "S/")
        : "S/";

    private double SaldoDisponibleCiclo => CicloSeleccionadoId > 0
        ? (CiclosActivos.FirstOrDefault(c => c.IdCicloCaja == CicloSeleccionadoId)?.SaldoInicial ?? 0)
          - (CiclosActivos.FirstOrDefault(c => c.IdCicloCaja == CicloSeleccionadoId)?.TotalGastado ?? 0)
        : 0;

    private bool PuedeEliminar => SolicitudEdicion?.Estado?.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase) == true;

    private string EstadoClase => SolicitudEdicion?.Estado?.ToUpperInvariant() switch
    {
        "PENDIENTE" => "bg-warning-subtle text-warning-emphasis",
        "APROBADO" => "bg-success-subtle text-success",
        "PAGADO" => "bg-primary-subtle text-primary",
        "RENDIDO" => "bg-info-subtle text-info",
        "RECHAZADO" => "bg-danger-subtle text-danger",
        "OBSERVADO" => "bg-info-subtle text-info",
        _ => "bg-secondary-subtle text-secondary"
    };

    private async Task RecalcularTipoCambio()
    {
        var monedaSolicitud = SolicitudEdicion.MonedaOriginal;
        var ciclo = SolicitudEdicion.Ciclo;
        var monedaCiclo = ciclo?.CajaChica?.Moneda;
        TipoCambioNoEncontrado = false;

        if (monedaSolicitud == null || monedaCiclo == null)
        {
            SolicitudEdicion.TipoCambio = 1.0;
            SolicitudEdicion.MontoConvertido = SolicitudEdicion.MontoSolicitado;
            return;
        }

        if (monedaSolicitud.IdMoneda == monedaCiclo.IdMoneda)
        {
            SolicitudEdicion.TipoCambio = 1.0;
            SolicitudEdicion.MontoConvertido = SolicitudEdicion.MontoSolicitado;
            return;
        }

        var tipoCambio = await TipoCambioWS.buscarPorMonedasYFechaAsync(
            monedaSolicitud.IdMoneda, monedaCiclo.IdMoneda, SolicitudEdicion.FechaSolicitud);

        if (tipoCambio != null)
        {
            SolicitudEdicion.TipoCambio = tipoCambio.Valor;
            SolicitudEdicion.MontoConvertido = SolicitudEdicion.MontoSolicitado * tipoCambio.Valor;
        }
        else
        {
            SolicitudEdicion.TipoCambio = 0.0;
            SolicitudEdicion.MontoConvertido = 0.0;
            TipoCambioNoEncontrado = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        await CargarCatalogos();
        await CargarEmpleadoActual();

        if (Solicitud != null)
        {
            SolicitudEdicion = CopiarSolicitud(Solicitud);
            await CargarCicloCompleto();
            await CargarComprobantes();
        }
        else if (IdSolicitud.HasValue)
        {
            await CargarSolicitud(IdSolicitud.Value);
        }
        else
        {
            await InicializarNuevaSolicitud();
        }

        if (EsCreacion && string.IsNullOrEmpty(ErrorMessage))
        {
            if (EmpleadoActual == null)
                ErrorMessage = "No se pudo cargar la información del empleado. Verifique que el servidor backend esté activo.";
            else if (Monedas.Count == 0)
                ErrorMessage = "No se encontraron monedas activas. Verifique que el servidor backend esté activo.";
            else if (CiclosActivos.Count == 0)
                ErrorMessage = "No se encontraron ciclos de caja abiertos. Verifique que el servidor backend esté activo.";
        }

        Cargando = false;
    }

    private async Task CargarCatalogos()
    {
        try { Monedas = await MonedaWS.listarActivasAsync(); }
        catch (Exception ex) { ErrorMessage = $"Error al cargar monedas: {ex.Message}"; }

        try
        {
            CiclosActivos = (await CicloCajaWS.listarAsync())
                .Where(c => c.Estado?.Equals("ABIERTO", StringComparison.OrdinalIgnoreCase) == true)
                .ToList();
        }
        catch (Exception ex)
        {
            if (string.IsNullOrEmpty(ErrorMessage))
                ErrorMessage = $"Error al cargar ciclos de caja: {ex.Message}";
        }
    }

    private async Task CargarEmpleadoActual()
    {
        try
        {
            var id = UsuarioWS.GetCurrentUserId();
            EmpleadoActual = await EmpleadoWS.obtenerPorIdAsync(id);
            if (EmpleadoActual == null && string.IsNullOrEmpty(ErrorMessage))
                ErrorMessage = "No se pudo cargar la información del empleado actual.";
        }
        catch (Exception ex)
        {
            EmpleadoActual = null;
            if (string.IsNullOrEmpty(ErrorMessage))
                ErrorMessage = $"Error al cargar datos del empleado: {ex.Message}";
        }
    }

    private async Task CargarSolicitud(int id)
    {
        try
        {
            var solicitud = await SolicitudGastoWS.obtenerPorIdAsync(id);
            if (solicitud != null)
            {
                SolicitudEdicion = CopiarSolicitud(solicitud);
                await CargarCicloCompleto();
                await CargarComprobantes();
            }
            else
                ErrorMessage = "No se encontró la solicitud.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task CargarCicloCompleto()
    {
        if (SolicitudEdicion?.Ciclo?.IdCicloCaja > 0)
        {
            try
            {
                var cicloCompleto = await CicloCajaWS.obtenerPorIdAsync(SolicitudEdicion.Ciclo!.IdCicloCaja);
                if (cicloCompleto != null)
                    SolicitudEdicion.Ciclo = cicloCompleto;
            }
            catch
            {
                // Se mantiene el ciclo original
            }
        }
    }

    private async Task CargarComprobantes()
    {
        if (SolicitudEdicion?.IdSolicitudGasto > 0)
        {
            try
            {
                SolicitudEdicion.Comprobantes = await ComprobantePagoWS.listarPorSolicitudAsync(SolicitudEdicion.IdSolicitudGasto);
            }
            catch
            {
                SolicitudEdicion.Comprobantes = new List<ComprobantePago>();
            }
        }
    }

    private async Task ReenviarRendicion()
    {
        if (SolicitudEdicion?.Ciclo?.Rendicion?.IdRendicion <= 0 || ProcesandoRendicion) return;

        ErrorMessage = string.Empty;
        ProcesandoRendicion = true;
        try
        {
            var idUsuario = UsuarioWS.GetCurrentUserId();
            await RendicionWS.reEnviarRendicionAsync(SolicitudEdicion.Ciclo!.Rendicion!.IdRendicion, idUsuario);
            await CargarCicloCompleto();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            ProcesandoRendicion = false;
        }
    }

    private void EditarComprobante(ComprobantePago comprobante)
    {
        ComprobanteEnEdicion = new ComprobantePago
        {
            IdComprobante = comprobante.IdComprobante,
            TipoDocumento = comprobante.TipoDocumento,
            RucProveedor = comprobante.RucProveedor,
            RazonSocial = comprobante.RazonSocial,
            NumeroSerial = comprobante.NumeroSerial,
            FechaEmision = comprobante.FechaEmision,
            MontoTotal = comprobante.MontoTotal,
            Moneda = comprobante.Moneda,
            Estado = comprobante.Estado,
            Solicitud = comprobante.Solicitud
        };
    }

    private async Task GuardarCambiosSolicitud()
    {
        if (SolicitudEdicion == null || Procesando) return;

        ErrorMessage = string.Empty;
        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await SolicitudGastoWS.actualizarAsync(SolicitudEdicion, idUsuarioAccion);
            await CargarSolicitud(SolicitudEdicion.IdSolicitudGasto);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private void CancelarEdicionComprobante()
    {
        ComprobanteEnEdicion = null;
    }

    private async Task GuardarComprobante()
    {
        if (ComprobanteEnEdicion == null || ProcesandoComprobante) return;

        ErrorMessage = string.Empty;
        ProcesandoComprobante = true;
        try
        {
            var idUsuario = UsuarioWS.GetCurrentUserId();
            await ComprobantePagoWS.actualizarAsync(ComprobanteEnEdicion, idUsuario);
            ComprobanteEnEdicion = null;
            await CargarComprobantes();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            ProcesandoComprobante = false;
        }
    }

    private async Task EliminarComprobante(ComprobantePago comprobante)
    {
        if (comprobante == null || comprobante.IdComprobante <= 0) return;

        ErrorMessage = string.Empty;
        try
        {
            var idUsuario = UsuarioWS.GetCurrentUserId();
            await ComprobantePagoWS.eliminarAsync(comprobante.IdComprobante, idUsuario);
            await CargarComprobantes();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task InicializarNuevaSolicitud()
    {
        SolicitudEdicion = new SolicitudGasto
        {
            FechaSolicitud = DateTime.Today,
            Estado = "PENDIENTE",
            Solicitante = EmpleadoActual,
            Destinatario = EmpleadoActual?.JefeDirecto,
            MonedaOriginal = Monedas.FirstOrDefault(),
            Ciclo = CiclosActivos.FirstOrDefault()
        };
        await RecalcularTipoCambio();
    }

    private SolicitudGasto CopiarSolicitud(SolicitudGasto origen)
    {
        return new SolicitudGasto
        {
            IdSolicitudGasto = origen.IdSolicitudGasto,
            FechaSolicitud = origen.FechaSolicitud,
            MontoSolicitado = origen.MontoSolicitado,
            MonedaOriginal = origen.MonedaOriginal,
            TipoCambio = origen.TipoCambio,
            MontoConvertido = origen.MontoConvertido,
            MotivoSolicitud = origen.MotivoSolicitud,
            ComentarioDecision = origen.ComentarioDecision,
            Estado = origen.Estado,
            IdTransaccion = origen.IdTransaccion,
            Solicitante = origen.Solicitante,
            Destinatario = origen.Destinatario,
            JefeAprobador = origen.JefeAprobador,
            TesoreroAprobador = origen.TesoreroAprobador,
            Ciclo = origen.Ciclo,
            Comprobantes = origen.Comprobantes
        };
    }

    private bool Validar(out string error)
    {
        error = string.Empty;
        if (SolicitudEdicion.FechaSolicitud == default)
            error = "La fecha es obligatoria.";
        else if (SolicitudEdicion.MontoSolicitado <= 0)
            error = "El monto debe ser mayor que cero.";
        else if (MonedaSeleccionadaId <= 0)
            error = "Debe seleccionar una moneda.";
        else if (CicloSeleccionadoId <= 0)
            error = "Debe seleccionar un ciclo de caja chica.";
        else if (string.IsNullOrWhiteSpace(SolicitudEdicion.MotivoSolicitud))
            error = "El motivo es obligatorio.";
        else if (SolicitudEdicion.MontoSolicitado > SaldoDisponibleCiclo)
            error = "El monto solicitado excede el saldo disponible del ciclo.";
        else if (TipoCambioNoEncontrado)
            error = "No existe tipo de cambio registrado entre la moneda solicitada y la de la caja chica para la fecha indicada.";

        return string.IsNullOrEmpty(error);
    }

    private async Task RegistrarSolicitud()
    {
        if (Procesando) return;
        if (!Validar(out var error))
        {
            ErrorMessage = error;
            return;
        }

        ErrorMessage = string.Empty;
        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await SolicitudGastoWS.insertarAsync(SolicitudEdicion, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EliminarSolicitud()
    {
        if (SolicitudEdicion?.IdSolicitudGasto <= 0) return;

        ErrorMessage = string.Empty;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await SolicitudGastoWS.eliminarAsync(SolicitudEdicion!.IdSolicitudGasto, idUsuarioAccion);
            await CerrarDetalle();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void IrAgregarComprobante()
    {
        if (Procesando) return;
        if (SolicitudEdicion?.IdSolicitudGasto > 0)
            Navigation.NavigateTo($"/Comprobantes de Pago/Asociar/{SolicitudEdicion.IdSolicitudGasto}");
    }

    public async Task CerrarDetalle()
    {
        if (OnCierraDetalle.HasDelegate)
        {
            await OnCierraDetalle.InvokeAsync();
        }
        else
        {
            Navigation.NavigateTo("/Mis Solicitudes De Gasto");
        }
    }
}
