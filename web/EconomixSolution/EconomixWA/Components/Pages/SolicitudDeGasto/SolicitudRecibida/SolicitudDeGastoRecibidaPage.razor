@page "/Solicitudes De Gasto"
@attribute [Authorize(Roles = "Administrador, Jefe, Tesoreria")]
@using Microsoft.AspNetCore.WebUtilities
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IUsuarioWS UsuarioWS
@inject IAreaWS AreaWS
@inject IEmpleadoWS EmpleadoWS
@inject IComprobantePagoWS ComprobantePagoWS

<div class="h-100 d-flex flex-column">
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">Solicitudes Recibidas</p>
            <p class="text-muted mb-0">Solicitudes de gasto recibidas para aprobación y seguimiento</p>
        </div>
        <LiveClock />
        <div class="flex-grow-1 text-end"></div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
        </div>
    }

    <SolicitudGastoSearchBar @bind-FiltroTexto="FiltroTexto"
                             @bind-FiltroMontoMin="FiltroMontoMin"
                             @bind-FiltroMontoMax="FiltroMontoMax"
                             @bind-FiltroEstado="FiltroEstado"
                             @bind-FiltroFechaInicio="FiltroFechaInicio"
                             @bind-FiltroFechaFin="FiltroFechaFin"
                             @bind-FiltroAreaId="FiltroAreaId"
                             Areas="Areas"
                             Empleados="Empleados"
                             @bind-EmpleadosSeleccionados="EmpleadosSeleccionados" />

    <div class="d-flex flex-column flex-fill overflow-hidden">
        <div class="row flex-fill mt-3 mb-3 overflow-hidden d-flex">

            @if(MostrarDetalle)
            {
                <div class="col-6 h-100 d-flex flex-column overflow-hidden">    
                    <div class="card rounded-4 p-3 h-100 overflow-scroll">
                        @if (Cargando) { <p class="text-muted text-center mt-5">Cargando solicitudes...</p> }
                        else if (SolicitudesFiltradas.Count() == 0) { <p class="text-muted text-center mt-5">@(HayFiltrosActivos ? "Ninguna solicitud coincide con los filtros" : "No hay solicitudes pendientes")</p> }
                        else { @foreach (var s in SolicitudesFiltradas) { <SolicitudDeGastoRecibidaItem Solicitud="s" Comprobantes="ObtenerComprobantes(s.IdSolicitudGasto)" OnMuestraDetalle="() => MostrarDetalleSolicitud(s)"/> } }
                    </div>
                </div>
            
                <div class="col-6 h-100">
                    <SolicitudDeGastoRecibidaDetalle Solicitud="SolicitudSeleccionada" OnCierraDetalle="CerrarDetalleSolicitud"/>
                </div>
            }
            else
            {
                <div class="col-12 h-100 d-flex flex-column overflow-hidden">
                    <div class="card rounded-4 p-3 h-100 overflow-scroll">
                        @if (Cargando) { <p class="text-muted text-center mt-5">Cargando solicitudes...</p> }
                        else if (SolicitudesFiltradas.Count() == 0) { <p class="text-muted text-center mt-5">@(HayFiltrosActivos ? "Ninguna solicitud coincide con los filtros" : "No hay solicitudes pendientes")</p> }
                        else { @foreach (var s in SolicitudesFiltradas) { <SolicitudDeGastoRecibidaItem Solicitud="s" Comprobantes="ObtenerComprobantes(s.IdSolicitudGasto)" OnMuestraDetalle="() => MostrarDetalleSolicitud(s)"/> } }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool MostrarDetalle { get; set; } = false;
    private bool Cargando { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;
    private string FiltroTexto { get; set; } = string.Empty;
    private double? FiltroMontoMin { get; set; }
    private double? FiltroMontoMax { get; set; }
    private string FiltroEstado { get; set; } = "Todas";
    private int FiltroAreaId { get; set; }
    private List<Empleado> EmpleadosSeleccionados { get; set; } = new();
    private DateTime? FiltroFechaInicio { get; set; }
    private DateTime? FiltroFechaFin { get; set; }
    private List<SolicitudGasto> Solicitudes { get; set; } = new();
    private List<Area> Areas { get; set; } = new();
    private List<Empleado> Empleados { get; set; } = new();
    private SolicitudGasto? SolicitudSeleccionada { get; set; }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(FiltroTexto)
        || FiltroMontoMin.HasValue
        || FiltroMontoMax.HasValue
        || FiltroEstado != "Todas"
        || FiltroFechaInicio.HasValue
        || FiltroFechaFin.HasValue
        || FiltroAreaId > 0
        || EmpleadosSeleccionados.Any();

    private IEnumerable<SolicitudGasto> SolicitudesFiltradas => Solicitudes
        .Where(s => string.IsNullOrWhiteSpace(FiltroTexto)
            || (s.Solicitante?.Nombres.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Solicitante?.ApellidoPaterno.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.MotivoSolicitud?.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(s => !FiltroMontoMin.HasValue || s.MontoSolicitado >= FiltroMontoMin.Value)
        .Where(s => !FiltroMontoMax.HasValue || s.MontoSolicitado <= FiltroMontoMax.Value)
        .Where(s => FiltroEstado == "Todas" || s.Estado.Equals(FiltroEstado, StringComparison.OrdinalIgnoreCase))
        .Where(s => !FiltroFechaInicio.HasValue || s.FechaSolicitud.Date >= FiltroFechaInicio.Value.Date)
        .Where(s => !FiltroFechaFin.HasValue || s.FechaSolicitud.Date <= FiltroFechaFin.Value.Date)
        .Where(s => FiltroAreaId <= 0 || s.Solicitante?.Area?.AreaID == FiltroAreaId)
        .Where(s => !EmpleadosSeleccionados.Any() || EmpleadosSeleccionados.Any(e => e.UsuarioID == s.Solicitante?.UsuarioID));

    public void MostrarDetalleSolicitud(SolicitudGasto solicitud)
    {
        SolicitudSeleccionada = solicitud;
        MostrarDetalle = true;
    }
    public async Task CerrarDetalleSolicitud()
    {
        await ListarSolicitudes();
        MostrarDetalle = false;
        SolicitudSeleccionada = null;
    }

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        try { Areas = await AreaWS.listarAsync(); } catch {}
        try { Empleados = await EmpleadoWS.listarAsync(); } catch {}
        await ListarSolicitudes();
        Cargando = false;
    }

    private List<ComprobantePago> Comprobantes { get; set; } = new();

    private List<ComprobantePago> ObtenerComprobantes(int idSolicitud)
    {
        return Comprobantes.Where(c => c.Solicitud?.IdSolicitudGasto == idSolicitud).ToList();
    }

    private async Task ListarSolicitudes()
    {
        ErrorMessage = string.Empty;
        try
        {
            var usuario = UsuarioWS.GetCurrentUser();
            if (usuario is Administrador)
            {
                Solicitudes = await SolicitudGastoWS.listarAsync();
            }
            else
            {
                var idJefe = usuario.UsuarioID;
                Solicitudes = await SolicitudGastoWS.listarPendientesJefeAsync(idJefe);
            }
            var list = await ComprobantePagoWS.listarAsync();
            Comprobantes = list != null ? new List<ComprobantePago>(list) : new List<ComprobantePago>();
        }
        catch (Exception ex) { ErrorMessage = ex.Message; }
    }
}
