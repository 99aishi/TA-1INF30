<div class="card rounded-4 p-3 mb-3 bg-light h-100">
    <div class="d-flex flex-row justify-content-between">
        <div class="d-flex flex-column">
            <div class="d-flex justify-content-start align-items-start gap-3">
                <p class="h5">SG-@Solicitud?.IdSolicitudGasto</p>
                <span class="badge rounded-pill @(Solicitud?.Estado == "PENDIENTE" ? "bg-warning-subtle text-warning-emphasis" : Solicitud?.Estado == "APROBADO" ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">@Solicitud?.Estado</span>
            </div>
            <div class="d-flex flex-column justify-content-start">
                <p class="text-muted m-0">@Solicitud?.Solicitante?.Nombres @Solicitud?.Solicitante?.ApellidoPaterno</p>
                <p class="text-muted m-0">@Solicitud?.FechaSolicitud.ToString("dd/MM/yyyy")</p>
            </div>
        </div>
        <div class="d-flex flex-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <p class="h4">@(Solicitud?.MonedaOriginal?.Simbolo ?? "S/") @Solicitud?.MontoSolicitado.ToString("N2")</p>
            </div>
            <button class="btn btn-primary" @onclick="AbrirDetalle">Ver</button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnMuestraDetalle { get; set; }

    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    public async Task AbrirDetalle()
    {
        await OnMuestraDetalle.InvokeAsync();
    }
}
