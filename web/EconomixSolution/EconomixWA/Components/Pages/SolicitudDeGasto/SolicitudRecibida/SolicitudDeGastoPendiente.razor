<div class="card rounded-4 m-3 bg-light">
    <div class="row align-items-center p-3">
        <div class="col-4 d-flex flex-column">
            <div class="d-flex align-items-center gap-2 mb-1">
                <h4 class="h5 mb-0 text-truncate" style="max-width: 100%;">
                    @Nombre
                </h4>
                @if(!string.IsNullOrEmpty(Prioridad))
                {
                    <span class="badge bg-warning-subtle text-warning-emphasis rounded-pill px-2">
                        @Prioridad
                    </span>
                }
            </div>
            <p class="small text-muted mb-1 text-truncate">@Concepto</p>
            <p class="small text-secondary mb-0" style="font-size: 0.75rem;">
                @Fecha.ToString("dd/MM/yyyy")
            </p>
        </div>
        
        <div class="col-3 text-center">
            <p class="h5 mb-0 text-nowrap">
                @IsoMoneda @Monto.ToString("N2")
            </p>
        </div>
        
        <div class="col-5 d-flex justify-content-end gap-1 flex-wrap">
            <button type="button" class="btn btn-outline-success btn-sm px-2 py-1 rounded-3" @onclick="OnAceptarClick">Aceptar</button>
            <button type="button" class="btn btn-outline-warning btn-sm px-2 py-1 rounded-3" @onclick="OnObservarClick">Observar</button>
            <button type="button" class="btn btn-outline-danger btn-sm px-2 py-1 rounded-3" @onclick="OnRechazarClick">Rechazar</button>
        </div>
        
    </div>
</div>

@code {
    [Parameter] public string Nombre { get; set; } = "";
    [Parameter] public string Concepto { get; set; } = "Compra de Libros";
    [Parameter] public DateTime Fecha { get; set; } = DateTime.Now;
    [Parameter] public string Prioridad { get; set; } = "Urgente";
    [Parameter] public string IsoMoneda { get; set; } = "S/.";
    [Parameter] public double Monto { get; set; } = 500.00;

    [Parameter] public EventCallback OnAceptar { get; set; }
    [Parameter] public EventCallback OnObservar { get; set; }
    [Parameter] public EventCallback OnRechazar { get; set; }

    private async Task OnAceptarClick() => await OnAceptar.InvokeAsync();
    private async Task OnObservarClick() => await OnObservar.InvokeAsync();
    private async Task OnRechazarClick() => await OnRechazar.InvokeAsync();
}