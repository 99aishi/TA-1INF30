@inject NavigationManager Navigation
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IUsuarioWS UsuarioWS

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 mb-3">
        <div class="col-8 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100">
                <p class="h3">Solicitud de Gasto  - No. 6767</p>
                <div class="row">
                    <div class="col-6 mt-3">
                        <label for="Area" class="form-label">Area</label>    
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" id="Area" placeholder="Area">
                    </div>
                    <div class="col-6 mt-3">
                        <label for="Fecha" class="form-label">Fecha</label>    
                        <input type="date" class="form-control form-control-lg rounded-4 bg-light" id="Fecha" placeholder="Fecha">
                    </div>
                    <div class="col-6 mt-3">
                        <label for="Solicitante" class="form-label">Solicitante</label>    
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" id="Solicitante" placeholder="Juan Preciado">
                    </div>
                    <div class="col-3 mt-3">
                        <label for="Monto" class="form-label">Monto</label>    
                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" id="Monto" placeholder=" @SimboloMoneda 0.00">
                    </div>
                    <div class="col-3 mt-3 align-self-center" style="height: 2rem">
                        <span class="badge h-100 bg-warning-subtle text-warning-emphasis rounded-pill px-2 align-self-start mt-4">Pendiente</span>
                    </div>
                    <div class="col-12 mt-3">
                        <label for="Motivo" class="form-label">Motivo</label>    
                        <textarea class="form-control bg-light" id="exampleFormControlTextarea1" rows="3" placeholder="Motivo de la solicitud de gasto">  </textarea>
                    </div>
                    <div class="col-12 mt-3">
                        <label for="Desición" class="form-label">Decisión</label>    
                        <textarea class="form-control bg-light" id="exampleFormControlTextarea1" rows="3" placeholder="Decisión de la solicitud de gasto">  </textarea>
                    </div>

                </div>
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                        @ErrorMessage
                        <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                    </div>
                }

                <div class="col-12 mt-3">
                    <label for="NumeroOperacion" class="form-label">Número de operación bancaria</label>
                    <input type="text" class="form-control bg-light rounded-4" id="NumeroOperacion" placeholder="OP-12345678" @bind="NumeroOperacionBancaria">
                </div>

                <div class="d-flex justify-content-end gap-3 mt-3">
                    <button type="button" class="btn btn-success align-self-start mt-3"
                            @onclick="Aprobar">
                        Confirmar
                    </button>

                    <button type="button" class="btn btn-outline-warning align-self-start mt-3"
                            @onclick="Observar">
                        Observar
                    </button>

                    <button type="button" class="btn btn-outline-danger align-self-start mt-3"
                            @onclick="Rechazar">
                        Rechazar
                    </button>
                </div>

            </div>
        </div>
        <div class="col-4 h-100 mb-3">
            <SolicitudDeGastoSeguimiento/>
        </div>
    </div>

</div>


@code {
    private string SimboloMoneda { get; set; } = "S/.";
    private string ErrorMessage { get; set; } = string.Empty;
    private string NumeroOperacionBancaria { get; set; } = string.Empty;

    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    [Parameter]
    public EventCallback OnCierraDetalle { get; set; }

    public async Task CerrarDetalle()
    {
        Navigation.NavigateTo("/Solicitudes De Gasto");
        await OnCierraDetalle.InvokeAsync();
    }

    private async Task Aprobar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, true, string.Empty, idUsuarioAccion, NumeroOperacionBancaria, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task Observar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, false, "Observado", idUsuarioAccion, string.Empty, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task Rechazar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null) return;

        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, false, "Rechazado", idUsuarioAccion, string.Empty, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void MostrarItemsSolicitud()
    {
        Navigation.NavigateTo("/Solicitudes De Gasto");
    }
}
