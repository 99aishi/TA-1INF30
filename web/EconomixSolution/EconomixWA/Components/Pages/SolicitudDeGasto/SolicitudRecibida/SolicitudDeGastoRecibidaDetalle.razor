@inject NavigationManager Navigation
@inject ISolicitudGastoWS SolicitudGastoWS
@inject ITransaccionWS TransaccionWS
@inject IUsuarioWS UsuarioWS
@inject IMonedaWS MonedaWS
@inject ICuentaBancariaWS CuentaBancariaWS
@using EconomixWA.Components.Pages.ComprobanteDePago

<div class="d-flex flex-column h-100 mb-3">
    <div class="row h-100 mb-3">
        <div class="col-8 h-100 mb-3">
            <div class="card rounded-4 p-3 mb-3 h-100 overflow-scroll">
                <p class="h3">Solicitud de Gasto - No. @(Solicitud?.IdSolicitudGasto > 0 ? Solicitud.IdSolicitudGasto : "-")</p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                        @ErrorMessage
                        <button type="button" class="btn-close" @onclick="() => ErrorMessage = string.Empty" aria-label="close"></button>
                    </div>
                }

                @if (Solicitud == null)
                {
                    <p class="text-muted text-center mt-5">Seleccione una solicitud para evaluar</p>
                }
                else
                {
                    <div class="row">
                        <div class="col-6 mt-3">
                            <label class="form-label">Área</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Solicitud.Solicitante?.Area?.Nombre ?? "-")" disabled="true">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control form-control-lg rounded-4 bg-light" value="@Solicitud.FechaSolicitud.ToString("yyyy-MM-dd")" disabled="true">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Solicitante</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(NombreSolicitante)" disabled="true">
                        </div>
                        <div class="col-6 mt-3">
                            <label class="form-label">Destinatario</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(NombreDestinatario)" disabled="true">
                        </div>
                        <div class="col-4 mt-3">
                            <label class="form-label">Monto</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(SimboloMoneda) @(Solicitud.MontoSolicitado.ToString("N2"))" disabled="true">
                        </div>
                        <div class="col-4 mt-3">
                            <label class="form-label">Moneda</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Solicitud.MonedaOriginal?.Nombre ?? "-")" disabled="true">
                        </div>
                        <div class="col-4 mt-3 align-self-center" style="height: 2rem">
                            <span class="badge h-100 @(EstadoClase) rounded-pill px-2 align-self-start mt-4">@(Solicitud.Estado ?? "PENDIENTE")</span>
                        </div>
                        <div class="col-12 mt-3">
                            <label class="form-label">Ciclo de Caja Chica</label>
                            <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Solicitud.Ciclo?.CajaChica?.Nombre ?? "-") - Semana @(Solicitud.Ciclo?.NumeroSemana ?? 0)" disabled="true">
                        </div>
                        <div class="col-12 mt-3">
                            <label class="form-label">Motivo</label>
                            <textarea class="form-control bg-light" rows="3" disabled="true">@Solicitud.MotivoSolicitud</textarea>
                        </div>

                        @if (EsPendiente)
                        {
                            <div class="col-12 mt-3">
                                <label class="form-label">Decisión / Comentario</label>
                                <textarea class="form-control bg-light" rows="3" placeholder="Comentario de la decisión" @bind="ComentarioDecision"></textarea>
                            </div>
                        }
                        else
                        {
                            <div class="col-12 mt-3">
                                <label class="form-label">Decisión / Comentario</label>
                                <textarea class="form-control bg-light" rows="3" disabled="true">@Solicitud.ComentarioDecision</textarea>
                            </div>
                        }

                        @if (PuedeVerDesembolso)
                        {
                            <div class="col-12 mt-4">
                                <div class="card rounded-4 border-success bg-success-subtle p-3">
                                    <p class="h5 mb-3">@(EsAprobado ? "Ejecutar desembolso" : "Desembolso ejecutado")</p>

                                    @if (TransaccionDesembolso != null)
                                    {
                                        <div class="row mb-3">
                                            <div class="col-6">
                                                <label class="form-label">Nro. Transacción</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="TR-@TransaccionDesembolso.IdTransaccion" disabled="true">
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label">Estado</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@TransaccionDesembolso.EstadoTransaccion" disabled="true">
                                            </div>
                                            <div class="col-6 mt-2">
                                                <label class="form-label">Monto</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(TransaccionDesembolso.Moneda?.Simbolo ?? "S/") @TransaccionDesembolso.Monto.ToString("N2")" disabled="true">
                                            </div>
                                            <div class="col-6 mt-2">
                                                <label class="form-label">Moneda</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(TransaccionDesembolso.Moneda?.Nombre ?? "-")" disabled="true">
                                            </div>
                                            <div class="col-6 mt-2">
                                                <label class="form-label">Cuenta origen</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(TransaccionDesembolso.CuentaOrigen?.NombreBanco ?? "-") - @(TransaccionDesembolso.CuentaOrigen?.NumeroBancario ?? "-")" disabled="true">
                                            </div>
                                            <div class="col-6 mt-2">
                                                <label class="form-label">Beneficiario</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(TransaccionDesembolso.Beneficiario != null ? $"{TransaccionDesembolso.Beneficiario.Nombres} {TransaccionDesembolso.Beneficiario.ApellidoPaterno}" : "-")" disabled="true">
                                            </div>
                                        </div>
                                    }
                                    else if (Solicitud.IdTransaccion > 0)
                                    {
                                        <p class="text-muted">Cargando datos de la transacción...</p>
                                    }
                                    else
                                    {
                                        <p class="text-warning">No se encontró transacción de desembolso registrada.</p>
                                    }

                                    <div class="row">
                                        <div class="col-12 mb-3">
                                            <label class="form-label">Medio de Pago</label>
                                            <select class="form-select form-select-lg rounded-4 bg-white" @bind="MedioDesembolsoSeleccionado" disabled="@(!EsAprobado)">
                                                <option value="TRANSFERENCIA">Transferencia Bancaria</option>
                                                <option value="YAPE">Yape</option>
                                                <option value="PLIN">Plin</option>
                                                <option value="EFECTIVO">Efectivo</option>
                                            </select>
                                        </div>

                                        @if (MedioDesembolsoSeleccionado == "TRANSFERENCIA")
                                        {
                                            <div class="col-12 mb-3">
                                                <label class="form-label">Cuenta destino del solicitante</label>
                                                <select class="form-select form-select-lg rounded-4 bg-white" @bind="CuentaDestinoSeleccionadaId" disabled="@(!EsAprobado)">
                                                    <option value="0">Seleccione...</option>
                                                    @foreach (var cuenta in CuentasSolicitante)
                                                    {
                                                        <option value="@cuenta.IdCuenta">@(cuenta.NombreBanco) - @(cuenta.NumeroBancario) @(MostrarCci(cuenta))</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                        else if (MedioDesembolsoSeleccionado is "YAPE" or "PLIN")
                                        {
                                            <div class="col-12 mb-3">
                                                <label class="form-label">Teléfono / Billetera digital del solicitante</label>
                                                <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Solicitud.Solicitante?.NumeroCelular ?? "-")" disabled="true">
                                            </div>
                                        }

                                        @if (MedioDesembolsoSeleccionado != "EFECTIVO")
                                        {
                                            <div class="col-12 mb-3">
                                                <label class="form-label">Número de operación</label>
                                                <input type="text" class="form-control bg-white rounded-4" placeholder="OP-12345678 / Código Yape / Código Plin" @bind="NumeroOperacionBancaria" disabled="@(!EsAprobado)">
                                            </div>
                                        }

                                        @if (EsAprobado)
                                        {
                                            <div class="col-12">
                                                <button type="button" class="btn btn-success" @onclick="EjecutarDesembolso" disabled="@Procesando">
                                                    @(Procesando ? "Procesando..." : "Marcar desembolso como completado")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (EsPendiente)
                    {
                        <div class="d-flex justify-content-end gap-3 mt-3">
                            <button type="button" class="btn btn-success align-self-start mt-3" @onclick="Aprobar" disabled="@Procesando">
                                @(Procesando ? "Procesando..." : "Aprobar")
                            </button>
                            <button type="button" class="btn btn-outline-warning align-self-start mt-3" @onclick="Observar" disabled="@Procesando">
                                Observar
                            </button>
                            <button type="button" class="btn btn-outline-danger align-self-start mt-3" @onclick="Rechazar" disabled="@Procesando">
                                Rechazar
                            </button>
                            <button type="button" class="btn btn-outline-primary align-self-start mt-3" @onclick="CerrarDetalle" disabled="@Procesando">
                                Cerrar
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-end gap-3 mt-3">
                            <button type="button" class="btn btn-outline-primary align-self-start mt-3" @onclick="CerrarDetalle" disabled="@Procesando">
                                Cerrar
                            </button>
                        </div>
                    }

                    <div class="d-flex flex-fill flex-column mt-4 gap-3 overflow-scroll">
                        <div class="card rounded-4 p-3">
                            <p class="h5">Datos de pago del solicitante</p>
                            @if (Solicitud.Solicitante != null)
                            {
                                <div class="row">
                                    <div class="col-6 mt-2">
                                        <label class="form-label">Teléfono / Billetera digital</label>
                                        <input type="text" class="form-control form-control-lg rounded-4 bg-light" value="@(Solicitud.Solicitante.NumeroCelular ?? "-")" disabled="true">
                                    </div>
                                    <div class="col-12 mt-2">
                                        <label class="form-label">Cuentas bancarias</label>
                                        @if (CuentasSolicitante.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm table-borderless">
                                                    <thead>
                                                        <tr>
                                                            <th>Banco</th>
                                                            <th>Número</th>
                                                            <th>CCI</th>
                                                            <th>Moneda</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var cuenta in CuentasSolicitante)
                                                        {
                                                            <tr>
                                                                <td>@cuenta.NombreBanco</td>
                                                                <td>@cuenta.NumeroBancario</td>
                                                                <td>@(cuenta.Cci ?? "-")</td>
                                                                <td>@(cuenta.Moneda?.Simbolo ?? "-")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-muted">El solicitante no tiene cuentas bancarias registradas.</p>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No hay información del solicitante.</p>
                            }
                        </div>
                    </div>

                    <div class="d-flex flex-fill flex-column mt-4 gap-3 overflow-scroll">
                        <div>
                            @if (Solicitud.Comprobantes?.Any() == true)
                            {
                                @foreach (var comprobante in Solicitud.Comprobantes)
                                {
                                    <ComprobanteDePagoItem EsParteDeSolicitud="true" />
                                }
                            }
                            else
                            {
                                <p class="text-muted text-center">No hay comprobantes registrados</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-4 h-100 mb-3">
            <SolicitudDeGastoSeguimiento Solicitud="Solicitud" />
        </div>
    </div>
</div>

@code {
    private string SimboloMoneda => Solicitud?.MonedaOriginal?.Simbolo ?? "S/";
    private string ErrorMessage { get; set; } = string.Empty;
    private string NumeroOperacionBancaria { get; set; } = string.Empty;
    private string ComentarioDecision { get; set; } = string.Empty;
    private string MedioDesembolsoSeleccionado { get; set; } = "TRANSFERENCIA";
    private int CuentaDestinoSeleccionadaId { get; set; } = 0;
    private bool Procesando { get; set; } = false;

    private List<CuentaBancaria> CuentasSolicitante { get; set; } = new();
    private Transaccion? TransaccionDesembolso { get; set; }

    [Parameter]
    public SolicitudGasto? Solicitud { get; set; }

    [Parameter]
    public EventCallback OnCierraDetalle { get; set; }

    private string NombreSolicitante => Solicitud?.Solicitante != null
        ? $"{Solicitud.Solicitante.Nombres} {Solicitud.Solicitante.ApellidoPaterno}"
        : string.Empty;

    private string NombreDestinatario => Solicitud?.Destinatario != null
        ? $"{Solicitud.Destinatario.Nombres} {Solicitud.Destinatario.ApellidoPaterno}"
        : string.Empty;

    private bool EsPendiente => Solicitud?.Estado?.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase) == true;
    private bool EsAprobado => Solicitud?.Estado?.Equals("APROBADO", StringComparison.OrdinalIgnoreCase) == true;
    private bool PuedeVerDesembolso => EsAprobado
        || Solicitud?.Estado?.Equals("PAGADO", StringComparison.OrdinalIgnoreCase) == true
        || Solicitud?.Estado?.Equals("RENDIDO", StringComparison.OrdinalIgnoreCase) == true;

    private string EstadoClase => Solicitud?.Estado?.ToUpperInvariant() switch
    {
        "PENDIENTE" => "bg-warning-subtle text-warning-emphasis",
        "APROBADO" => "bg-success-subtle text-success",
        "PAGADO" => "bg-primary-subtle text-primary",
        "RECHAZADO" => "bg-danger-subtle text-danger",
        "OBSERVADO" => "bg-info-subtle text-info",
        _ => "bg-secondary-subtle text-secondary"
    };

    protected override async Task OnParametersSetAsync()
    {
        if (Solicitud != null)
        {
            TransaccionDesembolso = null;
            MedioDesembolsoSeleccionado = "TRANSFERENCIA";
            ComentarioDecision = string.Empty;
            NumeroOperacionBancaria = string.Empty;
            CuentaDestinoSeleccionadaId = 0;
            await CargarCuentasSolicitante();
            await CargarTransaccionDesembolso();
        }
    }

    private async Task CargarTransaccionDesembolso()
    {
        if (Solicitud?.IdTransaccion > 0)
        {
            TransaccionDesembolso = await Task.Run(() => TransaccionWS.obtenerPorId(Solicitud.IdTransaccion));
            if (TransaccionDesembolso != null)
            {
                if (!string.IsNullOrWhiteSpace(TransaccionDesembolso.MedioPago))
                    MedioDesembolsoSeleccionado = TransaccionDesembolso.MedioPago;
                if (TransaccionDesembolso.CuentaDestino != null)
                    CuentaDestinoSeleccionadaId = TransaccionDesembolso.CuentaDestino.IdCuenta;
                if (!string.IsNullOrWhiteSpace(TransaccionDesembolso.NumeroOperacionBancaria))
                    NumeroOperacionBancaria = TransaccionDesembolso.NumeroOperacionBancaria;
            }
        }
    }

    private async Task CargarCuentasSolicitante()
    {
        if (Solicitud?.Solicitante == null) return;
        try
        {
            CuentasSolicitante = await Task.Run(() =>
                new List<CuentaBancaria>(CuentaBancariaWS.listarPorEmpleado(Solicitud.Solicitante.UsuarioID)));
        }
        catch
        {
            CuentasSolicitante = new List<CuentaBancaria>();
        }
    }

    private static string MostrarCci(CuentaBancaria cuenta)
    {
        if (string.IsNullOrWhiteSpace(cuenta.Cci)) return string.Empty;
        return $"(CCI: {cuenta.Cci})";
    }

    private bool ValidarEjecucion(out string error)
    {
        error = string.Empty;
        if (MedioDesembolsoSeleccionado == "TRANSFERENCIA" && CuentaDestinoSeleccionadaId <= 0)
        {
            error = "Debe seleccionar una cuenta bancaria destino.";
        }
        else if (MedioDesembolsoSeleccionado != "EFECTIVO" && string.IsNullOrWhiteSpace(NumeroOperacionBancaria))
        {
            error = "Debe ingresar el número de operación.";
        }
        return string.IsNullOrEmpty(error);
    }

    public async Task CerrarDetalle()
    {
        await OnCierraDetalle.InvokeAsync();
    }

    private async Task Aprobar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null || Procesando) return;

        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, true, ComentarioDecision, idUsuarioAccion, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task EjecutarDesembolso()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null || Procesando) return;
        if (!ValidarEjecucion(out var error))
        {
            ErrorMessage = error;
            return;
        }

        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.ejecutarDesembolso(Solicitud.IdSolicitudGasto, MedioDesembolsoSeleccionado, CuentaDestinoSeleccionadaId, NumeroOperacionBancaria, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task Observar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null || Procesando) return;

        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, false, string.IsNullOrWhiteSpace(ComentarioDecision) ? "Observado" : ComentarioDecision, idUsuarioAccion, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task Rechazar()
    {
        ErrorMessage = string.Empty;
        if (Solicitud == null || Procesando) return;

        Procesando = true;
        try
        {
            var idUsuarioAccion = UsuarioWS.GetCurrentUserId();
            await Task.Run(() => SolicitudGastoWS.evaluar(Solicitud.IdSolicitudGasto, false, string.IsNullOrWhiteSpace(ComentarioDecision) ? "Rechazado" : ComentarioDecision, idUsuarioAccion, idUsuarioAccion));
            await OnCierraDetalle.InvokeAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Procesando = false;
        }
    }
}
