@page "/dashboard"
@rendermode InteractiveServer
@inject IUsuarioWS UsuarioWS
@inject ISolicitudGastoWS SolicitudGastoWS
@inject IAuditoriaWS AuditoriaWS
@using System.Collections.Generic;
@using EconomixWA.Components.Pages.MainDashBoard;
@using EconomixWA.Components.Pages.SolicitudDeGasto.SolicitudRecibida;
@using EconomixWA.Components.Pages.SolicitudDeGasto;
@using EconomixWA.Components.Pages.Actividad;

<PageTitle>Dashboard</PageTitle>

<div class="h-100 d-flex flex-column">
    
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-0">@Saludo, @(UsuarioActual?.Nombres ?? "Usuario")</p>    
            <p class="h6 text-muted mb-0">Área: @(AreaUsuario)</p>
        </div>
        <LiveClock />
        <div class="flex-grow-1 text-end"></div>
    </div>

    <div class="d-flex flex-column flex-fill overflow-hidden">
        @switch(Rol){
            case "Jefe":
                <DashboardJefe/>
                <div class="row g-3 flex-fill mt-3 mb-3 overflow-hidden">
                    <div class="col-6 h-100">
                        <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
                            <div class="p-3 pb-2">
                                <h5 class="mb-0">Solicitudes de gasto pendientes</h5>
                            </div>
                            <hr class="my-0" />
                            <div class="overflow-auto flex-fill">
                                @if (CargandoSolicitudesJefe)
                                {
                                    <div class="p-3 text-center text-muted">Cargando solicitudes...</div>
                                }
                                else if (SolicitudesPendientesJefe.Count == 0)
                                {
                                    <div class="p-3 text-center text-muted">No hay solicitudes pendientes</div>
                                }
                                else
                                {
                                    @foreach (var s in SolicitudesPendientesJefe)
                                    {
                                        <SolicitudDeGastoPendiente Nombre="@(s.Solicitante?.Nombres ?? "Sin nombre")"
                                                                  Concepto="@(s.MotivoSolicitud ?? "Sin concepto")"
                                                                  Fecha="s.FechaSolicitud"
                                                                  Prioridad="@(s.FechaSolicitud < DateTime.Now.AddDays(-2) ? "Urgente" : "")"
                                                                  IsoMoneda="@(s.MonedaOriginal?.Simbolo ?? "S/.")"
                                                                  Monto="s.MontoSolicitado" />
                                    }
                                }
                            </div>
                        </div>    
                    </div>
                    <div class="col-6 h-100">
                        <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">     
                            <div class="p-3 pb-2">
                                <h5 class="mb-0">Acciones Recientes</h5>
                            </div>
                            <hr class="my-0" />
                            <div class="overflow-auto flex-fill">
                                @if (CargandoActividadJefe)
                                {
                                    <div class="p-3 text-center text-muted">Cargando actividad...</div>
                                }
                                else if (ActividadRecienteJefe.Count == 0)
                                {
                                    <div class="p-3 text-center text-muted">No hay actividad reciente</div>
                                }
                                else
                                {
                                    @foreach (var a in ActividadRecienteJefe)
                                    {
                                        <ActividadRecienteItem Titulo="@a.Titulo"
                                                               Modulo="@a.Modulo"
                                                               Usuario="@a.Usuario"
                                                               Area="@a.Area"
                                                               Descripcion="@a.Descripcion"
                                                               Monto="@a.Monto"
                                                               Estado="@a.Estado"
                                                               Fecha="a.Fecha" />
                                    }
                                }
                            </div>
                        </div>    
                    </div>
                </div>
                break;
            case "Empleado":
                <DashboardEmpleado/>
                break;
            case "Tesoreria":
                <DashboardTesoreria/>
                break;
            case "Administrador":
                <DashboardAdministrador/>
                break;
            default:
                break;
        }
    </div>
</div>

@code{
    private EconomixModel.Model.Usuario? UsuarioActual { get; set; }
    private string Rol => ObtenerRol();
    private string Saludo => ObtenerSaludo();
    private string AreaUsuario => UsuarioActual switch
    {
        Empleado emp when emp.Area != null => emp.Area.Nombre,
        Administrador => "Administración",
        _ => "Sin área asignada"
    };

    private bool CargandoSolicitudesJefe { get; set; } = true;
    private bool CargandoActividadJefe { get; set; } = true;
    private List<SolicitudGasto> SolicitudesPendientesJefe { get; set; } = new();
    private List<ActividadDto> ActividadRecienteJefe { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            UsuarioActual = UsuarioWS.GetCurrentUser();
        }
        catch
        {
            UsuarioActual = null;
        }

        if (Rol == "Jefe")
        {
            await Task.WhenAll(
                CargarSolicitudesPendientesJefe(),
                CargarActividadRecienteJefe());
        }
    }

    private async Task CargarSolicitudesPendientesJefe()
    {
        CargandoSolicitudesJefe = true;
        try
        {
            var idJefe = UsuarioWS.GetCurrentUserId();
            var todas = await Task.Run(() => SolicitudGastoWS.listar());
            SolicitudesPendientesJefe = todas
                .Where(s => s.Estado.Equals("PENDIENTE", StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(s => s.FechaSolicitud)
                .Take(10)
                .ToList();
        }
        catch
        {
            SolicitudesPendientesJefe = new List<SolicitudGasto>();
        }
        CargandoSolicitudesJefe = false;
    }

    private async Task CargarActividadRecienteJefe()
    {
        CargandoActividadJefe = true;
        try
        {
            var logs = await Task.Run(() => AuditoriaWS.listarRecientes(10));
            ActividadRecienteJefe = logs.Select(l => new ActividadDto
            {
                Titulo = l.Descripcion ?? "Sin descripción",
                Modulo = l.EntidadNombre ?? "Sistema",
                Usuario = l.NombreCompletoUsuario ?? "Sistema",
                Area = l.EntidadNombre ?? "-",
                Descripcion = l.Descripcion ?? "-",
                Monto = "-",
                Estado = l.AccionNombre ?? "-",
                Fecha = l.CreadoAt
            }).ToList();
        }
        catch
        {
            ActividadRecienteJefe = new List<ActividadDto>();
        }
        CargandoActividadJefe = false;
    }

    private string ObtenerRol()
    {
        return UsuarioActual switch
        {
            Administrador => "Administrador",
            Empleado emp => DeterminarRolEmpleado(emp),
            _ => "Empleado"
        };
    }

    private string DeterminarRolEmpleado(Empleado emp)
    {
        if (emp.Area != null && !string.IsNullOrEmpty(emp.Area.Nombre) &&
            emp.Area.Nombre.Contains("Tesorer", StringComparison.OrdinalIgnoreCase))
        {
            return "Tesoreria";
        }

        return emp.RolFlujo == RolFlujo.JEFE_AREA ? "Jefe" : "Empleado";
    }

    private string ObtenerSaludo()
    {
        var hora = DateTime.Now.Hour;
        return hora switch
        {
            >= 6 and < 12 => "Buenos días",
            >= 12 and < 19 => "Buenas tardes",
            _ => "Buenas noches"
        };
    }

    private class ActividadDto
    {
        public string Titulo { get; set; } = string.Empty;
        public string Modulo { get; set; } = string.Empty;
        public string Usuario { get; set; } = string.Empty;
        public string Area { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public string Monto { get; set; } = "-";
        public string Estado { get; set; } = string.Empty;
        public DateTime Fecha { get; set; }
    }
}
