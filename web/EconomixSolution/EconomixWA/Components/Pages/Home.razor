@page "/dashboard"
@rendermode InteractiveServer
@inject IUsuarioWS UsuarioWS
@using System.Collections.Generic;
@using EconomixWA.Components.Pages.MainDashBoard;
@using EconomixWA.Components.Pages.SolicitudDeGasto.SolicitudRecibida;
@using EconomixWA.Components.Pages.SolicitudDeGasto;
@using EconomixWA.Components.Pages.Actividad;



<PageTitle>Dashboard</PageTitle>

<div class ="d-flex flex-column h-100">
    
    <div class="d-flex flex-row justify-content-between pb-3">
        <div class="d-flex flex-column">
            <p class="h4">@Saludo, @(UsuarioActual?.Nombres ?? "Usuario")</p>    
            <p class="h6">Área: @(AreaUsuario)</p>
        </div>
        <div class="d-flex flex-column align-items-end">
            <p class="h5 mb-0">@FechaHoy</p>
        </div>
    </div>

    
    @switch(Rol){
        case "Jefe":
            <DashboardJefe/>
            <div class="row mt-3 overflow-hidden pb-3">
                <div class="col-6 h-100">
                    <div class="card rounded-4 pt-3 h-100 d-flex flex-column">
                        <h5 class="h2 ms-3">Solicitudes de gasto pendientes</h5>
                        <div class="overflow-scroll flex-fill pb-3">
                            @foreach(String nombre in Nombres){
                                <SolicitudDeGastoPendiente Nombre="@nombre"/>
                            }
                        </div>
                    </div>    
                </div>
                <div class="col-6 h-100">
                    <div class="card rounded-4 pt-3 h-100 d-flex flex-column">     
                        <h5 class="h2 ms-3">Acciones Recientes</h5>
                        <div class="overflow-scroll flex-fill">
                            @for(int i = 0; i < 100; i++){
                               <ActividadRecienteItem/>
                            }
                        </div>
                    </div>    
                </div>
            </div>
            break;
        case "Empleado":
            <DashboardEmpleado/>
            break;
        case "Tesoreria":
            <DashboardTesoreria/>
            break;
        case "Administrador":
            <DashboardAdministrador/>
            break;
        default:
            break;
    }
</div>

@code{
    public List<String> Nombres = new List<String>(){"Mario Hugo", "Tulio Tribiño", "Gregorio Samsaaaa", "Juan Carlos BOdoque",
                                                        "Mario Hugo", "Tulio Tribiño", "Gregorio Samsaaaa", "Juan Carlos BOdoque",
    
                                                    
                                                    string.Empty};

    private EconomixModel.Model.Usuario? UsuarioActual { get; set; }
    private string Rol => ObtenerRol();
    private string Saludo => ObtenerSaludo();
    private string FechaHoy => DateTime.Now.ToString("d/M/yyyy");
    private string AreaUsuario => UsuarioActual switch
    {
        Empleado emp when emp.Area != null => emp.Area.Nombre,
        Administrador => "Administración",
        _ => "Sin área asignada"
    };

    protected override void OnInitialized()
    {
        try
        {
            UsuarioActual = UsuarioWS.GetCurrentUser();
        }
        catch
        {
            UsuarioActual = null;
        }
    }

    private string ObtenerRol()
    {
        return UsuarioActual switch
        {
            Administrador => "Administrador",
            Empleado emp => DeterminarRolEmpleado(emp),
            _ => "Empleado"
        };
    }

    private string DeterminarRolEmpleado(Empleado emp)
    {
        if (emp.Area != null && !string.IsNullOrEmpty(emp.Area.Nombre) &&
            emp.Area.Nombre.Contains("Tesorer", StringComparison.OrdinalIgnoreCase))
        {
            return "Tesoreria";
        }

        return emp.RolFlujo == RolFlujo.JEFE_AREA ? "Jefe" : "Empleado";
    }

    private string ObtenerSaludo()
    {
        var hora = DateTime.Now.Hour;
        return hora switch
        {
            >= 6 and < 12 => "Buenos días",
            >= 12 and < 19 => "Buenas tardes",
            _ => "Buenas noches"
        };
    }
}



