@page "/dashboard"
@rendermode InteractiveServer
@inject IUsuarioWS UsuarioWS
@inject ISolicitudGastoWS SolicitudGastoWS

@inject IEmpleadoWS EmpleadoWS
@using System.Collections.Generic;
@using EconomixWA.Components.Pages.MainDashBoard;
@using EconomixWA.Components.Pages.SolicitudDeGasto.SolicitudRecibida;
@using EconomixWA.Components.Pages.SolicitudDeGasto;
@using EconomixWA.Components.Pages.SolicitudDeGasto.MiSolicitudesDeGasto;


<PageTitle>Dashboard</PageTitle>

<div class="h-100 d-flex flex-column">
    
    <div class="d-flex flex-row align-items-center mb-4">
        <div class="flex-grow-1">
            <p class="h4 mb-1">@Saludo, @(UsuarioActual?.Nombres ?? "Usuario")</p>    
            <p class="h6 text-muted mb-0">Área: @(AreaUsuario)</p>
        </div>
        <LiveClock />
        <div class="flex-grow-1 text-end"></div>
    </div>

    <div class="d-flex flex-column flex-fill overflow-hidden">
        @if (UsuarioActual == null)
        {
            <div class="d-flex justify-content-center align-items-center h-100">
                <p class="text-muted">Cargando...</p>
            </div>
        }
        else
        {
        @switch(Rol){
            case "Jefe":
                <DashboardJefe/>
                break;
            case "Empleado":
                <DashboardEmpleado/>
                <div class="row g-3 flex-fill mt-3 mb-3 overflow-hidden d-flex">
                    <div class="col-6 h-100 d-flex flex-column overflow-hidden">
                        <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
                            <div class="p-3 pb-2">
                                <h5 class="mb-0">Mis solicitudes</h5>
                            </div>
                            <hr class="my-0" />
                            <div class="overflow-scroll flex-fill">
                                @if (CargandoSolicitudesEmp)
                                {
                                    <div class="p-3 text-center text-muted">Cargando solicitudes...</div>
                                }
                                else if (SolicitudesEmpleado.Count == 0)
                                {
                                    <div class="p-3 text-center text-muted">No tiene solicitudes registradas</div>
                                }
                                else
                                {
                                    @foreach (var s in SolicitudesEmpleado)
                                    {
                                        <MiSolicitudDeGastoItem Solicitud="s" OnMuestraDetalle="() => SeleccionarSolicitudEmp(s)" />
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-6 h-100 d-flex flex-column overflow-hidden">
                        @if (SolicitudSeleccionadaEmp != null)
                        {
                            <SolicitudDeGastoSeguimiento Solicitud="SolicitudSeleccionadaEmp" />
                        }
                        else
                        {
                            <div class="card rounded-4 h-100 d-flex flex-column overflow-hidden">
                                <div class="p-3 pb-2">
                                    <h5 class="mb-0">Estado de solicitud</h5>
                                </div>
                                <hr class="my-0" />
                                <div class="overflow-scroll flex-fill d-flex align-items-center justify-content-center">
                                    <p class="text-muted">Seleccione una solicitud para ver su estado</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                break;
            case "Tesoreria":
                <DashboardTesoreria/>
                break;
            case "Administrador":
                <DashboardAdministrador/>
                break;
            default:
                break;
        }
        }
    </div>
</div>

@code{
    private EconomixModel.Model.Usuario? UsuarioActual { get; set; }
    private string Rol => ObtenerRol();
    private string Saludo => ObtenerSaludo();
    private string AreaUsuario => UsuarioActual switch
    {
        Empleado emp when emp.Area != null => emp.Area.Nombre,
        Administrador => "Administración",
        _ => "Sin área asignada"
    };

    private bool CargandoSolicitudesEmp { get; set; } = true;
    private List<SolicitudGasto> SolicitudesEmpleado { get; set; } = new();
    private SolicitudGasto? SolicitudSeleccionadaEmp { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            UsuarioActual = UsuarioWS.GetCurrentUser();
        }
        catch
        {
            UsuarioActual = null;
        }

        if (UsuarioActual is Empleado emp && emp.Area == null)
        {
            try
            {
                var empCompleto = await EmpleadoWS.obtenerPorIdAsync(emp.UsuarioID);
                if (empCompleto?.Area != null)
                    emp.Area = empCompleto.Area;
            }
            catch { }
        }

        if (Rol == "Empleado")
        {
            await CargarSolicitudesEmpleado();
        }
    }

    private async Task CargarSolicitudesEmpleado()
    {
        CargandoSolicitudesEmp = true;
        try
        {
            var id = UsuarioWS.GetCurrentUserId();
            var todas = await SolicitudGastoWS.listarPorSolicitanteAsync(id);
            SolicitudesEmpleado = todas
                .OrderByDescending(s => s.FechaSolicitud)
                .Take(20)
                .ToList();
        }
        catch
        {
            SolicitudesEmpleado = new();
        }
        CargandoSolicitudesEmp = false;
    }

    private void SeleccionarSolicitudEmp(SolicitudGasto s)
    {
        SolicitudSeleccionadaEmp = s;
    }

    private string ObtenerRol()
    {
        return UsuarioActual switch
        {
            Administrador => "Administrador",
            Empleado emp => DeterminarRolEmpleado(emp),
            _ => "Empleado"
        };
    }

    private string DeterminarRolEmpleado(Empleado emp)
    {
        if (emp.Area != null && !string.IsNullOrEmpty(emp.Area.Nombre) &&
            emp.Area.Nombre.Contains("Tesorer", StringComparison.OrdinalIgnoreCase))
        {
            return "Tesoreria";
        }

        return emp.RolFlujo == RolFlujo.JEFE_AREA ? "Jefe" : "Empleado";
    }

    private string ObtenerSaludo()
    {
        var hora = DateTime.Now.Hour;
        return hora switch
        {
            >= 6 and < 12 => "Buenos días",
            >= 12 and < 19 => "Buenas tardes",
            _ => "Buenas noches"
        };
    }
}
