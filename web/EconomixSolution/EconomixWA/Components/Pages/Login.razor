@page "/"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.WebUtilities
@layout LoginLayout
@inject NavigationManager Navigation

<div class="card shadow-lg p-4 rounded-4" style="width: 400px;">
    <div class="text-center mb-4">
        <h2 class="fw-bold">ECONOMIX</h2>
        <p class="text-muted">Iniciar sesión en tu cuenta</p>
    </div>

    @if (MostrarError)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            Las credenciales ingresadas son incorrectas
            <button type="button" class="btn-close" @onclick="() => MostrarError = false" aria-label="close"></button>
        </div>
    }

    @if (MostrarBloqueo)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            Cuenta bloqueada por demasiados intentos fallidos. Intente nuevamente en 15 minutos.
            <button type="button" class="btn-close" @onclick="() => MostrarBloqueo = false" aria-label="close"></button>
        </div>
    }

    @if (MostrarInactivo)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            El usuario se encuentra inactivo o ha sido eliminado. Contacte con el administrador.
            <button type="button" class="btn-close" @onclick="() => MostrarInactivo = false" aria-label="close"></button>
        </div>
    }

    <form action="/auth/login" method="post" onsubmit="showLoginLoading(event)">
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />
        
        <div class="mb-3">
            <label class="form-label text-muted small fw-semibold">Correo electrónico</label>
            <input type="email" name="usuario" class="form-control rounded-4 bg-light" placeholder="usuario@empresa.com" required />
        </div>

        <div class="mb-3">
            <label class="form-label text-muted small fw-semibold">Contraseña</label>
            <input type="password" name="password" class="form-control rounded-4 bg-light" placeholder="********" required />
        </div>

        <div class="d-grid gap-2 mt-4">
            <button type="submit" id="login-btn" class="btn btn-primary rounded-4 fw-semibold py-2">
                Iniciar sesión
            </button>
        </div>
    </form>
</div>

@code {
    private bool MostrarError { get; set; } = false;
    private bool MostrarBloqueo { get; set; } = false;
    private bool MostrarInactivo { get; set; } = false;
    private string ReturnUrl { get; set; } = "";

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var errorVal))
        {
            MostrarError = errorVal == "1";
            MostrarBloqueo = errorVal == "blocked";
            MostrarInactivo = errorVal == "inactive";
        }
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("returnUrl", out var returnUrlVal))
        {
            ReturnUrl = returnUrlVal.ToString();
        }
    }
}

<script>
    function showLoginLoading(e) {
        e.preventDefault();
        var btn = document.getElementById('login-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Iniciando sesión...';
        var form = e.target;
        setTimeout(function () { form.submit(); }, 60);
    }
</script>
