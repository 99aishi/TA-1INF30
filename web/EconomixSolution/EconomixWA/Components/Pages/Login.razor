@page "/"
@layout LoginLayout
@inject NavigationManager Navigation

<div class="card p-5 rounded-4 shadow-lg" style="width: 420px; background: rgba(30, 41, 59, 0.45); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); color: #f8fafc;">
    <div class="text-center mb-4">
        <h2 class="fw-bold mb-1" style="background: linear-gradient(135deg, #a78bfa 0%, #60a5fa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">ECONOMIX</h2>
        <p class="text-white-50 small">Iniciar sesión en tu cuenta</p>
    </div>

    @if (MostrarError)
    {
        <div class="alert alert-danger border-0 text-white shadow-sm mb-4" role="alert" style="background: rgba(239, 68, 68, 0.2); border-left: 4px solid #ef4444 !important;">
            <div class="d-flex justify-content-between align-items-center">
                <span>Las credenciales ingresadas son incorrectas</span>
                <button type="button" class="btn-close btn-close-white" @onclick="() => MostrarError = false" aria-label="close"></button>
            </div>
        </div>
    }

    @if (MostrarBloqueo)
    {
        <div class="alert alert-warning border-0 text-white shadow-sm mb-4" role="alert" style="background: rgba(245, 158, 11, 0.2); border-left: 4px solid #f59e0b !important;">
            <div class="d-flex justify-content-between align-items-center">
                <span class="small">Cuenta bloqueada por demasiados intentos fallidos. Intente nuevamente en 15 minutos.</span>
                <button type="button" class="btn-close btn-close-white" @onclick="() => MostrarBloqueo = false" aria-label="close"></button>
            </div>
        </div>
    }

    @if (MostrarInactivo)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            El usuario se encuentra inactivo o ha sido eliminado. Contacte con el administrador.
            <button type="button" class="btn-close" @onclick="() => MostrarInactivo = false" aria-label="close"></button>
        </div>
    }

    <form action="/auth/login" method="post" onsubmit="showLoginLoading(event)">
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />
        
        <div class="mb-3">
            <label class="form-label text-white-50 small fw-semibold">Correo electrónico</label>
            <input type="email" name="usuario" class="form-control form-control-lg bg-transparent text-white border-secondary-subtle rounded-3" placeholder="usuario@empresa.com" required style="background: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(255, 255, 255, 0.15) !important;" />
        </div>

        <div class="mb-4">
            <label class="form-label text-white-50 small fw-semibold">Contraseña</label>
            <input type="password" name="password" class="form-control form-control-lg bg-transparent text-white border-secondary-subtle rounded-3" placeholder="********" required style="background: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(255, 255, 255, 0.15) !important;" />
        </div>

        <div class="d-grid gap-2 mt-2">
            <button type="submit" id="login-btn" class="btn btn-primary-glow btn-lg rounded-3 fw-semibold py-2 shadow-sm transition-all">
                Iniciar sesión
            </button>
        </div>
    </form>
</div>

<style>
    .btn-primary-glow {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border: none;
        color: white;
    }
    .btn-primary-glow:hover {
        background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
        color: white;
    }
    .btn-primary-glow:active {
        transform: scale(0.98);
    }
    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.3) !important;
    }
    .form-control:focus {
        background: rgba(255, 255, 255, 0.08) !important;
        border-color: #6366f1 !important;
        box-shadow: 0 0 8px rgba(99, 102, 241, 0.3) !important;
        color: white !important;
    }
</style>

@code {
    private bool MostrarError { get; set; } = false;
    private bool MostrarBloqueo { get; set; } = false;
    private bool MostrarInactivo { get; set; } = false;
    private string ReturnUrl { get; set; } = "";

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var errorVal))
        {
            MostrarError = errorVal == "1";
            MostrarBloqueo = errorVal == "blocked";
            MostrarInactivo = errorVal == "inactive";
        }
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("returnUrl", out var returnUrlVal))
        {
            ReturnUrl = returnUrlVal.ToString();
        }
    }
}

<script>
    function showLoginLoading(e) {
        e.preventDefault();
        var btn = document.getElementById('login-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Iniciando sesión...';
        var form = e.target;
        setTimeout(function () { form.submit(); }, 60);
    }
</script>
