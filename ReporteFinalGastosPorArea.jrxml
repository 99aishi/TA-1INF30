<jasperReport name="GastosPorArea" language="groovy" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30" uuid="ace012be-cb50-4fbe-b557-f13e61fed332">
