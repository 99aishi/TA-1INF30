	<parameter name="FECHA_INICIO" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="FECHA_FIN" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    a.id_area                           AS id_area,
    a.nombre_area                       AS nombre_area,
    COUNT(cp.id_comprobante)            AS cantidad_comprobantes,
    COALESCE(SUM(cp.monto_subtotal), 0)       AS subtotal,
    COALESCE(SUM(cp.monto_igv), 0)            AS igv,
    COALESCE(SUM(cp.monto_total), 0)    AS total
FROM ope_comprobante_pago cp
INNER JOIN ope_solicitud_gasto sg
    ON cp.id_solicitud_gasto = sg.id_solicitud_gasto
INNER JOIN rrhh_empleado e
    ON sg.id_usuario_solicitante = e.id_usuario
INNER JOIN rrhh_area a
    ON e.id_area = a.id_area
WHERE
    cp.estado_comprobante = 'APROBADO'
    AND cp.fecha_emision BETWEEN $P{FECHA_INICIO} AND $P{FECHA_FIN}
GROUP BY
    a.id_area,
    a.nombre_area
ORDER BY
    total DESC]]></query>
