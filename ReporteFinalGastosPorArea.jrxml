		<property name="com.jaspersoft.studio.field.name" value="id_area"/>
		<property name="com.jaspersoft.studio.field.label" value="id_area"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="rrhh_area"/>
	</field>
	<field name="nombre_area" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nombre_area"/>
		<property name="com.jaspersoft.studio.field.label" value="nombre_area"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="rrhh_area"/>
	</field>
	<field name="cantidad_comprobantes" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="cantidad_comprobantes"/>
		<property name="com.jaspersoft.studio.field.label" value="cantidad_comprobantes"/>
	</field>
	<field name="subtotal" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="subtotal"/>
		<property name="com.jaspersoft.studio.field.label" value="subtotal"/>
	</field>
	<field name="igv" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="igv"/>
		<property name="com.jaspersoft.studio.field.label" value="igv"/>
	</field>
	<field name="total" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="total"/>
		<property name="com.jaspersoft.studio.field.label" value="total"/>
	</field>
	<variable name="TOTAL_COMPROBANTES" calculation="Sum" class="java.lang.Long">
		<expression><![CDATA[$F{cantidad_comprobantes}]]></expression>
	</variable>
	<variable name="TOTAL_SUBTOTAL" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{subtotal}]]></expression>
	</variable>
	<variable name="TOTAL_IGV" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{igv}]]></expression>
	</variable>
	<variable name="TOTAL_GENERAL" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{total}]]></expression>
	</variable>
	<variable name="ROW_NUMBER" calculation="Count" class="java.lang.Integer">
		<expression><![CDATA[$F{id_area}]]></expression>
	</variable>
